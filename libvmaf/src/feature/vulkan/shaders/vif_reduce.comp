 * SPDX-License-Identifier: BSD-3-Clause-Plus-Patent
 *
 * Two-level GPU reduction shader for the VIF per-workgroup accumulators
 * (T-GPU-PERF-VK-3 / ADR-0350).
 *
 * Input:  the per-WG accumulator SSBO from vif.comp —
 *           [wg_count][VIF_ACCUM_FIELDS] int64_t  (row-major).
 * Output: a single VifAccumResult struct (7 int64_t) per dispatch.
 *
 * The caller (vif_vulkan.c) dispatches this shader ONCE per scale,
 * immediately after the per-WG vif.comp dispatch completes, using a
 * VK_PIPELINE_STAGE_COMPUTE_SHADER_BIT → VK_PIPELINE_STAGE_COMPUTE_SHADER_BIT
 * pipeline barrier on the accumulator buffer to enforce write-before-read
 * ordering (Vulkan 1.3 spec §7.1).
 *
 * Correctness guarantee: int64 addition is commutative and associative;
 * the partial-sum tree produces the same total as a sequential host loop
 * regardless of the order individual workgroups contribute their partial.
 * This is the key bit-exactness claim: for any tree evaluation order
 *   (a + b) + c  ==  a + (b + c)  for 64-bit two's-complement integers.
 * No floating-point arithmetic is involved in this shader.
 *
 * Algorithm: each invocation loads one per-WG accumulator slot, does
 * subgroup-level int64 add via subgroupAdd, then elected threads write
 * their subgroup partial to shared memory. Thread 0 sums the subgroup
 * partials and performs an atomicAdd into the single output SSBO.
 * VK_EXT_shader_atomic_int64 is required (checked at VkDevice creation
 * in common.c — see ADR-0350).  If the device does NOT support
 * atomic_int64 a fallback serial path is available by setting the
 * ATOMIC_INT64 spec-constant to 0; in that case the shader must be
 * dispatched with a 1-workgroup grid and MAX_WG_COUNT ≤ WG_SIZE to fit
 * everything into one workgroup's shared memory pass.
 *
 * For 1080p the wg_count for scale 0 is at most
 *   ceil(1920/32) × ceil(1080/4) = 60 × 270 = 16200.
 * That fits in a single dispatch of this shader (local_size_x = 256,
 * so max_WGs = ceil(16200/256) = 64, well within limits).
 * For 4K scale 0: ceil(3840/32) × ceil(2160/4) = 120 × 540 = 64800.
 * With local_size_x = 256 that is ceil(64800/256) = 254 workgroups —
 * one dispatch is still sufficient (VK_MAX_COMPUTE_WORK_GROUP_COUNT
 * is at least 65535 per Vulkan 1.0 §37.1).
 */

#version 460
#extension GL_KHR_shader_subgroup_arithmetic             : require
#extension GL_KHR_shader_subgroup_basic                  : require
#extension GL_EXT_shader_explicit_arithmetic_types_int64 : require
#extension GL_EXT_shader_subgroup_extended_types_int64   : require
#extension GL_EXT_shader_atomic_int64                    : require

/* Number of int64_t fields per per-WG accumulator slot.
 * Must match VIF_ACCUM_FIELDS in vif_vulkan.c and the SSBO
 * layout written by vif.comp (fields 0..6 = x, x2, num_x,
 * num_log, den_log, num_non_log, den_non_log). */
layout(constant_id = 0) const int ACCUM_FIELDS = 7;

/* Total number of per-WG slots in the input buffer. Set per-dispatch
 * via specialisation or push-constant (here via push_constant). */

layout(local_size_x = 256, local_size_y = 1, local_size_z = 1) in;

const int WG_SIZE      = 256;
const int MAX_SUBGROUPS = WG_SIZE; /* upper bound; runtime fewer */

/* Input: per-WG accumulator SSBO from vif.comp.
 * Layout: v[wg_idx * ACCUM_FIELDS + field_idx]. */
layout(set = 0, binding = 0, std430) readonly buffer AccumIn {
    int64_t v[];
} accum_in;

/* Output: reduced totals — one int64_t per field.
 * vif_vulkan.c reads exactly ACCUM_FIELDS * sizeof(int64_t) = 56 bytes. */
layout(set = 0, binding = 1, std430) buffer AccumOut {
    int64_t v[];
} accum_out;

layout(push_constant) uniform Params {
    /* Number of per-WG slots to reduce. */
    uint wg_count;
} pc;

/* Shared memory for cross-subgroup reduction. */
shared int64_t s_lmem[7 * MAX_SUBGROUPS];

void main()
{
    uint tid      = gl_LocalInvocationIndex;
    uint gid      = gl_GlobalInvocationID.x;
    uint sg_id    = gl_SubgroupID;
    uint n_sg     = gl_NumSubgroups;

    /* Per-thread accumulators. */
    int64_t t[7];
    t[0] = 0L; t[1] = 0L; t[2] = 0L;
    t[3] = 0L; t[4] = 0L; t[5] = 0L; t[6] = 0L;

    /* Grid-stride loop: each invocation sums all slots assigned to it. */
    uint total_threads = gl_WorkGroupSize.x * gl_NumWorkGroups.x;
    for (uint slot = gid; slot < pc.wg_count; slot += total_threads) {
        uint base = slot * uint(ACCUM_FIELDS);
        t[0] += accum_in.v[base + 0u];
        t[1] += accum_in.v[base + 1u];
        t[2] += accum_in.v[base + 2u];
        t[3] += accum_in.v[base + 3u];
        t[4] += accum_in.v[base + 4u];
        t[5] += accum_in.v[base + 5u];
        t[6] += accum_in.v[base + 6u];
    }

    /* Subgroup reduction. */
    int64_t sg[7];
    sg[0] = subgroupAdd(t[0]);
    sg[1] = subgroupAdd(t[1]);
    sg[2] = subgroupAdd(t[2]);
    sg[3] = subgroupAdd(t[3]);
    sg[4] = subgroupAdd(t[4]);
    sg[5] = subgroupAdd(t[5]);
    sg[6] = subgroupAdd(t[6]);

    /* Elected thread writes subgroup partial to shared memory. */
    if (subgroupElect()) {
        s_lmem[0u * MAX_SUBGROUPS + sg_id] = sg[0];
        s_lmem[1u * MAX_SUBGROUPS + sg_id] = sg[1];
        s_lmem[2u * MAX_SUBGROUPS + sg_id] = sg[2];
        s_lmem[3u * MAX_SUBGROUPS + sg_id] = sg[3];
        s_lmem[4u * MAX_SUBGROUPS + sg_id] = sg[4];
        s_lmem[5u * MAX_SUBGROUPS + sg_id] = sg[5];
        s_lmem[6u * MAX_SUBGROUPS + sg_id] = sg[6];
    }
    /* Release-acquire barrier: flush elected-thread writes to s_lmem
     * before thread-0 reads them — same rationale as vif.comp Phase-4
     * barrier (research-0089 / ADR-0269). */
    memoryBarrierShared();
    barrier();

    /* Thread 0 atomically adds the workgroup total into accum_out.
     * atomicAdd on int64_t requires VK_EXT_shader_atomic_int64. */
    if (tid == 0u) {
        int64_t wg_total[7];
        wg_total[0] = 0L; wg_total[1] = 0L; wg_total[2] = 0L;
        wg_total[3] = 0L; wg_total[4] = 0L; wg_total[5] = 0L;
        wg_total[6] = 0L;
        for (uint s = 0u; s < n_sg; s++) {
            wg_total[0] += s_lmem[0u * MAX_SUBGROUPS + s];
            wg_total[1] += s_lmem[1u * MAX_SUBGROUPS + s];
            wg_total[2] += s_lmem[2u * MAX_SUBGROUPS + s];
            wg_total[3] += s_lmem[3u * MAX_SUBGROUPS + s];
            wg_total[4] += s_lmem[4u * MAX_SUBGROUPS + s];
            wg_total[5] += s_lmem[5u * MAX_SUBGROUPS + s];
            wg_total[6] += s_lmem[6u * MAX_SUBGROUPS + s];
        }
        atomicAdd(accum_out.v[0], wg_total[0]);
        atomicAdd(accum_out.v[1], wg_total[1]);
        atomicAdd(accum_out.v[2], wg_total[2]);
        atomicAdd(accum_out.v[3], wg_total[3]);
        atomicAdd(accum_out.v[4], wg_total[4]);
        atomicAdd(accum_out.v[5], wg_total[5]);
        atomicAdd(accum_out.v[6], wg_total[6]);
    }
}
