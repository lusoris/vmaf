 *
 * Vulkan compute shader for the float_motion feature extractor.
 *
 * CPU reference: libvmaf/src/feature/float_motion.c (separable 5-tap
 * Gaussian blur of the reference plane via convolution_f32_c_s + SAD
 * between consecutive blurred reference frames in float).
 *
 * Algorithm (must match CPU float_motion):
 *   1. Convert ref pixel: `val = (raw / scaler) - 128.0`  (offset = -128;
 *      scaler is 1 for bpc=8, 4 / 16 / 256 for bpc=10/12/16).
 *   2. Vertical filter (5-tap FILTER_5_s):
 *        v[i,j] = sum_k FILTER_5_s[k] * ref[mirror(i-2+k), j]
 *   3. Horizontal filter:
 *        b[i,j] = sum_k FILTER_5_s[k] * v[i, mirror(j-2+k)]
 *   4. Frame > 0: SAD += |b[i,j] - prev_b[i,j]|   (per-pixel float)
 *      score = SAD / (w * h)   (host-side double accum)
 *
 * FILTER_5_s = {0.054488685, 0.244201342, 0.402619947, 0.244201342,
 *               0.054488685}, sums to ~1.0.
 *
 * Mirror padding: skip-boundary reflective mirror
 *   `2 * (sup - 1) - idx` for idx >= sup
 * Matches CPU `convolution_internal.h::convolution_edge_s` (NOT
 * float_motion_v2's edge-replicating mirror).
 *
 * Specialization constants:
 *   constant_id = 0  WIDTH
 *   constant_id = 1  HEIGHT
 *   constant_id = 2  BPC            8 / 10 / 12 / 16
 *   constant_id = 3  COMPUTE_SAD    0 = first frame, 1 = SAD vs prev
 *   constant_id = 4  SUBGROUP_SIZE  32 (default)
 *
 * Bindings:
 *   binding 0: ref input plane (uint8 / uint16 packed in uint32)
 *   binding 1: cur blurred output (float per pixel)
 *   binding 2: prev blurred input (float per pixel) — only read when
 *              COMPUTE_SAD == 1
 *   binding 3: per-WG float SAD partials
 */

#version 460
#extension GL_KHR_shader_subgroup_arithmetic : require
#extension GL_KHR_shader_subgroup_basic      : require

layout(local_size_x = 32, local_size_y = 4, local_size_z = 1) in;

layout(constant_id = 0) const int WIDTH         = 0;
layout(constant_id = 1) const int HEIGHT        = 0;
layout(constant_id = 2) const int BPC           = 8;
layout(constant_id = 3) const int SUBGROUP_SIZE = 32;

const int FW       = 5;
const int HALF_FW  = 2;
const int WG_X     = 32;
const int WG_Y     = 4;
const int WG_SIZE  = WG_X * WG_Y;
const int MAX_SUBGROUPS = WG_SIZE;

const float FILT[5] = float[5](
    0.054488685, 0.244201342, 0.402619947, 0.244201342, 0.054488685
);

const int TILE_H = WG_Y + FW - 1;   /* 8  */
const int TILE_W = WG_X + FW - 1;   /* 36 */

shared float s_tile[TILE_H * TILE_W];      /* float-converted ref samples + halo */
shared float s_vert[WG_Y * TILE_W];        /* vertical filter output, halo on x */
shared float s_sad[MAX_SUBGROUPS];

layout(set = 0, binding = 0, std430) readonly buffer RefIn  { uint pixels[]; } ref_in;
layout(set = 0, binding = 1, std430)          buffer CurB   { float b[];     } cur_blur;
layout(set = 0, binding = 2, std430) readonly buffer PrevB  { float b[];     } prev_blur;
layout(set = 0, binding = 3, std430)          buffer Sad    { float v[];     } sad_out;

layout(push_constant) uniform Params {
    uint width;
    uint height;
    uint bpc;
    uint compute_sad;
    uint num_workgroups_x;
} pc;

int dev_mirror(int idx, int sup) {
    if (idx < 0) return -idx;
    if (idx >= sup) return 2 * (sup - 1) - idx;
    return idx;
}

float read_src(int y, int x) {
    /* Convert raw uint pixel to (raw / scaler) - 128.0. */
    if (BPC <= 8) {
        uint stride_words = (uint(pc.width) + 3u) >> 2;
        uint word = ref_in.pixels[uint(y) * stride_words + (uint(x) >> 2)];
        uint v = (word >> ((uint(x) & 3u) * 8u)) & 0xFFu;
        return float(v) - 128.0;
    } else {
        uint stride_words = (uint(pc.width) + 1u) >> 1;
        uint word = ref_in.pixels[uint(y) * stride_words + (uint(x) >> 1)];
        uint v = (word >> ((uint(x) & 1u) * 16u)) & 0xFFFFu;
        float scaler = 1.0;
        if (BPC == 10) scaler = 4.0;
        else if (BPC == 12) scaler = 16.0;
        else if (BPC == 16) scaler = 256.0;
        return float(v) / scaler - 128.0;
    }
}

void main() {
    int gx = int(gl_GlobalInvocationID.x);
    int gy = int(gl_GlobalInvocationID.y);
    int lx = int(gl_LocalInvocationID.x);
    int ly = int(gl_LocalInvocationID.y);
    uint lid = uint(ly * WG_X + lx);
    bool valid = (gx < int(pc.width) && gy < int(pc.height));

    int tile_oy = int(gl_WorkGroupID.y) * WG_Y - HALF_FW;
    int tile_ox = int(gl_WorkGroupID.x) * WG_X - HALF_FW;
    int tile_elems = TILE_H * TILE_W;

    bool interior =
        (tile_oy >= 0) && (tile_oy + TILE_H <= int(pc.height)) &&
        (tile_ox >= 0) && (tile_ox + TILE_W <= int(pc.width));

    /* --- Phase 1: cooperative tile load (float) --- */
    for (int i = int(lid); i < tile_elems; i += WG_SIZE) {
        int tr = i / TILE_W;
        int tc = i - tr * TILE_W;
        int py = tile_oy + tr;
        int px = tile_ox + tc;
        if (!interior) {
            py = dev_mirror(py, int(pc.height));
            px = dev_mirror(px, int(pc.width));
        }
        s_tile[tr * TILE_W + tc] = read_src(py, px);
    }
    barrier();

    /* --- Phase 2: vertical filter into s_vert (full TILE_W width) --- */
    int vert_total = WG_Y * TILE_W;
    for (int i = int(lid); i < vert_total; i += WG_SIZE) {
        int r = i / TILE_W;
        int c = i - r * TILE_W;
        float acc = 0.0;
        for (int k = 0; k < FW; k++)
            acc += FILT[k] * s_tile[(r + k) * TILE_W + c];
        s_vert[r * TILE_W + c] = acc;
    }
    barrier();

    /* --- Phase 3: per-thread horizontal filter + SAD against prev --- */
    float abs_diff = 0.0;
    if (valid) {
        float blurred = 0.0;
        for (int k = 0; k < FW; k++)
            blurred += FILT[k] * s_vert[ly * TILE_W + (lx + k)];
        cur_blur.b[uint(gy) * pc.width + uint(gx)] = blurred;

        if (pc.compute_sad != 0u) {
            float prev = prev_blur.b[uint(gy) * pc.width + uint(gx)];
            float diff = blurred - prev;
            abs_diff = diff < 0.0 ? -diff : diff;
        }
    }

    /* --- Phase 4: subgroup + cross-subgroup float reduction --- */
    if (pc.compute_sad != 0u) {
        float sg_sum = subgroupAdd(abs_diff);
        uint sg_id = gl_SubgroupID;
        uint n_subgrps = gl_NumSubgroups;
        if (subgroupElect())
            s_sad[sg_id] = sg_sum;
        barrier();

        if (lid == 0u) {
            float total = 0.0;
            for (uint s = 0u; s < n_subgrps; s++)
                total += s_sad[s];
            uint wg_idx = gl_WorkGroupID.y * pc.num_workgroups_x + gl_WorkGroupID.x;
            sad_out.v[wg_idx] = total;
        }
    } else {
        if (lid == 0u) {
            uint wg_idx = gl_WorkGroupID.y * pc.num_workgroups_x + gl_WorkGroupID.x;
            sad_out.v[wg_idx] = 0.0;
        }
    }
}
