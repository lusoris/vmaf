 *
 * Vulkan compute shader for cambi's separable 3-tap mode filter.
 *
 * CPU reference:
 *   libvmaf/src/feature/cambi.c::filter_mode() / mode3() / min3()
 *
 * Algorithm (separable; this shader is one direction; dispatch
 * twice — once horizontal, once vertical):
 *
 *   mode3(a, b, c):
 *     if (a == b || a == c) return a;
 *     if (b == c)           return b;
 *     return min3(a, b, c);   // tie-break: minimum value
 *
 *   horizontal pass:
 *     out[i, 0]              = in[i, 0]
 *     out[i, j] (1..w-2)     = mode3(in[i, j-1], in[i, j], in[i, j+1])
 *     out[i, w-1]            = in[i, w-1]
 *
 *   vertical pass: same shape on columns. The CPU code unrolls the
 *   2D filter using a 3-row scratch buffer; on GPU we just dispatch
 *   the separable horizontal pass into a scratch buffer and the
 *   vertical pass from scratch back into the image.
 *
 * Status: scaffold only. See ADR-0205.
 *
 * Specialization constants:
 *   constant_id = 0  WIDTH
 *   constant_id = 1  HEIGHT
 *   constant_id = 2  AXIS         0 = horizontal, 1 = vertical
 *
 * Bindings:
 *   binding 0: input plane (uint16 packed in uint32)
 *   binding 1: output plane (uint16 packed in uint32)
 *
 * Precision contract: bit-exact (integer comparisons + min).
 */

#version 460

layout(local_size_x = 16, local_size_y = 16, local_size_z = 1) in;

layout(constant_id = 0) const int WIDTH  = 0;
layout(constant_id = 1) const int HEIGHT = 0;
layout(constant_id = 2) const int AXIS   = 0;

layout(set = 0, binding = 0, std430) readonly buffer In  { uint pixels[]; } src;
layout(set = 0, binding = 1, std430)          buffer Out { uint pixels[]; } dst;

layout(push_constant) uniform Params {
    uint width;
    uint height;
    uint stride_words;
} pc;

uint read_u16(int y, int x) {
    uint word = src.pixels[uint(y) * pc.stride_words + (uint(x) >> 1)];
    return (word >> ((uint(x) & 1u) * 16u)) & 0xFFFFu;
}

void write_u16(int y, int x, uint v) {
    uint idx = uint(y) * pc.stride_words + (uint(x) >> 1);
    uint shift = (uint(x) & 1u) * 16u;
    uint mask = 0xFFFFu << shift;
    atomicAnd(dst.pixels[idx], ~mask);
    atomicOr (dst.pixels[idx], (v & 0xFFFFu) << shift);
}

uint min3(uint a, uint b, uint c) {
    if (a <= b && a <= c) return a;
    if (b <= c)           return b;
    return c;
}

uint mode3(uint a, uint b, uint c) {
    if (a == b || a == c) return a;
    if (b == c)           return b;
    return min3(a, b, c);
}

void main() {
    int x = int(gl_GlobalInvocationID.x);
    int y = int(gl_GlobalInvocationID.y);
    if (x >= int(pc.width) || y >= int(pc.height))
        return;

    uint v;
    if (AXIS == 0) {
        /* Horizontal pass. */
        if (x == 0 || x == int(pc.width) - 1) {
            v = read_u16(y, x);
        } else {
            uint a = read_u16(y, x - 1);
            uint b = read_u16(y, x);
            uint c = read_u16(y, x + 1);
            v = mode3(a, b, c);
        }
    } else {
        /* Vertical pass. */
        if (y == 0 || y == int(pc.height) - 1) {
            v = read_u16(y, x);
        } else {
            uint a = read_u16(y - 1, x);
            uint b = read_u16(y,     x);
            uint c = read_u16(y + 1, x);
            v = mode3(a, b, c);
        }
    }
    write_u16(y, x, v);
}
