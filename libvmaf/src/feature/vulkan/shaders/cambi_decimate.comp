 *
 * Vulkan compute shader for cambi's per-scale 2x decimation step.
 *
 * CPU reference:
 *   libvmaf/src/feature/cambi.c::decimate()
 *
 * Algorithm:
 *   data_out[i, j] = data_in[2 * i, 2 * j]
 *
 * Strict subsample (NOT a 2x2 box filter); matches CPU bit-exactly.
 *
 * Status: scaffold only. See ADR-0205.
 *
 * Specialization constants:
 *   constant_id = 0  OUT_WIDTH
 *   constant_id = 1  OUT_HEIGHT
 *
 * Bindings:
 *   binding 0: input plane (uint16 packed in uint32)
 *   binding 1: output plane (uint16 packed in uint32)
 *
 * Precision contract: bit-exact (integer copy).
 */

#version 460

layout(local_size_x = 16, local_size_y = 16, local_size_z = 1) in;

layout(constant_id = 0) const int OUT_WIDTH  = 0;
layout(constant_id = 1) const int OUT_HEIGHT = 0;

layout(set = 0, binding = 0, std430) readonly buffer In  { uint pixels[]; } src;
layout(set = 0, binding = 1, std430)          buffer Out { uint pixels[]; } dst;

layout(push_constant) uniform Params {
    uint out_width;
    uint out_height;
    uint in_stride_words;    /* = (in_width  + 1) >> 1 */
    uint out_stride_words;   /* = (out_width + 1) >> 1 */
} pc;

uint read_u16(int y, int x) {
    uint word = src.pixels[uint(y) * pc.in_stride_words + (uint(x) >> 1)];
    return (word >> ((uint(x) & 1u) * 16u)) & 0xFFFFu;
}

void write_u16(int y, int x, uint v) {
    uint idx = uint(y) * pc.out_stride_words + (uint(x) >> 1);
    uint shift = (uint(x) & 1u) * 16u;
    uint mask = 0xFFFFu << shift;
    atomicAnd(dst.pixels[idx], ~mask);
    atomicOr (dst.pixels[idx], (v & 0xFFFFu) << shift);
}

void main() {
    int gx = int(gl_GlobalInvocationID.x);
    int gy = int(gl_GlobalInvocationID.y);
    if (gx >= int(pc.out_width) || gy >= int(pc.out_height))
        return;
    uint v = read_u16(gy * 2, gx * 2);
    write_u16(gy, gx, v);
}
