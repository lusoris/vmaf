 *
 * Vulkan compute shader for the integer_motion_v2 feature extractor.
 *
 * CPU reference: libvmaf/src/feature/integer_motion_v2.c
 *   `motion_score_pipeline_8` / `motion_score_pipeline_16`
 *
 * Algorithm (must match CPU integer_motion_v2):
 *   Exploits convolution linearity:
 *     SAD(blur(prev), blur(cur)) == sum(|blur(prev - cur)|)
 *
 *   1. Per pixel: diff = prev[i,j] - cur[i,j]   (signed; range
 *      [-(2^bpc - 1), +(2^bpc - 1)])
 *   2. Vertical filter on diff:
 *        v[i,j] = (sum_k filter[k] * diff[mirror(i-2+k), j]
 *                  + (1 << (bpc - 1))) >> bpc       (CPU >>8 for bpc==8;
 *                                                    CPU code uses round
 *                                                    1<<7 + shift 8 in
 *                                                    that branch — same)
 *   3. Horizontal filter on v:
 *        h[i,j] = (sum_k filter[k] * v[i, mirror(j-2+k)]
 *                  + 32768) >> 16
 *   4. SAD: sad += |h[i,j]|       (per-pixel int32, accumulated int64)
 *
 *   Final score on the host:
 *        motion_v2_sad_score = sad / 256.0 / (width * height)
 *   The CPU's flush() emits motion2_v2_score = min(cur, next) — host
 *   side, no kernel work needed.
 *
 * Filter (sum = 65536): {3571, 16004, 26386, 16004, 3571}
 *
 * Mirror padding (matches CPU `mirror` after upstream commit 856d3835):
 *   if (idx < 0)        idx = -idx;
 *   if (idx >= sup)     idx = 2 * sup - idx - 2;
 *
 * int64 SAD reduction
 * -------------------
 * Each workgroup writes a single int64_t partial-SAD into its slot of
 * the per-WG accumulator SSBO. The host CPU sums the slots after the
 * dispatch — same approach as motion.comp / vif.comp, no atomic-int64
 * capability required.
 *
 * Specialization constants (set per-pipeline via VkSpecializationInfo):
 *   constant_id = 0  WIDTH
 *   constant_id = 1  HEIGHT
 *   constant_id = 2  BPC            8 / 10 / 12 / 16
 *   constant_id = 3  SUBGROUP_SIZE  pinned per pipeline (default 32)
 *
 * Bindings (compact: motion_v2 has no per-frame blurred state to keep,
 * so we drop motion.comp's prev_blur / cur_blur ping-pong):
 *   binding 0: prev ref input plane
 *              BPC <= 8  -> uint8 packed in uint32 (4 px / word)
 *              BPC  > 8  -> uint16 packed in uint32 (2 px / word)
 *   binding 1: cur  ref input plane (same layout as binding 0)
 *   binding 2: per-workgroup int64 SAD partials (one slot per WG)
 *
 * Mirrors `motion.comp`'s tile / halo / subgroup-reduce layout 1:1 —
 * the only structural delta is signed-diff arithmetic and the dropped
 * blur output. Per ADR-0192 (batch 3 part 1a) this is the smallest
 * possible delta on top of the already-reviewed motion kernel.
 */

#version 460
#extension GL_KHR_shader_subgroup_arithmetic               : require
#extension GL_KHR_shader_subgroup_basic                    : require
#extension GL_EXT_shader_explicit_arithmetic_types_int64   : require
#extension GL_EXT_shader_subgroup_extended_types_int64     : require

/* Workgroup geometry: 32 x 4 = 128 threads, matches motion.comp. */
layout(local_size_x = 32, local_size_y = 4, local_size_z = 1) in;

layout(constant_id = 0) const int WIDTH         = 0;
layout(constant_id = 1) const int HEIGHT        = 0;
layout(constant_id = 2) const int BPC           = 8;
layout(constant_id = 3) const int SUBGROUP_SIZE = 32;

const int FW          = 5;
const int HALF_FW     = 2;
const int WG_X        = 32;
const int WG_Y        = 4;
const int WG_SIZE     = WG_X * WG_Y;
const int MAX_SUBGROUPS = WG_SIZE;

const int FILTER[5] = int[5]( 3571, 16004, 26386, 16004, 3571 );

/* Tile dimensions: 5-tap filter + WG halo on every edge. */
const int TILE_H = WG_Y + FW - 1;   /* 4 + 4 = 8  */
const int TILE_W = WG_X + FW - 1;   /* 32 + 4 = 36 */

/* Signed diff (prev - cur). For bpc<=12 the range fits int32; the
 * shared-mem cell stays int. The 64-bit promotion happens inside the
 * vertical convolve where filter[k] * diff overflows int32 at bpc=16. */
shared int  s_diff[TILE_H * TILE_W];

/* Vertically-filtered intermediate covering the full WG_Y rows ×
 * TILE_W column halo (so the horizontal pass can index neighbours).
 * After the >>bpc shift, range fits int32 easily. */
shared int  s_vert[WG_Y * TILE_W];

/* Per-subgroup partial SAD scratch. */
shared int64_t s_sad[MAX_SUBGROUPS];

layout(set = 0, binding = 0, std430) readonly buffer PrevRef { uint pixels[]; } prev_ref;
layout(set = 0, binding = 1, std430) readonly buffer CurRef  { uint pixels[]; } cur_ref;
layout(set = 0, binding = 2, std430)          buffer Sad     { int64_t v[];  } sad_out;

layout(push_constant) uniform Params {
    uint width;
    uint height;
    uint bpc;
    uint num_workgroups_x;
} pc;

/* CPU integer_motion_v2.c uses skip-boundary reflective mirror
 * (a-b-c|b-a) after upstream commit 856d3835 (May 2026): `2 * size - idx - 2`
 * for idx >= size. Matches motion.comp's `2 * (sup - 1) - idx` algebraically;
 * kept literal here to stay textually aligned with the CPU formula. */
int dev_mirror(int idx, int sup) {
    if (idx < 0) return -idx;
    if (idx >= sup) return 2 * sup - idx - 2;
    return idx;
}

uint read_prev(int y, int x) {
    if (BPC <= 8) {
        uint stride_words = (uint(pc.width) + 3u) >> 2;
        uint word = prev_ref.pixels[uint(y) * stride_words + (uint(x) >> 2)];
        return (word >> ((uint(x) & 3u) * 8u)) & 0xFFu;
    } else {
        uint stride_words = (uint(pc.width) + 1u) >> 1;
        uint word = prev_ref.pixels[uint(y) * stride_words + (uint(x) >> 1)];
        return (word >> ((uint(x) & 1u) * 16u)) & 0xFFFFu;
    }
}

uint read_cur(int y, int x) {
    if (BPC <= 8) {
        uint stride_words = (uint(pc.width) + 3u) >> 2;
        uint word = cur_ref.pixels[uint(y) * stride_words + (uint(x) >> 2)];
        return (word >> ((uint(x) & 3u) * 8u)) & 0xFFu;
    } else {
        uint stride_words = (uint(pc.width) + 1u) >> 1;
        uint word = cur_ref.pixels[uint(y) * stride_words + (uint(x) >> 1)];
        return (word >> ((uint(x) & 1u) * 16u)) & 0xFFFFu;
    }
}

void main()
{
    int gx = int(gl_GlobalInvocationID.x);
    int gy = int(gl_GlobalInvocationID.y);
    int lx = int(gl_LocalInvocationID.x);
    int ly = int(gl_LocalInvocationID.y);
    uint lid = uint(ly * WG_X + lx);
    bool valid = (gx < int(pc.width) && gy < int(pc.height));

    /* Vertical-pass round/shift (CPU: round = 1<<(bpc-1), shift = bpc). */
    int shift_v = int(pc.bpc);
    int round_v = 1 << (int(pc.bpc) - 1);

    /* ============================================================
     * Phase 1: cooperative tile load with mirror padding.
     * Each cell holds (prev - cur) as signed int.
     * ============================================================ */
    int tile_oy = int(gl_WorkGroupID.y) * WG_Y - HALF_FW;
    int tile_ox = int(gl_WorkGroupID.x) * WG_X - HALF_FW;
    int tile_elems = TILE_H * TILE_W;

    bool interior =
        (tile_oy >= 0) && (tile_oy + TILE_H <= int(pc.height)) &&
        (tile_ox >= 0) && (tile_ox + TILE_W <= int(pc.width));

    for (int i = int(lid); i < tile_elems; i += WG_SIZE) {
        int tr = i / TILE_W;
        int tc = i - tr * TILE_W;
        int py = tile_oy + tr;
        int px = tile_ox + tc;
        if (!interior) {
            py = dev_mirror(py, int(pc.height));
            px = dev_mirror(px, int(pc.width));
        }
        int prev_v = int(read_prev(py, px));
        int cur_v  = int(read_cur(py, px));
        s_diff[tr * TILE_W + tc] = prev_v - cur_v;
    }
    barrier();

    /* ============================================================
     * Phase 2: cooperative vertical convolution -> s_vert.
     * Output covers WG_Y rows x TILE_W columns (full halo width).
     * For bpc=16 the per-tap product can hit 26386 * 65535 ≈ 1.7e9
     * and the 5-tap sum overflows int32 — accumulate in int64 first,
     * then narrow to int after the round/shift.
     * ============================================================ */
    int vert_total = WG_Y * TILE_W;
    for (int i = int(lid); i < vert_total; i += WG_SIZE) {
        int r = i / TILE_W;
        int c = i - r * TILE_W;
        int64_t acc = 0L;
        for (int k = 0; k < FW; k++) {
            acc += int64_t(FILTER[k]) * int64_t(s_diff[(r + k) * TILE_W + c]);
        }
        int64_t shifted = (acc + int64_t(round_v)) >> int64_t(shift_v);
        s_vert[r * TILE_W + c] = int(shifted);
    }
    barrier();

    /* ============================================================
     * Phase 3: per-thread horizontal convolution + abs + accumulate.
     * For valid output pixel (gx, gy) with local (lx, ly):
     *   h = (sum filter[k] * s_vert[ly, lx+k] + 32768) >> 16
     *   contrib = |h|
     * filter[k] up to 26386, s_vert up to ~filter_sum*max_diff/2^bpc;
     * for bpc=16 max_diff = 65535 → s_vert up to ~65280, so the per-
     * tap product hits 26386 * 65280 ≈ 1.7e9 (overflows int32). int64
     * accumulator throughout. Same precision contract as motion.comp's
     * unsigned `uint h` accumulator — int64 is conservative for
     * negative values.
     * ============================================================ */
    int64_t abs_diff = 0L;

    if (valid) {
        int64_t h = 0L;
        for (int k = 0; k < FW; k++) {
            h += int64_t(FILTER[k]) * int64_t(s_vert[ly * TILE_W + (lx + k)]);
        }
        int64_t blurred = (h + 32768L) >> 16L;
        /* abs(int64) — explicit branch matches CPU's abs(int32) for the
         * range-of-interest; for blurred outside int32 (shouldn't
         * happen given the upstream shifts) we still compute the
         * magnitude correctly. */
        abs_diff = (blurred < 0L) ? -blurred : blurred;
    }

    /* ============================================================
     * Phase 4: subgroup + cross-subgroup SAD reduction.
     * ============================================================ */
    int64_t sg_sum = subgroupAdd(abs_diff);
    uint sg_id     = gl_SubgroupID;
    uint n_subgrps = gl_NumSubgroups;

    if (subgroupElect()) {
        s_sad[sg_id] = sg_sum;
    }
    barrier();

    if (lid == 0u) {
        int64_t total = 0L;
        for (uint s = 0u; s < n_subgrps; s++) {
            total += s_sad[s];
        }
        uint wg_idx = gl_WorkGroupID.y * pc.num_workgroups_x + gl_WorkGroupID.x;
        sad_out.v[wg_idx] = total;
    }
}
