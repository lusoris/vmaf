float csf(int idx) {
    if (PLANE == 0) return CSF_Y[idx];
    if (PLANE == 1) return CSF_CB[idx];
    return CSF_CR[idx];
}

layout(set = 0, binding = 0, std430) readonly buffer RefIn   { float v[]; } ref_in;
layout(set = 0, binding = 1, std430) readonly buffer DistIn  { float v[]; } dist_in;
layout(set = 0, binding = 2, std430)          buffer Partials { float v[]; } partials_out;

layout(push_constant) uniform Params {
    uint width;
    uint height;
    uint num_blocks_x;
    uint num_blocks_y;
} pc;

/* Shared memory: 8×8 raw samples (int32) for ref + dist.
 * Cooperative load only — all per-block math runs in thread 0
 * to match CPU's linear i,j summation order bit-exactly (the
 * subgroupAdd-based reduction was the dominant places=4 drift
 * source: 8.2e-5 → near-zero). */
shared int s_ref[64];
shared int s_dist[64];

/* OD_UNBIASED_RSHIFT32: round-to-zero right shift. Matches
 * the macro in xiph/psnr_hvs.c — needed because GLSL signed
 * `>>` is arithmetic (rounds toward -inf for negatives), but
 * the Xiph DCT relies on round-toward-zero semantics. */
int od_dct_rshift(int a, int b) {
    return int((uint(a) >> uint(32 - b)) + uint(a)) >> b;
}

/* Forward 8-point DCT — port of od_bin_fdct8 from
 * libvmaf/src/feature/third_party/xiph/psnr_hvs.c:72.
 * Reads `in[0..7]` (with stride `stride`), writes `out[0..7]`
 * (stride 1). */
void od_bin_fdct8(out int y0, out int y1, out int y2, out int y3,
                  out int y4, out int y5, out int y6, out int y7,
                  int x0, int x1, int x2, int x3, int x4, int x5, int x6, int x7) {
    /* Initial permutation. */
    int t0 = x0;
    int t4 = x1;
    int t2 = x2;
    int t6 = x3;
    int t7 = x4;
    int t3 = x5;
    int t5 = x6;
    int t1 = x7;
    int t1h, t4h, t6h;
    /* +1/-1 butterflies. */
    t1 = t0 - t1;
    t1h = od_dct_rshift(t1, 1);
    t0 -= t1h;
    t4 += t5;
    t4h = od_dct_rshift(t4, 1);
    t5 -= t4h;
    t3 = t2 - t3;
    t2 -= od_dct_rshift(t3, 1);
    t6 += t7;
    t6h = od_dct_rshift(t6, 1);
    t7 = t6h - t7;
    /* Embedded 4-point type-II DCT. */
    t0 += t6h;
    t6 = t0 - t6;
    t2 = t4h - t2;
    t4 = t2 - t4;
    /* Embedded 2-point type-II DCT. */
    t0 -= (t4 * 13573 + 16384) >> 15;
    t4 += (t0 * 11585 + 8192) >> 14;
    t0 -= (t4 * 13573 + 16384) >> 15;
    /* Embedded 2-point type-IV DST. */
    t6 -= (t2 * 21895 + 16384) >> 15;
    t2 += (t6 * 15137 + 8192) >> 14;
    t6 -= (t2 * 21895 + 16384) >> 15;
    /* Embedded 4-point type-IV DST. */
    t3 += (t5 * 19195 + 16384) >> 15;
    t5 += (t3 * 11585 + 8192) >> 14;
    t3 -= (t5 * 7489 + 4096) >> 13;
    t7 = od_dct_rshift(t5, 1) - t7;
    t5 -= t7;
    t3 = t1h - t3;
    t1 -= t3;
    t7 += (t1 * 3227 + 16384) >> 15;
    t1 -= (t7 * 6393 + 16384) >> 15;
    t7 += (t1 * 3227 + 16384) >> 15;
    t5 += (t3 * 2485 + 4096) >> 13;
    t3 -= (t5 * 18205 + 16384) >> 15;
    t5 += (t3 * 2485 + 4096) >> 13;
    y0 = t0;
    y1 = t1;
    y2 = t2;
    y3 = t3;
    y4 = t4;
    y5 = t5;
    y6 = t6;
    y7 = t7;
}

void od_bin_fdct8x8_in_place(inout int blk[64]) {
    int z[64];
    /* CPU layout (psnr_hvs.c):
     *   for (i = 0; i < 8; i++) od_bin_fdct8(z + 8*i, x + i, xstride);
     *   for (i = 0; i < 8; i++) od_bin_fdct8(y + 8*i, z + i, 8);
     * Pass 1: read input column i (8 samples at stride 8), write
     * z[8*i + 0..7] = DCT-coeffs of column i. Pass 2: read column i
     * of z (= z[8*j + i] for j=0..7 = i-th coeff of every column),
     * DCT to give 2-D DCT row i, written to blk[8*i + 0..7]. */
    for (int i = 0; i < 8; i++) {
        int y0, y1, y2, y3, y4, y5, y6, y7;
        od_bin_fdct8(y0, y1, y2, y3, y4, y5, y6, y7,
                     blk[0 * 8 + i], blk[1 * 8 + i], blk[2 * 8 + i], blk[3 * 8 + i],
                     blk[4 * 8 + i], blk[5 * 8 + i], blk[6 * 8 + i], blk[7 * 8 + i]);
        z[i * 8 + 0] = y0;
        z[i * 8 + 1] = y1;
        z[i * 8 + 2] = y2;
        z[i * 8 + 3] = y3;
        z[i * 8 + 4] = y4;
        z[i * 8 + 5] = y5;
        z[i * 8 + 6] = y6;
        z[i * 8 + 7] = y7;
    }
    for (int i = 0; i < 8; i++) {
        int y0, y1, y2, y3, y4, y5, y6, y7;
        od_bin_fdct8(y0, y1, y2, y3, y4, y5, y6, y7,
                     z[0 * 8 + i], z[1 * 8 + i], z[2 * 8 + i], z[3 * 8 + i],
                     z[4 * 8 + i], z[5 * 8 + i], z[6 * 8 + i], z[7 * 8 + i]);
        blk[i * 8 + 0] = y0;
        blk[i * 8 + 1] = y1;
        blk[i * 8 + 2] = y2;
        blk[i * 8 + 3] = y3;
        blk[i * 8 + 4] = y4;
        blk[i * 8 + 5] = y5;
        blk[i * 8 + 6] = y6;
        blk[i * 8 + 7] = y7;
    }
}

/* Reverse the picture_copy normalisation back to the original
 * integer sample (matches the CPU integer DCT input). For 8-bit
 * picture_copy uses scale=1 (just float cast), for 10-bit
 * scale=4 (samples 0..1023 were divided by 4), 12-bit scale=16. */
int sample_to_int(float v) {
    if (BPC == 8) return int(v + 0.5);
    if (BPC == 10) return int(v * 4.0 + 0.5);
    /* BPC == 12 */
    return int(v * 16.0 + 0.5);
}

void main() {
    uint blk_x = gl_WorkGroupID.x;
    uint blk_y = gl_WorkGroupID.y;
    uint lx = gl_LocalInvocationID.x;
    uint ly = gl_LocalInvocationID.y;
    uint local_idx = ly * 8u + lx;

    /* Block origin in pixel coords. */
    uint x0 = blk_x * 7u;
    uint y0 = blk_y * 7u;

    bool valid_block = (blk_x < pc.num_blocks_x && blk_y < pc.num_blocks_y &&
                        x0 + 7u < pc.width && y0 + 7u < pc.height);

    /* Cooperative load: each thread loads one (i, j) sample. */
    int my_ref = 0;
    int my_dist = 0;
    if (valid_block) {
        uint sx = x0 + lx;
        uint sy = y0 + ly;
        uint src_idx = sy * pc.width + sx;
        my_ref = sample_to_int(ref_in.v[src_idx]);
        my_dist = sample_to_int(dist_in.v[src_idx]);
    }
    s_ref[local_idx] = my_ref;
    s_dist[local_idx] = my_dist;
    barrier();

    /* All per-block math runs in thread 0 to match CPU's linear
     * i,j summation order bit-exactly. The DCT was already
     * thread-0-scalar; making the rest also serial costs ~2 µs/block
     * but gives precision floor ≪ 1 ULP relative (vs ~8e-5 dB drift
     * from subgroupAdd-based reductions in the previous version). */
    if (local_idx == 0u) {
        /* dct_s / dct_d hold raw samples first (CPU does the int->dct
         * promotion in-place after computing means/vars). */
        int dct_s[64];
        int dct_d[64];
        for (int i = 0; i < 64; i++) dct_s[i] = s_ref[i];
        for (int i = 0; i < 64; i++) dct_d[i] = s_dist[i];

        /* Per-block accumulators (matches calc_psnrhvs locals
         * line 281-294 byte-for-byte). `precise` blocks the
         * GLSL/SPIR-V compiler from fusing `a*b+c` into a single
         * FMA instruction — the CPU compiles to scalar `mul + add`
         * (two roundings), so FMA's single-rounding contraction
         * is the dominant places=4 drift source on the per-coeff
         * masking + accumulation path. */
        precise float s_means[4]; precise float d_means[4];
        precise float s_vars[4];  precise float d_vars[4];
        precise float s_gmean = 0.0; precise float d_gmean = 0.0;
        precise float s_gvar  = 0.0; precise float d_gvar  = 0.0;
        precise float s_mc    = 0.0; precise float d_mc    = 0.0;
        for (int i = 0; i < 4; i++) {
            s_means[i] = d_means[i] = s_vars[i] = d_vars[i] = 0.0;
        }

        /* Pass 1: means (linear i, j order — matches CPU). */
        for (int i = 0; i < 8; i++) {
            for (int j = 0; j < 8; j++) {
                int sub = ((i & 12) >> 2) + ((j & 12) >> 1);
                s_gmean += float(dct_s[i * 8 + j]);
                d_gmean += float(dct_d[i * 8 + j]);
                s_means[sub] += float(dct_s[i * 8 + j]);
                d_means[sub] += float(dct_d[i * 8 + j]);
            }
        }
        s_gmean /= 64.0;
        d_gmean /= 64.0;
        for (int i = 0; i < 4; i++) s_means[i] /= 16.0;
        for (int i = 0; i < 4; i++) d_means[i] /= 16.0;

        /* Pass 2: variances (linear i, j — matches CPU). */
        for (int i = 0; i < 8; i++) {
            for (int j = 0; j < 8; j++) {
                int sub = ((i & 12) >> 2) + ((j & 12) >> 1);
                float ds = float(dct_s[i * 8 + j]) - s_gmean;
                float dd = float(dct_d[i * 8 + j]) - d_gmean;
                s_gvar += ds * ds;
                d_gvar += dd * dd;
                float qs = float(dct_s[i * 8 + j]) - s_means[sub];
                float qd = float(dct_d[i * 8 + j]) - d_means[sub];
                s_vars[sub] += qs * qs;
                d_vars[sub] += qd * qd;
            }
        }

        /* CPU normalisation: `s_gvar *= 1/63.f * 64`. The literal
         * float order (1/63.f then *64) matters at ULP precision —
         * mirror it exactly. */
        s_gvar *= 1.0 / 63.0 * 64.0;
        d_gvar *= 1.0 / 63.0 * 64.0;
        for (int i = 0; i < 4; i++) s_vars[i] *= 1.0 / 15.0 * 16.0;
        for (int i = 0; i < 4; i++) d_vars[i] *= 1.0 / 15.0 * 16.0;

        if (s_gvar > 0.0)
            s_gvar = (s_vars[0] + s_vars[1] + s_vars[2] + s_vars[3]) / s_gvar;
        if (d_gvar > 0.0)
            d_gvar = (d_vars[0] + d_vars[1] + d_vars[2] + d_vars[3]) / d_gvar;

        /* Forward 8×8 DCT in place. */
        od_bin_fdct8x8_in_place(dct_s);
        od_bin_fdct8x8_in_place(dct_d);

        /* Pass 3: per-coefficient mask·dct² accumulation — skipping
         * DC (i=j=0). Linear i, j order. */
        float mask[64];
        for (int i = 0; i < 8; i++) {
            for (int j = 0; j < 8; j++) {
                float c = csf(i * 8 + j);
                float m = c * 0.3885746225901003;
                mask[i * 8 + j] = m * m;
            }
        }
        /* CPU computes `dct[i][j] * dct[i][j]` as int×int (exact
         * for typical values < 2^23 / 2 ≈ 5793 dct magnitude),
         * THEN casts to float to multiply by mask. Mirror that
         * order — float×float of two large values would lose ULPs
         * vs the int square. */
        for (int i = 0; i < 8; i++) {
            int j0 = (i == 0) ? 1 : 0;
            for (int j = j0; j < 8; j++) {
                int sq = dct_s[i * 8 + j] * dct_s[i * 8 + j];
                s_mc += float(sq) * mask[i * 8 + j];
            }
        }
        for (int i = 0; i < 8; i++) {
            int j0 = (i == 0) ? 1 : 0;
            for (int j = j0; j < 8; j++) {
                int sq = dct_d[i * 8 + j] * dct_d[i * 8 + j];
                d_mc += float(sq) * mask[i * 8 + j];
            }
        }
        float sm = sqrt(s_mc * s_gvar) / 32.0;
        float dm = sqrt(d_mc * d_gvar) / 32.0;
        if (dm > sm) sm = dm;
        float thresh = sm;

        /* Pass 4: per-coefficient masked-error contribution sum.
         * Matches CPU: `for (i,j) ret += (err·csf)²` with
         * `pixels++` for every (i,j) including DC. */
        precise float ret = 0.0;
        for (int i = 0; i < 8; i++) {
            for (int j = 0; j < 8; j++) {
                precise float c = csf(i * 8 + j);
                precise float err = abs(float(dct_s[i * 8 + j]) - float(dct_d[i * 8 + j]));
                if (i != 0 || j != 0) {
                    precise float t = thresh / mask[i * 8 + j];
                    err = err < t ? 0.0 : err - t;
                }
                /* Force separate-rounding semantics: split into
                 * pre-computed `ec` so the SPIR-V optimizer can't
                 * fuse the chain into a single FMA-equivalent. */
                precise float ec = err * c;
                precise float term = ec * ec;
                ret += term;
            }
        }
        if (!valid_block) ret = 0.0;

        uint slot = blk_y * pc.num_blocks_x + blk_x;
        partials_out.v[slot] = ret;
    }
}
