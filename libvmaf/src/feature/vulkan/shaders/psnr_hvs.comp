float csf(int idx) {
    if (PLANE == 0) return CSF_Y[idx];
    if (PLANE == 1) return CSF_CB[idx];
    return CSF_CR[idx];
}

layout(set = 0, binding = 0, std430) readonly buffer RefIn   { float v[]; } ref_in;
layout(set = 0, binding = 1, std430) readonly buffer DistIn  { float v[]; } dist_in;
layout(set = 0, binding = 2, std430)          buffer Partials { float v[]; } partials_out;

layout(push_constant) uniform Params {
    uint width;
    uint height;
    uint num_blocks_x;
    uint num_blocks_y;
} pc;

/* Shared memory: 8×8 raw samples (int32) for ref + dist,
 * plus the per-coefficient masked-error contribution and
 * cross-subgroup partial scratch. */
shared int s_ref[64];
shared int s_dist[64];
shared float s_partials_sg[MAX_SUBGROUPS];
shared int s_dct_ref[64];
shared int s_dct_dist[64];
shared float s_mask;
shared float s_d_mask;

/* OD_UNBIASED_RSHIFT32: round-to-zero right shift. Matches
 * the macro in xiph/psnr_hvs.c — needed because GLSL signed
 * `>>` is arithmetic (rounds toward -inf for negatives), but
 * the Xiph DCT relies on round-toward-zero semantics. */
int od_dct_rshift(int a, int b) {
    return int((uint(a) >> uint(32 - b)) + uint(a)) >> b;
}

/* Forward 8-point DCT — port of od_bin_fdct8 from
 * libvmaf/src/feature/third_party/xiph/psnr_hvs.c:72.
 * Reads `in[0..7]` (with stride `stride`), writes `out[0..7]`
 * (stride 1). */
void od_bin_fdct8(out int y0, out int y1, out int y2, out int y3,
                  out int y4, out int y5, out int y6, out int y7,
                  int x0, int x1, int x2, int x3, int x4, int x5, int x6, int x7) {
    /* Initial permutation. */
    int t0 = x0;
    int t4 = x1;
    int t2 = x2;
    int t6 = x3;
    int t7 = x4;
    int t3 = x5;
    int t5 = x6;
    int t1 = x7;
    int t1h, t4h, t6h;
    /* +1/-1 butterflies. */
    t1 = t0 - t1;
    t1h = od_dct_rshift(t1, 1);
    t0 -= t1h;
    t4 += t5;
    t4h = od_dct_rshift(t4, 1);
    t5 -= t4h;
    t3 = t2 - t3;
    t2 -= od_dct_rshift(t3, 1);
    t6 += t7;
    t6h = od_dct_rshift(t6, 1);
    t7 = t6h - t7;
    /* Embedded 4-point type-II DCT. */
    t0 += t6h;
    t6 = t0 - t6;
    t2 = t4h - t2;
    t4 = t2 - t4;
    /* Embedded 2-point type-II DCT. */
    t0 -= (t4 * 13573 + 16384) >> 15;
    t4 += (t0 * 11585 + 8192) >> 14;
    t0 -= (t4 * 13573 + 16384) >> 15;
    /* Embedded 2-point type-IV DST. */
    t6 -= (t2 * 21895 + 16384) >> 15;
    t2 += (t6 * 15137 + 8192) >> 14;
    t6 -= (t2 * 21895 + 16384) >> 15;
    /* Embedded 4-point type-IV DST. */
    t3 += (t5 * 19195 + 16384) >> 15;
    t5 += (t3 * 11585 + 8192) >> 14;
    t3 -= (t5 * 7489 + 4096) >> 13;
    t7 = od_dct_rshift(t5, 1) - t7;
    t5 -= t7;
    t3 = t1h - t3;
    t1 -= t3;
    t7 += (t1 * 3227 + 16384) >> 15;
    t1 -= (t7 * 6393 + 16384) >> 15;
    t7 += (t1 * 3227 + 16384) >> 15;
    t5 += (t3 * 2485 + 4096) >> 13;
    t3 -= (t5 * 18205 + 16384) >> 15;
    t5 += (t3 * 2485 + 4096) >> 13;
    y0 = t0;
    y1 = t1;
    y2 = t2;
    y3 = t3;
    y4 = t4;
    y5 = t5;
    y6 = t6;
    y7 = t7;
}

void od_bin_fdct8x8_in_place(inout int blk[64]) {
    int z[64];
    /* CPU layout (psnr_hvs.c):
     *   for (i = 0; i < 8; i++) od_bin_fdct8(z + 8*i, x + i, xstride);
     *   for (i = 0; i < 8; i++) od_bin_fdct8(y + 8*i, z + i, 8);
     * Pass 1: read input column i (8 samples at stride 8), write
     * z[8*i + 0..7] = DCT-coeffs of column i. Pass 2: read column i
     * of z (= z[8*j + i] for j=0..7 = i-th coeff of every column),
     * DCT to give 2-D DCT row i, written to blk[8*i + 0..7]. */
    for (int i = 0; i < 8; i++) {
        int y0, y1, y2, y3, y4, y5, y6, y7;
        od_bin_fdct8(y0, y1, y2, y3, y4, y5, y6, y7,
                     blk[0 * 8 + i], blk[1 * 8 + i], blk[2 * 8 + i], blk[3 * 8 + i],
                     blk[4 * 8 + i], blk[5 * 8 + i], blk[6 * 8 + i], blk[7 * 8 + i]);
        z[i * 8 + 0] = y0;
        z[i * 8 + 1] = y1;
        z[i * 8 + 2] = y2;
        z[i * 8 + 3] = y3;
        z[i * 8 + 4] = y4;
        z[i * 8 + 5] = y5;
        z[i * 8 + 6] = y6;
        z[i * 8 + 7] = y7;
    }
    for (int i = 0; i < 8; i++) {
        int y0, y1, y2, y3, y4, y5, y6, y7;
        od_bin_fdct8(y0, y1, y2, y3, y4, y5, y6, y7,
                     z[0 * 8 + i], z[1 * 8 + i], z[2 * 8 + i], z[3 * 8 + i],
                     z[4 * 8 + i], z[5 * 8 + i], z[6 * 8 + i], z[7 * 8 + i]);
        blk[i * 8 + 0] = y0;
        blk[i * 8 + 1] = y1;
        blk[i * 8 + 2] = y2;
        blk[i * 8 + 3] = y3;
        blk[i * 8 + 4] = y4;
        blk[i * 8 + 5] = y5;
        blk[i * 8 + 6] = y6;
        blk[i * 8 + 7] = y7;
    }
}

/* Reverse the picture_copy normalisation back to the original
 * integer sample (matches the CPU integer DCT input). For 8-bit
 * picture_copy uses scale=1 (just float cast), for 10-bit
 * scale=4 (samples 0..1023 were divided by 4), 12-bit scale=16. */
int sample_to_int(float v) {
    if (BPC == 8) return int(v + 0.5);
    if (BPC == 10) return int(v * 4.0 + 0.5);
    /* BPC == 12 */
    return int(v * 16.0 + 0.5);
}

void main() {
    uint blk_x = gl_WorkGroupID.x;
    uint blk_y = gl_WorkGroupID.y;
    uint lx = gl_LocalInvocationID.x;
    uint ly = gl_LocalInvocationID.y;
    uint local_idx = ly * 8u + lx;

    /* Block origin in pixel coords. */
    uint x0 = blk_x * 7u;
    uint y0 = blk_y * 7u;

    bool valid_block = (blk_x < pc.num_blocks_x && blk_y < pc.num_blocks_y &&
                        x0 + 7u < pc.width && y0 + 7u < pc.height);

    /* Cooperative load: each thread loads one (i, j) sample. */
    int my_ref = 0;
    int my_dist = 0;
    if (valid_block) {
        uint sx = x0 + lx;
        uint sy = y0 + ly;
        uint src_idx = sy * pc.width + sx;
        my_ref = sample_to_int(ref_in.v[src_idx]);
        my_dist = sample_to_int(dist_in.v[src_idx]);
    }
    s_ref[local_idx] = my_ref;
    s_dist[local_idx] = my_dist;
    barrier();

    /* Compute global mean + per-quadrant means + variances.
     * sub-block index = ((i & 12) >> 2) + ((j & 12) >> 1):
     *   row i in 0..3 → (i & 12) = 0; in 4..7 → (i & 12) = 4
     *   col j in 0..3 → (j & 12) = 0; in 4..7 → (j & 12) = 4
     *   sub = (0 or 1) + (0 or 2) = 0/1/2/3.
     * Each sub-block is 4×4 = 16 samples but the CPU code uses
     * masking (i & 12) which is 0 for 0..3 and 4..7 wraps around
     * — actually let me re-check. In C, `i & 12` for i in 0..7:
     *   i=0..3: i & 12 = 0
     *   i=4..7: i & 12 = 4
     * So sub = (0 or 4)>>2 + (0 or 4)>>1 = (0 or 1) + (0 or 2) = 0/1/2/3.
     * That yields 4 sub-blocks of 4×4 each. */
    int sub = int(((ly & 12u) >> 2) + ((lx & 12u) >> 1));
    /* But ly,lx are 0..7 here, so (ly & 12u)= 0 if ly<4 else 4. OK. */

    /* Sum reductions: subgroupAdd over the entire WG (subgroup
     * size may < 64, so we need cross-subgroup reduce). For
     * simplicity, use a single `subgroupAdd` per partial then
     * cross-subgroup reduce in shared memory. */
    float my_ref_f = float(my_ref);
    float my_dist_f = float(my_dist);

    /* Global means (full 8×8). */
    float sg_s_gmean = subgroupAdd(my_ref_f);
    float sg_d_gmean = subgroupAdd(my_dist_f);
    if (subgroupElect()) {
        s_partials_sg[gl_SubgroupID] = sg_s_gmean;
    }
    barrier();
    float s_gmean = 0.0;
    for (uint i = 0u; i < gl_NumSubgroups; i++) s_gmean += s_partials_sg[i];
    s_gmean /= 64.0;
    barrier();
    if (subgroupElect()) {
        s_partials_sg[gl_SubgroupID] = sg_d_gmean;
    }
    barrier();
    float d_gmean = 0.0;
    for (uint i = 0u; i < gl_NumSubgroups; i++) d_gmean += s_partials_sg[i];
    d_gmean /= 64.0;
    barrier();

    /* Per-quadrant means: each thread contributes my_ref to its sub. */
    /* Compute s_means[sub] / d_means[sub] via subgroupAdd masked per sub.
     * Since we only have 4 subs, cheapest is a 4-element shared array,
     * atomically add each thread's contribution. */
    /* Use a non-atomic approach: compute via 4 subgroup-add's, each
     * masking by sub == k. */
    float s_means[4];
    float d_means[4];
    for (int k = 0; k < 4; k++) {
        float r = (sub == k) ? my_ref_f : 0.0;
        float d = (sub == k) ? my_dist_f : 0.0;
        float sg_r = subgroupAdd(r);
        float sg_d = subgroupAdd(d);
        if (subgroupElect()) s_partials_sg[gl_SubgroupID] = sg_r;
        barrier();
        float total_r = 0.0;
        for (uint i = 0u; i < gl_NumSubgroups; i++) total_r += s_partials_sg[i];
        s_means[k] = total_r / 16.0;
        barrier();
        if (subgroupElect()) s_partials_sg[gl_SubgroupID] = sg_d;
        barrier();
        float total_d = 0.0;
        for (uint i = 0u; i < gl_NumSubgroups; i++) total_d += s_partials_sg[i];
        d_means[k] = total_d / 16.0;
        barrier();
    }

    /* Global + per-quadrant variances. */
    float my_s_gdev = (my_ref_f - s_gmean) * (my_ref_f - s_gmean);
    float my_d_gdev = (my_dist_f - d_gmean) * (my_dist_f - d_gmean);
    float my_s_qdev = (my_ref_f - s_means[sub]) * (my_ref_f - s_means[sub]);
    float my_d_qdev = (my_dist_f - d_means[sub]) * (my_dist_f - d_means[sub]);

    float sg_s_gvar = subgroupAdd(my_s_gdev);
    if (subgroupElect()) s_partials_sg[gl_SubgroupID] = sg_s_gvar;
    barrier();
    float s_gvar = 0.0;
    for (uint i = 0u; i < gl_NumSubgroups; i++) s_gvar += s_partials_sg[i];
    barrier();

    float sg_d_gvar = subgroupAdd(my_d_gdev);
    if (subgroupElect()) s_partials_sg[gl_SubgroupID] = sg_d_gvar;
    barrier();
    float d_gvar = 0.0;
    for (uint i = 0u; i < gl_NumSubgroups; i++) d_gvar += s_partials_sg[i];
    barrier();

    /* Per-quadrant variances. */
    float s_vars[4];
    float d_vars[4];
    for (int k = 0; k < 4; k++) {
        float r = (sub == k) ? my_s_qdev : 0.0;
        float d = (sub == k) ? my_d_qdev : 0.0;
        float sg_r = subgroupAdd(r);
        float sg_d = subgroupAdd(d);
        if (subgroupElect()) s_partials_sg[gl_SubgroupID] = sg_r;
        barrier();
        float total_r = 0.0;
        for (uint i = 0u; i < gl_NumSubgroups; i++) total_r += s_partials_sg[i];
        s_vars[k] = total_r;
        barrier();
        if (subgroupElect()) s_partials_sg[gl_SubgroupID] = sg_d;
        barrier();
        float total_d = 0.0;
        for (uint i = 0u; i < gl_NumSubgroups; i++) total_d += s_partials_sg[i];
        d_vars[k] = total_d;
        barrier();
    }

    /* Apply CPU's normalisation factors. */
    s_gvar *= 64.0 / 63.0;
    d_gvar *= 64.0 / 63.0;
    for (int k = 0; k < 4; k++) {
        s_vars[k] *= 16.0 / 15.0;
        d_vars[k] *= 16.0 / 15.0;
    }

    if (s_gvar > 0.0) s_gvar = (s_vars[0] + s_vars[1] + s_vars[2] + s_vars[3]) / s_gvar;
    if (d_gvar > 0.0) d_gvar = (d_vars[0] + d_vars[1] + d_vars[2] + d_vars[3]) / d_gvar;

    /* DCT — done in thread (0, 0) only. Uses shared memory copies. */
    if (local_idx == 0u) {
        int blk[64];
        for (int i = 0; i < 64; i++) blk[i] = s_ref[i];
        od_bin_fdct8x8_in_place(blk);
        for (int i = 0; i < 64; i++) s_dct_ref[i] = blk[i];
        for (int i = 0; i < 64; i++) blk[i] = s_dist[i];
        od_bin_fdct8x8_in_place(blk);
        for (int i = 0; i < 64; i++) s_dct_dist[i] = blk[i];
    }
    barrier();

    /* Compute mask thresholds. mask[i][j] = (csf · 0.3885746225901003)².
     * s_mask = sqrt(sum_{(i,j)≠(0,0)}(dct_s² · mask) · s_gvar) / 32.
     * d_mask similarly. Then s_mask = max(s_mask, d_mask). */
    float my_csf = csf(int(local_idx));
    float my_mask = my_csf * 0.3885746225901003;
    my_mask = my_mask * my_mask;

    /* Per-coefficient mask²·dct² contributions; skip DC (i=j=0). */
    float my_s_mc = (local_idx == 0u) ? 0.0 :
                    (float(s_dct_ref[local_idx]) * float(s_dct_ref[local_idx]) * my_mask);
    float my_d_mc = (local_idx == 0u) ? 0.0 :
                    (float(s_dct_dist[local_idx]) * float(s_dct_dist[local_idx]) * my_mask);

    float sg_s_mc = subgroupAdd(my_s_mc);
    if (subgroupElect()) s_partials_sg[gl_SubgroupID] = sg_s_mc;
    barrier();
    float s_mc_total = 0.0;
    for (uint i = 0u; i < gl_NumSubgroups; i++) s_mc_total += s_partials_sg[i];
    barrier();

    float sg_d_mc = subgroupAdd(my_d_mc);
    if (subgroupElect()) s_partials_sg[gl_SubgroupID] = sg_d_mc;
    barrier();
    float d_mc_total = 0.0;
    for (uint i = 0u; i < gl_NumSubgroups; i++) d_mc_total += s_partials_sg[i];
    barrier();

    if (local_idx == 0u) {
        float sm = sqrt(s_mc_total * s_gvar) / 32.0;
        float dm = sqrt(d_mc_total * d_gvar) / 32.0;
        if (dm > sm) sm = dm;
        s_mask = sm;
        s_d_mask = dm; /* unused after barrier, keep for future debug */
    }
    barrier();
    float thresh = s_mask;

    /* Per-coefficient masked error. */
    float err = abs(float(s_dct_ref[local_idx]) - float(s_dct_dist[local_idx]));
    if (local_idx != 0u) {
        float t = thresh / my_mask;
        err = err < t ? 0.0 : err - t;
    }
    float my_contrib = (err * my_csf) * (err * my_csf);

    /* Mask out invalid blocks (shouldn't happen due to dispatch
     * sizing, but defensive). */
    if (!valid_block) my_contrib = 0.0;

    /* Per-WG sum of contributions → one float partial. */
    float sg_contrib = subgroupAdd(my_contrib);
    if (subgroupElect()) s_partials_sg[gl_SubgroupID] = sg_contrib;
    barrier();
    if (local_idx == 0u) {
        float wg_total = 0.0;
        for (uint i = 0u; i < gl_NumSubgroups; i++) wg_total += s_partials_sg[i];
        uint slot = blk_y * pc.num_blocks_x + blk_x;
        partials_out.v[slot] = wg_total;
    }
}
