/* Copyright 2026 Lusoris and Claude (Anthropic)
 * SPDX-License-Identifier: BSD-3-Clause-Plus-Patent
 *
 * Vulkan compute shader for the float_psnr_hvs feature extractor
 * (T7-23 / batch 2 part 3a / ADR-0188 / ADR-0191). First DCT-based
 * GPU kernel in the fork. Mirrors `calc_psnrhvs` in
 * libvmaf/src/feature/third_party/xiph/psnr_hvs.c byte-for-byte
 * modulo language differences.
 *
 *  - One workgroup per output 8×8 block (step=7 sliding window).
 *  - 64 threads per workgroup (one per coefficient).
 *  - Cooperative load of source + dist samples → shared memory.
 *  - Cooperative computation of global mean + per-quadrant means
 *    + variances via subgroupAdd.
 *  - Scalar `od_bin_fdct8x8` integer DCT in thread (0,0).
 *  - Per-thread (i,j) computes its (err·csf[i][j])² masked
 *    contribution.
 *  - Per-WG subgroupAdd → one float partial per block.
 *
 * Specialization constants (one pipeline per plane × bpc):
 *   constant_id = 0  WIDTH        (plane width, after chroma sub-sample)
 *   constant_id = 1  HEIGHT       (plane height)
 *   constant_id = 2  BPC          (8 / 10 / 12)
 *   constant_id = 3  PLANE        (0 = Y, 1 = Cb, 2 = Cr)
 *   constant_id = 4  SUBGROUP_SIZE (compile-time array sizing)
 *
 * Resource bindings:
 *   0: ref plane (float, picture_copy-normalised: [0, 255] for 8-bit,
 *      [0, samplemax] for 10/12-bit — host upscales by 1/4 / 1/16
 *      respectively; this shader rescales to the original integer
 *      domain to match the CPU integer DCT contract).
 *   1: dist plane (same convention).
 *   2: per-block float partials, slot = blk_y*num_blocks_x + blk_x.
 *
 * Output: total = sum(partials) over the host. Per-plane score:
 *   score = total / pixels / samplemax²
 * with pixels = num_blocks · 64 (matches CPU's per-coefficient
 * `pixels++` accumulator).
 */
#version 460
#extension GL_KHR_shader_subgroup_arithmetic : require
#extension GL_KHR_shader_subgroup_basic      : require

layout(local_size_x = 8, local_size_y = 8, local_size_z = 1) in;

layout(constant_id = 0) const int BPC           = 8;
layout(constant_id = 1) const int PLANE         = 0;
layout(constant_id = 2) const int SUBGROUP_SIZE = 32;

const int WG_X    = 8;
const int WG_Y    = 8;
const int WG_SIZE = WG_X * WG_Y;
const int MAX_SUBGROUPS = WG_SIZE;

