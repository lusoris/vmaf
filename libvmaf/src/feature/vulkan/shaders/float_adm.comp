/* Copyright 2026 Lusoris and Claude (Anthropic)
 * SPDX-License-Identifier: BSD-3-Clause-Plus-Patent
 *
 * Vulkan compute shader for the float_adm (Adaptive Detail Model)
 * feature extractor — sixth Group B float twin (T7-23 / ADR-0192 /
 * ADR-0199).
 *
 * Float twin of the integer ADM Vulkan kernel
 * (libvmaf/src/feature/vulkan/shaders/adm.comp, ADR-0178). Algorithm
 * mirrors the CPU compute_adm in libvmaf/src/feature/adm.c, with the
 * float (`_s` suffix) primitives from
 * libvmaf/src/feature/adm_tools.c:
 *   adm_dwt2_s, adm_decouple_s, adm_csf_s, adm_csf_den_scale_s,
 *   adm_cm_s, adm_sum_cube_s.
 *
 * Stages (via STAGE specialization constant):
 *   0 = DWT vertical pass (ref + dis fused, dim_z = 2) → tmp_lo / tmp_hi
 *   1 = DWT horizontal pass (ref + dis fused)          → 4 sub-bands
 *                                                        (a / h / v / d)
 *   2 = Decouple + CSF — produces the 3 csf_a + csf_f bands
 *       (`a` = bth - rst; csf_a = rfactor * a; csf_f = 1/30 * |csf_a|).
 *   3 = CSF denominator (|rfactor*ref|^3 sum) + Contrast Measure
 *       (per-pixel (xh,xv,xd) - thr, cubed, summed) fused — emits
 *       per-WG float partials (6 slots: csf_h/v/d, cm_h/v/d).
 *
 * Accumulator strategy
 * --------------------
 * The CPU paths use float multiply-accumulate per row, then promote
 * to double for the outer row sum. We follow the same pattern: per
 * WG, each thread accumulates its strided columns in a float, then
 * subgroupAdd reduces, then thread-0 promotes the WG total to one
 * float slot. The host then accumulates across WGs in double — that
 * absorbs the order-independence drift produced when WGs span multiple
 * rows. This matches how float_vif_vulkan (ADR-0197) and the CPU
 * AVX2 reference order their reductions.
 *
 * Mirror padding
 * --------------
 * The float ADM CPU pipeline has NO mirror asymmetry: both the scalar
 * `adm_dwt2_s` and the AVX2 `float_adm_dwt2_avx2` consume the same
 * `ind_y` / `ind_x` index buffer built by `dwt2_src_indices_filt_s`,
 * which uses `2 * sup - idx - 1` for both axes. We reproduce that
 * `-1` form here. (Cited contrastively against ADR-0197: float_vif's
 * AVX2 path actually re-derives borders inline with the `-2` form
 * from convolution_internal.h, and the GPU port had to follow that —
 * float_adm's AVX2 path does NOT, so we keep `-1`. See ADR-0199.)
 *
 * Specialization constants:
 *   constant_id = 0  WIDTH    base frame width  (scale 0)
 *   constant_id = 1  HEIGHT   base frame height (scale 0)
 *   constant_id = 2  BPC      8 / 10 / 12 / 16
 *   constant_id = 3  SCALE    0..3
 *   constant_id = 4  STAGE    0..3
 */

#version 460
#extension GL_KHR_shader_subgroup_arithmetic : require
#extension GL_KHR_shader_subgroup_basic      : require

layout(local_size_x = 16, local_size_y = 16, local_size_z = 1) in;

layout(constant_id = 0) const int WIDTH  = 0;
layout(constant_id = 1) const int HEIGHT = 0;
layout(constant_id = 2) const int BPC    = 8;
layout(constant_id = 3) const int SCALE  = 0;
layout(constant_id = 4) const int STAGE  = 0;

const int FADM_NUM_BANDS = 3;

/* CDF 9/7 (DB2) wavelet coefficients — matches dwt2_db2_coeffs_lo_s /
 * dwt2_db2_coeffs_hi_s in adm_tools.c. */
const float DWT_LO_0 =  0.482962913144690;
const float DWT_LO_1 =  0.836516303737469;
const float DWT_LO_2 =  0.224143868041857;
const float DWT_LO_3 = -0.129409522550921;
const float DWT_HI_0 = -0.129409522550921;
const float DWT_HI_1 = -0.224143868041857;
const float DWT_HI_2 =  0.836516303737469;
const float DWT_HI_3 = -0.482962913144690;

/* CSF / CM scalar constants (adm_tools.c). */
const float FLOAT_ONE_BY_30 = 0.0333333351;
const float FLOAT_ONE_BY_15 = 0.0666666701;
const float COS_1DEG_SQ = 0.99969541789740297f;
const float ADM_EPS = 1e-30;
const float ADM_BORDER_FACTOR_F = 0.1f;

/* ------------------------------------------------------------------
 * Resource bindings (storage buffers, std430).
 *
 *   binding 0: scale-0 source plane (BPC<=8: u8 packed; BPC>8: u16
 *              packed). Read by stage 0 only when SCALE==0.
 *   binding 1: dwt_tmp_ref (float, lo|hi sub-rows interleaved).
 *   binding 2: dwt_tmp_dis (float).
 *   binding 3: ref_band[0..3] (LL,HL,LH,HH packed contiguous,
 *              4 × buf_stride × half_h floats).
 *   binding 4: dis_band[0..3].
 *   binding 5: csf_a[0..2] (3 × buf_stride × half_h floats).
 *   binding 6: csf_f[0..2] (3 × buf_stride × half_h floats).
 *   binding 7: per-WG float accumulator slots (6 × #WG floats).
 *   binding 8: dis source plane (mirror of binding 0).
 * ------------------------------------------------------------------ */
layout(set = 0, binding = 0, std430) readonly  buffer RefSrc { uint  pix[]; } ref_src;
layout(set = 0, binding = 1, std430)           buffer DwtR   { float v[];   } dwt_tmp_ref;
layout(set = 0, binding = 2, std430)           buffer DwtD   { float v[];   } dwt_tmp_dis;
layout(set = 0, binding = 3, std430)           buffer RefB   { float v[];   } ref_band;
layout(set = 0, binding = 4, std430)           buffer DisB   { float v[];   } dis_band;
layout(set = 0, binding = 5, std430)           buffer CsfA   { float v[];   } csf_a_buf;
layout(set = 0, binding = 6, std430)           buffer CsfF   { float v[];   } csf_f_buf;
layout(set = 0, binding = 7, std430)           buffer Acc    { float v[];   } accum_out;
layout(set = 0, binding = 8, std430) readonly  buffer DisSrc { uint  pix[]; } dis_src;

layout(push_constant) uniform Params {
    uint cur_w;          /* this scale's input width  (parent LL width) */
    uint cur_h;          /* this scale's input height */
    uint half_w;         /* (cur_w + 1) / 2 */
    uint half_h;         /* (cur_h + 1) / 2 */
    uint buf_stride;     /* aligned float stride of the band buffers */
    float scaler;        /* HBD divisor (1 for 8-bit, 4 / 16 / 256 for 10/12/16) */
    float pixel_offset;  /* -128.0 (ADM picture_copy convention) */
    float rfactor_h;
    float rfactor_v;
    float rfactor_d;
    float gain_limit;    /* adm_enhn_gain_limit, e.g. 100.0 */
    /* Stage-3 active rectangle (border_factor margins applied). */
    int active_left;
    int active_top;
    int active_right;
    int active_bottom;
    /* Stage-3 only: reduction-rectangle column count = num_workgroups_x. */
    uint num_workgroups_x;
} pc;

/* ------------------------------------------------------------------
 * Mirror helper — both axes use the `-1` form (matches CPU
 * dwt2_src_indices_filt_s in adm_tools.c). See header notes.
 * ------------------------------------------------------------------ */
int dev_mirror(int idx, int sup) {
    if (idx < 0) return -idx;
    if (idx >= sup) return 2 * sup - idx - 1;
    return idx;
}

/* ------------------------------------------------------------------
 * Source-plane reader (scale 0 only).
 *
 * Mirror Y, clamp X. For 8-bit, the byte-packed std430 layout is
 *   row_words = ceil(w/4); pix[row*row_words + (x>>2)] >> ((x&3)*8).
 * For 10/12/16 the u16 form is row_words = ceil(w/2); pix[...] >> ((x&1)*16).
 *
 * Returns the float value with picture_copy semantics applied:
 *   8-bit:    val = (float)u8 + offset
 *   10/16:    val = (float)u16 / scaler + offset
 * ------------------------------------------------------------------ */
float read_src_pixel(uint plane_is_dis, int y, int x, int w, int h) {
    y = dev_mirror(y, h);
    if (x < 0) x = 0;
    if (x >= w) x = w - 1;
    if (BPC <= 8) {
        uint stride_words = (uint(w) + 3u) >> 2;
        uint row = uint(y) * stride_words;
        uint word = (plane_is_dis == 0u)
            ? ref_src.pix[row + (uint(x) >> 2)]
            : dis_src.pix[row + (uint(x) >> 2)];
        uint sh = (uint(x) & 3u) * 8u;
        uint b = (word >> sh) & 0xFFu;
        return float(b) + pc.pixel_offset;
    } else {
        uint stride_words = (uint(w) + 1u) >> 1;
        uint row = uint(y) * stride_words;
        uint word = (plane_is_dis == 0u)
            ? ref_src.pix[row + (uint(x) >> 1)]
            : dis_src.pix[row + (uint(x) >> 1)];
        uint sh = (uint(x) & 1u) * 16u;
        uint v = (word >> sh) & 0xFFFFu;
        return float(v) / pc.scaler + pc.pixel_offset;
    }
}

/* SCALE>0 reads parent LL band (band 0) from ref_band/dis_band. */
float read_band_a_at(uint plane_is_dis, int y, int x) {
    /* Parent width/height = pc.cur_w/cur_h here. */
    y = dev_mirror(y, int(pc.cur_h));
    if (x < 0) x = 0;
    if (x >= int(pc.cur_w)) x = int(pc.cur_w) - 1;
    /* Note: parent's buf_stride matches the *current* scale's buf_stride
     * because pc.buf_stride is sized to the half_w0 of scale 0 (and we
     * align up). The host always aligns via the same ALIGN_CEIL chain so
     * a single buf_stride works for every parent. */
    uint stride = pc.buf_stride;
    uint base = uint(y) * stride + uint(x);
    return (plane_is_dis == 0u) ? ref_band.v[base] : dis_band.v[base];
}

float read_dwt_input(uint plane_is_dis, int y, int x) {
    if (SCALE == 0) {
        return read_src_pixel(plane_is_dis, y, x, int(pc.cur_w), int(pc.cur_h));
    } else {
        return read_band_a_at(plane_is_dis, y, x);
    }
}

/* ------------------------------------------------------------------
 * Stage 0 — DWT vertical pass (ref+dis fused on dim_z = 2).
 *
 * Output row n consumes input rows 2n-1..2n+2 (4 taps). Layout:
 *   tmp[gy * (cur_w*2) + gx]               = lo
 *   tmp[gy * (cur_w*2) + cur_w + gx]       = hi
 * ------------------------------------------------------------------ */
void run_stage_dwt_vert() {
    uint gx_u = gl_GlobalInvocationID.x;
    uint gy_u = gl_GlobalInvocationID.y;
    uint plane_is_dis = gl_GlobalInvocationID.z;

    int gx = int(gx_u);
    int gy = int(gy_u);
    if (gx >= int(pc.cur_w) || gy >= int(pc.half_h)) return;

    int row_start = 2 * gy - 1;
    float s0 = read_dwt_input(plane_is_dis, row_start + 0, gx);
    float s1 = read_dwt_input(plane_is_dis, row_start + 1, gx);
    float s2 = read_dwt_input(plane_is_dis, row_start + 2, gx);
    float s3 = read_dwt_input(plane_is_dis, row_start + 3, gx);

    float lo = DWT_LO_0 * s0 + DWT_LO_1 * s1 + DWT_LO_2 * s2 + DWT_LO_3 * s3;
    float hi = DWT_HI_0 * s0 + DWT_HI_1 * s1 + DWT_HI_2 * s2 + DWT_HI_3 * s3;

    uint out_stride = pc.cur_w * 2u;
    if (plane_is_dis == 0u) {
        dwt_tmp_ref.v[uint(gy) * out_stride + uint(gx)]              = lo;
        dwt_tmp_ref.v[uint(gy) * out_stride + pc.cur_w + uint(gx)]   = hi;
    } else {
        dwt_tmp_dis.v[uint(gy) * out_stride + uint(gx)]              = lo;
        dwt_tmp_dis.v[uint(gy) * out_stride + pc.cur_w + uint(gx)]   = hi;
    }
}

/* ------------------------------------------------------------------
 * Stage 1 — DWT horizontal pass (ref+dis fused on dim_z = 2).
 *
 * Reads the lo/hi sub-rows from stage 0; emits 4 bands (a/h/v/d).
 *
 * NB the float CPU `adm_dwt2_s` orders bands as
 *   dst->band_a = lo · lo (DWT_LO ⊗ DWT_LO)
 *   dst->band_v = lo · hi (DWT_LO ⊗ DWT_HI)   — high-pass H
 *   dst->band_h = hi · lo (DWT_HI ⊗ DWT_LO)   — high-pass V
 *   dst->band_d = hi · hi (DWT_HI ⊗ DWT_HI)
 * which matches the integer ADM convention. We index slots 0..3 in the
 * same a / h / v / d order so the decouple stage's reads line up.
 * ------------------------------------------------------------------ */
float read_dwt_tmp(uint plane_is_dis, int gy, int x_sub, uint half_offset) {
    x_sub = dev_mirror(x_sub, int(pc.cur_w));
    uint stride = pc.cur_w * 2u;
    uint idx = uint(gy) * stride + half_offset + uint(x_sub);
    return (plane_is_dis == 0u) ? dwt_tmp_ref.v[idx] : dwt_tmp_dis.v[idx];
}

void write_band(uint plane_is_dis, uint band, int x, int y, float val) {
    uint slice = pc.buf_stride * pc.half_h;
    uint idx = band * slice + uint(y) * pc.buf_stride + uint(x);
    if (plane_is_dis == 0u) ref_band.v[idx] = val;
    else                    dis_band.v[idx] = val;
}

void run_stage_dwt_hori() {
    uint gx_u = gl_GlobalInvocationID.x;
    uint gy_u = gl_GlobalInvocationID.y;
    uint plane_is_dis = gl_GlobalInvocationID.z;

    int gx = int(gx_u);
    int gy = int(gy_u);
    if (gx >= int(pc.half_w) || gy >= int(pc.half_h)) return;

    int base_x = 2 * gx;

    /* lo sub-row (low-pass V output of stage 0). */
    float l0 = read_dwt_tmp(plane_is_dis, gy, base_x - 1, 0u);
    float l1 = read_dwt_tmp(plane_is_dis, gy, base_x + 0, 0u);
    float l2 = read_dwt_tmp(plane_is_dis, gy, base_x + 1, 0u);
    float l3 = read_dwt_tmp(plane_is_dis, gy, base_x + 2, 0u);

    float a_val = DWT_LO_0 * l0 + DWT_LO_1 * l1 + DWT_LO_2 * l2 + DWT_LO_3 * l3;
    float v_val = DWT_HI_0 * l0 + DWT_HI_1 * l1 + DWT_HI_2 * l2 + DWT_HI_3 * l3;

    /* hi sub-row (high-pass V output of stage 0). */
    float h0 = read_dwt_tmp(plane_is_dis, gy, base_x - 1, pc.cur_w);
    float h1 = read_dwt_tmp(plane_is_dis, gy, base_x + 0, pc.cur_w);
    float h2 = read_dwt_tmp(plane_is_dis, gy, base_x + 1, pc.cur_w);
    float h3 = read_dwt_tmp(plane_is_dis, gy, base_x + 2, pc.cur_w);

    float h_val = DWT_LO_0 * h0 + DWT_LO_1 * h1 + DWT_LO_2 * h2 + DWT_LO_3 * h3;
    float d_val = DWT_HI_0 * h0 + DWT_HI_1 * h1 + DWT_HI_2 * h2 + DWT_HI_3 * h3;

    write_band(plane_is_dis, 0u, gx, gy, a_val);
    write_band(plane_is_dis, 1u, gx, gy, h_val);
    write_band(plane_is_dis, 2u, gx, gy, v_val);
    write_band(plane_is_dis, 3u, gx, gy, d_val);
}

/* ------------------------------------------------------------------
 * Decouple + CSF helpers.
 * ------------------------------------------------------------------ */

float read_band_at(uint plane_is_dis, uint band, int y, int x) {
    uint slice = pc.buf_stride * pc.half_h;
    uint idx = band * slice + uint(y) * pc.buf_stride + uint(x);
    return (plane_is_dis == 0u) ? ref_band.v[idx] : dis_band.v[idx];
}

float read_csf_f_at(uint band, int y, int x) {
    /* Edge mirror — matches the CPU ADM_CM_THRESH_S_*_0 / *_W_M_1 /
     * 0_* / H_M_1_* macro variants in adm_tools.h. The CPU treats
     * the (i±1, ±1) reads as **mirrored to col=1 / col=w-2**, NOT as
     * clamped to col=0 / col=w-1. Same pattern on the V axis. The
     * difference is small but systematic; clamp-to-edge over-counts
     * the border CM contribution by ~1 unit per scale on the
     * Netflix normal pair. */
    if (x < 0)                  x = -x;            /* y-style mirror, dx=-1 → +1 */
    if (x >= int(pc.half_w))    x = 2 * int(pc.half_w) - x - 2;
    if (y < 0)                  y = -y;
    if (y >= int(pc.half_h))    y = 2 * int(pc.half_h) - y - 2;
    /* Final clamp guards against pathological tiny dims (e.g.
     * half_w == 1 → mirror would land at -1). */
    if (x < 0) x = 0;
    if (y < 0) y = 0;
    if (x >= int(pc.half_w)) x = int(pc.half_w) - 1;
    if (y >= int(pc.half_h)) y = int(pc.half_h) - 1;
    uint slice = pc.buf_stride * pc.half_h;
    return csf_f_buf.v[band * slice + uint(y) * pc.buf_stride + uint(x)];
}

float read_csf_a_at(uint band, int y, int x) {
    /* Used by stage 3 only; same clamp policy as csf_f. The center
     * pixel reads from raw bands re-derived inline (cheaper than
     * reading csf_a back). */
    if (x < 0) x = 0;
    if (x >= int(pc.half_w)) x = int(pc.half_w) - 1;
    if (y < 0) y = 0;
    if (y >= int(pc.half_h)) y = int(pc.half_h) - 1;
    uint slice = pc.buf_stride * pc.half_h;
    return csf_a_buf.v[band * slice + uint(y) * pc.buf_stride + uint(x)];
}

void write_csf_a(uint band, int x, int y, float val) {
    uint slice = pc.buf_stride * pc.half_h;
    csf_a_buf.v[band * slice + uint(y) * pc.buf_stride + uint(x)] = val;
}

void write_csf_f(uint band, int x, int y, float val) {
    uint slice = pc.buf_stride * pc.half_h;
    csf_f_buf.v[band * slice + uint(y) * pc.buf_stride + uint(x)] = val;
}

/* Compute decouple `r_val` + `a_val` for one band. Mirrors
 * adm_decouple_s (line 142 of adm_tools.c) for a single (band, pixel).
 *
 * Returns rst (the "r" band coefficient). a_val (the "a" band) =
 * bth - rst. The caller does that subtract.
 *
 * `precise` keeps the angle-flag floating-point ordering identical to
 * CPU's `-ffp-contract=off` semantics (matches the integer ADM kernel,
 * see ADR-0178 / T7-16). */
float decouple_one_band_f(float oh, float ov, float od_unused,
                          float th, float tv, float td_unused,
                          float bth_self, float oh_self,
                          out bool angle_flag_out)
{
    /* Angle flag is a (band-independent) per-pixel scalar: same H/V
     * directions for all 3 bands. Compute it once if the caller wants
     * it back out. */
    precise float ot_dp = oh * th + ov * tv;
    precise float o_mag = oh * oh + ov * ov;
    precise float t_mag = th * th + tv * tv;
    precise float lhs = ot_dp * ot_dp;
    precise float rhs = COS_1DEG_SQ * o_mag * t_mag;
    bool angle_flag = (ot_dp >= 0.0) && (lhs >= rhs);
    angle_flag_out = angle_flag;

    float k = bth_self / (oh_self + ADM_EPS);
    k = clamp(k, 0.0, 1.0);
    float rst = k * oh_self;

    if (angle_flag && rst > 0.0) {
        rst = min(rst * pc.gain_limit, bth_self);
    } else if (angle_flag && rst < 0.0) {
        rst = max(rst * pc.gain_limit, bth_self);
    }
    return rst;
}

/* ------------------------------------------------------------------
 * Stage 2 — Decouple + CSF (writes csf_a + csf_f for stage 3).
 * ------------------------------------------------------------------ */
void run_stage_decouple_csf() {
    uint gx_u = gl_GlobalInvocationID.x;
    uint gy_u = gl_GlobalInvocationID.y;
    int gx = int(gx_u);
    int gy = int(gy_u);
    if (gx >= int(pc.half_w) || gy >= int(pc.half_h)) return;

    /* Load all 3 bands (h, v, d) for ref and dis at this pixel. */
    float oh = read_band_at(0u, 1u, gy, gx);
    float ov = read_band_at(0u, 2u, gy, gx);
    float od = read_band_at(0u, 3u, gy, gx);
    float th = read_band_at(1u, 1u, gy, gx);
    float tv = read_band_at(1u, 2u, gy, gx);
    float td = read_band_at(1u, 3u, gy, gx);

    /* Angle flag. */
    precise float ot_dp = oh * th + ov * tv;
    precise float o_mag = oh * oh + ov * ov;
    precise float t_mag = th * th + tv * tv;
    precise float lhs_e = ot_dp * ot_dp;
    precise float rhs_e = COS_1DEG_SQ * o_mag * t_mag;
    bool angle_flag = (ot_dp >= 0.0) && (lhs_e >= rhs_e);

    float oarr[3]; oarr[0] = oh; oarr[1] = ov; oarr[2] = od;
    float tarr[3]; tarr[0] = th; tarr[1] = tv; tarr[2] = td;
    float rfac[3]; rfac[0] = pc.rfactor_h; rfac[1] = pc.rfactor_v; rfac[2] = pc.rfactor_d;

    for (int b = 0; b < FADM_NUM_BANDS; b++) {
        float k = tarr[b] / (oarr[b] + ADM_EPS);
        k = clamp(k, 0.0, 1.0);
        float rst = k * oarr[b];
        if (angle_flag && rst > 0.0)      rst = min(rst * pc.gain_limit, tarr[b]);
        else if (angle_flag && rst < 0.0) rst = max(rst * pc.gain_limit, tarr[b]);

        float a_val = tarr[b] - rst;
        float csf_a_val = rfac[b] * a_val;
        write_csf_a(uint(b), gx, gy, csf_a_val);
        write_csf_f(uint(b), gx, gy, FLOAT_ONE_BY_30 * abs(csf_a_val));
    }
}

/* ------------------------------------------------------------------
 * Stage 3 — CSF denominator (|rfactor*ref|^3) + Contrast Measure
 *           (((|csf_a| - thr) clamp 0)^3) fused, per-band per-row.
 *
 * Workgroup grid: dispatch (3 * num_active_rows, 1, 1).
 *   band_idx = wg / num_active_rows
 *   row_idx  = wg % num_active_rows
 * Each WG sums a single band's CSF and CM contributions for one row;
 * threads stride columns; subgroupAdd reduces to 1 float; thread-0
 * writes (csf_total_band, cm_total_band) into the per-WG accumulator
 * slots. The host accumulates across WGs in double.
 *
 * Slot layout per WG: 6 floats:
 *   [csf_h][csf_v][csf_d][cm_h][cm_v][cm_d]
 * but for THIS WG only the (band_idx, csf|cm) entries are written.
 * The other 4 stay zero (host-cleared).
 * ------------------------------------------------------------------ */
shared float s_csf[256];
shared float s_cm[256];

/* Computes the CM threshold for a single (row, col) pixel, summed
 * across **all 3 bands**. Mirrors `ADM_CM_THRESH_S_I_J` in
 * adm_tools.h: the macro's outer `for theta = 0..2` loop accumulates
 * (8 neighbour csf_f reads + (1/15)·|csf_a centre|) into a single
 * `*accum`. The CPU then applies that one threshold to every band's
 * `xh / xv / xd`. We replicate the cross-band sum so per-band CM
 * arithmetic matches the CPU value-for-value. */
float cm_threshold_all_bands(int row, int col,
                             float own_csf_a_h,
                             float own_csf_a_v,
                             float own_csf_a_d)
{
    float thr = 0.0;
    for (uint b = 0u; b < uint(FADM_NUM_BANDS); b++) {
        for (int dy = -1; dy <= 1; dy++) {
            for (int dx = -1; dx <= 1; dx++) {
                if (dx == 0 && dy == 0) continue;
                thr += read_csf_f_at(b, row + dy, col + dx);
            }
        }
    }
    thr += FLOAT_ONE_BY_15 * abs(own_csf_a_h);
    thr += FLOAT_ONE_BY_15 * abs(own_csf_a_v);
    thr += FLOAT_ONE_BY_15 * abs(own_csf_a_d);
    return thr;
}

void run_stage_csf_cm() {
    uint wg_id = gl_WorkGroupID.x;
    int active_h = pc.active_bottom - pc.active_top;
    int active_w = pc.active_right - pc.active_left;
    if (active_h <= 0 || active_w <= 0) return;
    uint num_rows = uint(active_h);
    uint band_idx = wg_id / num_rows;
    uint row_idx  = wg_id - band_idx * num_rows;
    int row = pc.active_top + int(row_idx);

    uint lid = gl_LocalInvocationID.y * 16u + gl_LocalInvocationID.x;
    const uint WG_SIZE = 256u;

    float rfactor_band = (band_idx == 0u) ? pc.rfactor_h
                       : (band_idx == 1u) ? pc.rfactor_v
                                          : pc.rfactor_d;

    float local_csf_sum = 0.0;
    float local_cm_sum  = 0.0;

    for (int col = pc.active_left + int(lid); col < pc.active_right; col += int(WG_SIZE)) {
        /* CSF denominator for this band: (|rfactor * ref_band|)^3.
         * adm_csf_den_scale_s reads the raw `ref_dwt2` bands. */
        float src_ref = read_band_at(0u, band_idx + 1u, row, col);
        float csf_o = abs(rfactor_band * src_ref);
        local_csf_sum += csf_o * csf_o * csf_o;

        /* Contrast measure: adm_cm_s receives `&decouple_r` as `src`,
         * NOT `ref_dwt2`. So CM uses the decoupled-reference band
         * value, which we re-derive inline here from the raw bands at
         * this pixel (same closed-form computation as adm_decouple_s,
         * cheap). The 8-neighbour `thr` comes from csf_f written by
         * stage 2; the centre's own csf_a contribution comes from
         * csf_a written by stage 2. */
        float oh = read_band_at(0u, 1u, row, col);
        float ov = read_band_at(0u, 2u, row, col);
        float od = read_band_at(0u, 3u, row, col);
        float th = read_band_at(1u, 1u, row, col);
        float tv = read_band_at(1u, 2u, row, col);
        float td = read_band_at(1u, 3u, row, col);

        precise float ot_dp = oh * th + ov * tv;
        precise float o_mag = oh * oh + ov * ov;
        precise float t_mag = th * th + tv * tv;
        precise float lhs = ot_dp * ot_dp;
        precise float rhs = COS_1DEG_SQ * o_mag * t_mag;
        bool angle_flag = (ot_dp >= 0.0) && (lhs >= rhs);

        float oarr[3]; oarr[0] = oh; oarr[1] = ov; oarr[2] = od;
        float tarr[3]; tarr[0] = th; tarr[1] = tv; tarr[2] = td;

        float k = tarr[band_idx] / (oarr[band_idx] + ADM_EPS);
        k = clamp(k, 0.0, 1.0);
        float r_val = k * oarr[band_idx];
        if (angle_flag && r_val > 0.0)
            r_val = min(r_val * pc.gain_limit, tarr[band_idx]);
        else if (angle_flag && r_val < 0.0)
            r_val = max(r_val * pc.gain_limit, tarr[band_idx]);

        /* CM threshold sums csf_f over all 3 bands' 8-neighbours +
         * (1/15)·|csf_a centre| for each of the 3 bands — matches the
         * CPU `ADM_CM_THRESH_S_I_J` macro's 3-band aggregate. */
        float own_csf_a_h = read_csf_a_at(0u, row, col);
        float own_csf_a_v = read_csf_a_at(1u, row, col);
        float own_csf_a_d = read_csf_a_at(2u, row, col);
        float thr = cm_threshold_all_bands(row, col, own_csf_a_h, own_csf_a_v, own_csf_a_d);

        float x = rfactor_band * r_val;
        float xa = abs(x) - thr;
        if (xa < 0.0) xa = 0.0;
        local_cm_sum += xa * xa * xa;
    }

    float sg_csf = subgroupAdd(local_csf_sum);
    float sg_cm  = subgroupAdd(local_cm_sum);
    uint sg_id = gl_SubgroupID;
    uint n_sg = gl_NumSubgroups;
    if (subgroupElect()) {
        s_csf[sg_id] = sg_csf;
        s_cm[sg_id]  = sg_cm;
    }
    barrier();
    if (lid == 0u) {
        float total_csf = 0.0;
        float total_cm  = 0.0;
        for (uint sg = 0u; sg < n_sg; sg++) {
            total_csf += s_csf[sg];
            total_cm  += s_cm[sg];
        }
        uint slot_base = wg_id * 6u;
        accum_out.v[slot_base + band_idx]      = total_csf;
        accum_out.v[slot_base + 3u + band_idx] = total_cm;
    }
}

/* ------------------------------------------------------------------ */

void main()
{
    if      (STAGE == 0) run_stage_dwt_vert();
    else if (STAGE == 1) run_stage_dwt_hori();
    else if (STAGE == 2) run_stage_decouple_csf();
    else                 run_stage_csf_cm();
}
