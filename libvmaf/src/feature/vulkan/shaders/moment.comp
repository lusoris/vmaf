 *
 * Vulkan compute shader for the float_moment feature extractor
 * (T7-23 / batch 1d). Mirrors libvmaf/src/feature/moment.c —
 * computes both 1st and 2nd raw moment of the ref and dis luma
 * planes in a single dispatch, accumulating into 4 separate int64
 * atomic counters (ref1st, dis1st, ref2nd, dis2nd).
 *
 * The CPU reference accumulates in `double`; the GPU
 * accumulates the equivalent in int64 (the source pixels are
 * integer YUV — no precision lost). Host divides by w*h to get
 * the final float result. Bit-exact vs CPU for any 8/10/12bpc
 * input within int64's range:
 *   max sum = 4096*4096 * 65535      = 1.1e12 < 2^63  (1st)
 *   max sum = 4096*4096 * 65535*65535 = 7.2e16 < 2^63 (2nd)
 *
 * v1: luma-only, single dispatch. Same 16x8 = 128 thread WG as
 * psnr.comp; subgroup-int64 reduction → 4 atomic counters.
 *
 * Specialization constants (set per-pipeline via VkSpecializationInfo):
 *   constant_id = 0  WIDTH
 *   constant_id = 1  HEIGHT
 *   constant_id = 2  BPC                 (8 / 10 / 12 / 16)
 *   constant_id = 3  SUBGROUP_SIZE       (compile-time array sizing)
 */
#version 460
#extension GL_KHR_shader_subgroup_arithmetic               : require
#extension GL_KHR_shader_subgroup_basic                    : require
#extension GL_EXT_shader_explicit_arithmetic_types_int64   : require
#extension GL_EXT_shader_subgroup_extended_types_int64     : require
#extension GL_EXT_shader_atomic_int64                      : require

layout(local_size_x = 16, local_size_y = 8, local_size_z = 1) in;

layout(constant_id = 0) const int WIDTH         = 0;
layout(constant_id = 1) const int HEIGHT        = 0;
layout(constant_id = 2) const int BPC           = 8;
layout(constant_id = 3) const int SUBGROUP_SIZE = 32;

const int WG_X     = 16;
const int WG_Y     = 8;
const int WG_SIZE  = WG_X * WG_Y;
/* Worst case: subgroup_size=1 on lavapipe → WG_SIZE subgroups. */
const int MAX_SUBGROUPS = WG_SIZE;

/* Per-subgroup partial sums for the 4 metrics. */
shared int64_t s_ref1st[MAX_SUBGROUPS];
shared int64_t s_dis1st[MAX_SUBGROUPS];
shared int64_t s_ref2nd[MAX_SUBGROUPS];
shared int64_t s_dis2nd[MAX_SUBGROUPS];

layout(set = 0, binding = 0, std430) readonly buffer RefIn { uint pixels[]; } ref_in;
layout(set = 0, binding = 1, std430) readonly buffer DisIn { uint pixels[]; } dis_in;
/* Out: [0]=ref1st, [1]=dis1st, [2]=ref2nd, [3]=dis2nd */
layout(set = 0, binding = 2, std430)          buffer Sums  { int64_t v[]; }   sums_out;

layout(push_constant) uniform Params {
    uint width;
    uint height;
    uint bpc;
    uint num_workgroups_x;
} pc;

uint read_ref(uint y, uint x) {
    if (BPC <= 8) {
        uint stride_words = (pc.width + 3u) >> 2;
        uint word = ref_in.pixels[y * stride_words + (x >> 2)];
        uint sh = (x & 3u) * 8u;
        return (word >> sh) & 0xFFu;
    } else {
        uint stride_words = (pc.width + 1u) >> 1;
        uint word = ref_in.pixels[y * stride_words + (x >> 1)];
        uint sh = (x & 1u) * 16u;
        return (word >> sh) & 0xFFFFu;
    }
}

uint read_dis(uint y, uint x) {
    if (BPC <= 8) {
        uint stride_words = (pc.width + 3u) >> 2;
        uint word = dis_in.pixels[y * stride_words + (x >> 2)];
        uint sh = (x & 3u) * 8u;
        return (word >> sh) & 0xFFu;
    } else {
        uint stride_words = (pc.width + 1u) >> 1;
        uint word = dis_in.pixels[y * stride_words + (x >> 1)];
        uint sh = (x & 1u) * 16u;
        return (word >> sh) & 0xFFFFu;
    }
}

void main()
{
    uint gx = gl_GlobalInvocationID.x;
    uint gy = gl_GlobalInvocationID.y;
    bool valid = (gx < pc.width && gy < pc.height);

    int64_t my_ref1 = 0L;
    int64_t my_dis1 = 0L;
    int64_t my_ref2 = 0L;
    int64_t my_dis2 = 0L;
    if (valid) {
        int64_t r = int64_t(read_ref(gy, gx));
        int64_t d = int64_t(read_dis(gy, gx));
        my_ref1 = r;
        my_dis1 = d;
        my_ref2 = r * r;
        my_dis2 = d * d;
    }

    /* Subgroup-level reductions (4 in parallel). */
    int64_t sg_ref1 = subgroupAdd(my_ref1);
    int64_t sg_dis1 = subgroupAdd(my_dis1);
    int64_t sg_ref2 = subgroupAdd(my_ref2);
    int64_t sg_dis2 = subgroupAdd(my_dis2);
    if (subgroupElect()) {
        s_ref1st[gl_SubgroupID] = sg_ref1;
        s_dis1st[gl_SubgroupID] = sg_dis1;
        s_ref2nd[gl_SubgroupID] = sg_ref2;
        s_dis2nd[gl_SubgroupID] = sg_dis2;
    }
    barrier();

    /* Cross-subgroup reduction by lane 0; one atomicAdd per metric. */
    if (gl_LocalInvocationIndex == 0u) {
        int64_t total_ref1 = 0L;
        int64_t total_dis1 = 0L;
        int64_t total_ref2 = 0L;
        int64_t total_dis2 = 0L;
        for (uint i = 0u; i < gl_NumSubgroups; ++i) {
            total_ref1 += s_ref1st[i];
            total_dis1 += s_dis1st[i];
            total_ref2 += s_ref2nd[i];
            total_dis2 += s_dis2nd[i];
        }
        atomicAdd(sums_out.v[0], total_ref1);
        atomicAdd(sums_out.v[1], total_dis1);
        atomicAdd(sums_out.v[2], total_ref2);
        atomicAdd(sums_out.v[3], total_dis2);
    }
}
