 *
 * Vulkan compute shader for the ssimulacra2 per-scale SSIMMap +
 * EdgeDiffMap stats (T7-23 / GPU long-tail batch 3 part 7 /
 * ADR-0200). Mirrors `ssim_map` + `edge_diff_map` in
 * libvmaf/src/feature/ssimulacra2.c.
 *
 * Per output pixel (per channel), computes:
 *   SSIMMap:    d   = 1 - num_m * num_s / denom_s  (clamped >= 0)
 *               accumulators: sum(d), sum(d^4)
 *   EdgeDiff:   ed1 = |img1 - mu1|, ed2 = |img2 - mu2|
 *               d1  = (1 + ed2)/(1 + ed1) - 1
 *               art = max(d1, 0); det = max(-d1, 0)
 *               accumulators: sum(art), sum(art^4),
 *                             sum(det), sum(det^4)
 *
 * One dispatch processes all 3 channels (X, Y, B) — each input
 * buffer is a 3-plane planar layout, w*h tightly packed per plane.
 *
 * Per-WG output: 18 floats, indexed (wg_idx * 18 + slot):
 *   slot[c*2 + 0]      = ssim sum_l1[c]      (c in 0..2)
 *   slot[c*2 + 1]      = ssim sum_l4[c]
 *   slot[6 + c*4 + 0]  = edge sum_art[c]
 *   slot[6 + c*4 + 1]  = edge sum_art4[c]
 *   slot[6 + c*4 + 2]  = edge sum_det[c]
 *   slot[6 + c*4 + 3]  = edge sum_det4[c]
 *
 * Specialization constants:
 *   constant_id = 0  WIDTH   (per-scale W)
 *   constant_id = 1  HEIGHT  (per-scale H)
 */
#version 460

layout(local_size_x = 16, local_size_y = 8, local_size_z = 1) in;

layout(constant_id = 0) const int WIDTH  = 0;
layout(constant_id = 1) const int HEIGHT = 0;

const int WG_X = 16;
const int WG_Y = 8;
const int WG_SIZE = WG_X * WG_Y;
const float kC2 = 0.0009;

layout(set = 0, binding = 0, std430) readonly buffer Mu1   { float v[]; } mu1;
layout(set = 0, binding = 1, std430) readonly buffer Mu2   { float v[]; } mu2;
layout(set = 0, binding = 2, std430) readonly buffer S11   { float v[]; } s11;
layout(set = 0, binding = 3, std430) readonly buffer S22   { float v[]; } s22;
layout(set = 0, binding = 4, std430) readonly buffer S12   { float v[]; } s12;
layout(set = 0, binding = 5, std430) readonly buffer Img1  { float v[]; } img1;
layout(set = 0, binding = 6, std430) readonly buffer Img2  { float v[]; } img2;
layout(set = 0, binding = 7, std430)          buffer Part  { float v[]; } partials;

layout(push_constant) uniform Params {
    uint width;
    uint height;
    uint num_workgroups_x;
    uint plane_size; /* element count per channel plane = width * height */
} pc;

/* 6 metrics per channel × 3 channels = 18 shared arrays. WG_SIZE=128. */
shared float s_buf[18][WG_SIZE];

void process_channel(uint c, uint idx, uint lid, bool in_bounds) {
    uint cidx = idx + c * pc.plane_size;
    float my_ssim_l1 = 0.0;
    float my_ssim_l4 = 0.0;
    float my_art = 0.0;
    float my_art4 = 0.0;
    float my_det = 0.0;
    float my_det4 = 0.0;

    if (in_bounds) {
        float u1 = mu1.v[cidx];
        float u2 = mu2.v[cidx];
        float a11 = s11.v[cidx];
        float a22 = s22.v[cidx];
        float a12 = s12.v[cidx];

        float u11 = u1 * u1;
        float u22 = u2 * u2;
        float u12 = u1 * u2;

        float num_m = 1.0 - (u1 - u2) * (u1 - u2);
        float num_s = 2.0 * (a12 - u12) + kC2;
        float denom_s = (a11 - u11) + (a22 - u22) + kC2;

        float d = 1.0 - (num_m * num_s) / denom_s;
        if (d < 0.0) d = 0.0;
        my_ssim_l1 = d;
        float d2 = d * d;
        my_ssim_l4 = d2 * d2;

        float i1 = img1.v[cidx];
        float i2 = img2.v[cidx];
        float ed1 = abs(i1 - u1);
        float ed2 = abs(i2 - u2);
        float dd  = (1.0 + ed2) / (1.0 + ed1) - 1.0;
        float art = max(dd, 0.0);
        float det = max(-dd, 0.0);
        my_art = art;
        float art2 = art * art;
        my_art4 = art2 * art2;
        my_det = det;
        float det2 = det * det;
        my_det4 = det2 * det2;
    }

    /* SSIM slots: c*2 + {0,1}. Edge slots: 6 + c*4 + {0..3}. */
    s_buf[c * 2u + 0u][lid] = my_ssim_l1;
    s_buf[c * 2u + 1u][lid] = my_ssim_l4;
    s_buf[6u + c * 4u + 0u][lid] = my_art;
    s_buf[6u + c * 4u + 1u][lid] = my_art4;
    s_buf[6u + c * 4u + 2u][lid] = my_det;
    s_buf[6u + c * 4u + 3u][lid] = my_det4;
}

void main() {
    uint lx = gl_LocalInvocationID.x;
    uint ly = gl_LocalInvocationID.y;
    uint lid = ly * uint(WG_X) + lx;

    uint x = gl_GlobalInvocationID.x;
    uint y = gl_GlobalInvocationID.y;
    bool in_bounds = (x < pc.width) && (y < pc.height);
    uint idx = y * pc.width + x;

    process_channel(0u, idx, lid, in_bounds);
    process_channel(1u, idx, lid, in_bounds);
    process_channel(2u, idx, lid, in_bounds);
    barrier();

    /* Lock-step shared-mem reduction: WG_SIZE = 128 → 7 halving steps. */
    for (uint stride = uint(WG_SIZE) >> 1u; stride > 0u; stride >>= 1u) {
        if (lid < stride) {
            for (uint k = 0u; k < 18u; ++k) {
                s_buf[k][lid] += s_buf[k][lid + stride];
            }
        }
        barrier();
    }

    if (lid == 0u) {
        uint wg_idx = gl_WorkGroupID.y * pc.num_workgroups_x + gl_WorkGroupID.x;
        uint base = wg_idx * 18u;
        for (uint k = 0u; k < 18u; ++k) {
            partials.v[base + k] = s_buf[k][0];
        }
    }
}
