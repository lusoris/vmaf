 *
 * Vulkan compute shader for the float_vif feature extractor.
 *
 * CPU reference: libvmaf/src/feature/vif.c (`compute_vif`) +
 * vif_tools.c (`vif_filter1d_s`, `vif_dec2_s`, `vif_statistic_s`,
 * `vif_stat_one_pixel`).
 *
 * v1 scope: `vif_kernelscale = 1.0` only (the default; the CPU
 * supports 11 alternative kernelscales but the GPU port restricts
 * to the production default per ADR-0197). Filter widths per
 * scale: {17, 9, 5, 3}.
 *
 * Two operating modes via the MODE spec constant:
 *   MODE = 0 (compute):  read ref+dis at this scale, apply
 *     separable V→H filter to compute (mu1, mu2, ref²_filt,
 *     dis²_filt, ref·dis_filt) inline, run vif_stat_one_pixel
 *     per pixel, reduce (num, den) per workgroup.
 *   MODE = 1 (decimate): read ref+dis at the *previous* scale's
 *     dimensions, apply this scale's filter, downsample by 2 →
 *     write to this scale's input buffer.
 *
 * Mirror padding diverges per axis (matches CPU `vif_mirror_tap_v` /
 * `vif_mirror_tap_h`):
 *   vertical:   2 * extent - idx - 2  for idx >= extent
 *   horizontal: 2 * extent - idx - 1  for idx >= extent
 *
 * Input source by (MODE, SCALE):
 *   MODE=compute, SCALE=0  → raw uint plane (bindings 0/1)
 *   MODE=compute, SCALE>0  → float buffer  (bindings 2/3)
 *   MODE=decimate, SCALE=1 → raw uint plane (bindings 0/1)
 *   MODE=decimate, SCALE>1 → float buffer  (bindings 2/3)
 *
 * Output by mode:
 *   MODE=compute  → per-WG (num, den) float partials at bindings 6/7
 *   MODE=decimate → float ref/dis at bindings 4/5
 *
 * Spec constants:
 *   constant_id = 0  MODE   (0 = compute, 1 = decimate)
 *   constant_id = 1  SCALE  (0..3)
 *   constant_id = 2  SUBGROUP_SIZE (32 default)
 */

#version 460
#extension GL_KHR_shader_subgroup_arithmetic : require
#extension GL_KHR_shader_subgroup_basic      : require

layout(local_size_x = 16, local_size_y = 16, local_size_z = 1) in;

layout(constant_id = 0) const int MODE          = 0;
layout(constant_id = 1) const int SCALE         = 0;
layout(constant_id = 2) const int SUBGROUP_SIZE = 32;

const int WG_X     = 16;
const int WG_Y     = 16;
const int WG_SIZE  = WG_X * WG_Y;
const int MAX_SUBGROUPS = WG_SIZE;

const int FW_S0 = 17;
const int FW_S1 = 9;
const int FW_S2 = 5;
const int FW_S3 = 3;

const float COEFF_S0[17] = float[17](
    0.00745626912, 0.0142655009,  0.0250313189,  0.0402820669,
    0.0594526194,  0.0804751068,  0.0999041125,  0.113746084,
    0.118773937,
    0.113746084,   0.0999041125,  0.0804751068,  0.0594526194,
    0.0402820669,  0.0250313189,  0.0142655009,  0.00745626912
);
const float COEFF_S1[9] = float[9](
    0.0189780835, 0.0558981746, 0.120920904, 0.192116052,
    0.224173605,
    0.192116052,  0.120920904,  0.0558981746, 0.0189780835
);
const float COEFF_S2[5] = float[5](
    0.054488685, 0.244201347, 0.402619958, 0.244201347, 0.054488685
);
const float COEFF_S3[3] = float[3](
    0.166378498, 0.667243004, 0.166378498
);

int filter_width() {
    if (SCALE == 0) return FW_S0;
    if (SCALE == 1) return FW_S1;
    if (SCALE == 2) return FW_S2;
    return FW_S3;
}
int half_filter_width() { return filter_width() / 2; }
float coeff(int idx) {
    if (SCALE == 0) return COEFF_S0[idx];
    if (SCALE == 1) return COEFF_S1[idx];
    if (SCALE == 2) return COEFF_S2[idx];
    return COEFF_S3[idx];
}

const int MAX_HALF_FW = 8;
const int TILE_W      = WG_X + 2 * MAX_HALF_FW;
const int TILE_H      = WG_Y + 2 * MAX_HALF_FW;

shared float s_ref_tile[TILE_H * TILE_W];
shared float s_dis_tile[TILE_H * TILE_W];
shared float s_v_mu1[WG_Y * TILE_W];
shared float s_v_mu2[WG_Y * TILE_W];
shared float s_v_xx[WG_Y * TILE_W];
shared float s_v_yy[WG_Y * TILE_W];
shared float s_v_xy[WG_Y * TILE_W];
shared float s_num[MAX_SUBGROUPS];
shared float s_den[MAX_SUBGROUPS];

layout(set = 0, binding = 0, std430) readonly buffer RefRaw { uint  p[]; } ref_raw;
layout(set = 0, binding = 1, std430) readonly buffer DisRaw { uint  p[]; } dis_raw;
layout(set = 0, binding = 2, std430) readonly buffer RefF   { float v[]; } ref_f;
layout(set = 0, binding = 3, std430) readonly buffer DisF   { float v[]; } dis_f;
layout(set = 0, binding = 4, std430)          buffer RefOut { float v[]; } ref_out;
layout(set = 0, binding = 5, std430)          buffer DisOut { float v[]; } dis_out;
layout(set = 0, binding = 6, std430)          buffer NumOut { float v[]; } num_out;
layout(set = 0, binding = 7, std430)          buffer DenOut { float v[]; } den_out;

layout(push_constant) uniform Params {
    uint width;
    uint height;
    uint bpc;
    uint num_workgroups_x;
    uint in_width;
    uint in_height;
} pc;

int dev_mirror_v(int idx, int sup) {
    if (idx < 0) return -idx;
    if (idx >= sup) return 2 * sup - idx - 2;
    return idx;
}
/* H mirror matches CPU `convolution_edge_s` (used by the AVX2
 * border path that runs in production at default vif_sigma_nsq=2.0).
 * Note: this differs by one from `vif_mirror_tap_h` in vif_tools.c
 * (which is only reached on the scalar fallback path). The CPU has
 * an internal asymmetry; the GPU follows the AVX2 path because
 * that's what production runs against. */
int dev_mirror_h(int idx, int sup) {
    if (idx < 0) return -idx;
    if (idx >= sup) return 2 * sup - idx - 2;
    return idx;
}

float read_raw_ref(int y, int x, int stride_w, uint bpc) {
    if (bpc <= 8u) {
        uint stride_words = (uint(stride_w) + 3u) >> 2;
        uint word = ref_raw.p[uint(y) * stride_words + (uint(x) >> 2)];
        uint v = (word >> ((uint(x) & 3u) * 8u)) & 0xFFu;
        return float(v) - 128.0;
    }
    uint stride_words = (uint(stride_w) + 1u) >> 1;
    uint word = ref_raw.p[uint(y) * stride_words + (uint(x) >> 1)];
    uint v = (word >> ((uint(x) & 1u) * 16u)) & 0xFFFFu;
    float scaler = 1.0;
    if (bpc == 10u) scaler = 4.0;
    else if (bpc == 12u) scaler = 16.0;
    else if (bpc == 16u) scaler = 256.0;
    return float(v) / scaler - 128.0;
}
float read_raw_dis(int y, int x, int stride_w, uint bpc) {
    if (bpc <= 8u) {
        uint stride_words = (uint(stride_w) + 3u) >> 2;
        uint word = dis_raw.p[uint(y) * stride_words + (uint(x) >> 2)];
        uint v = (word >> ((uint(x) & 3u) * 8u)) & 0xFFu;
        return float(v) - 128.0;
    }
    uint stride_words = (uint(stride_w) + 1u) >> 1;
    uint word = dis_raw.p[uint(y) * stride_words + (uint(x) >> 1)];
    uint v = (word >> ((uint(x) & 1u) * 16u)) & 0xFFFFu;
    float scaler = 1.0;
    if (bpc == 10u) scaler = 4.0;
    else if (bpc == 12u) scaler = 16.0;
    else if (bpc == 16u) scaler = 256.0;
    return float(v) / scaler - 128.0;
}

float load_ref(int y, int x) {
    bool raw_src = (MODE == 0 && SCALE == 0) || (MODE == 1 && SCALE == 1);
    if (raw_src) return read_raw_ref(y, x, int(pc.in_width), pc.bpc);
    return ref_f.v[y * int(pc.in_width) + x];
}
float load_dis(int y, int x) {
    bool raw_src = (MODE == 0 && SCALE == 0) || (MODE == 1 && SCALE == 1);
    if (raw_src) return read_raw_dis(y, x, int(pc.in_width), pc.bpc);
    return dis_f.v[y * int(pc.in_width) + x];
}

void main_compute() {
    int gx = int(gl_GlobalInvocationID.x);
    int gy = int(gl_GlobalInvocationID.y);
    int lx = int(gl_LocalInvocationID.x);
    int ly = int(gl_LocalInvocationID.y);
    uint lid = uint(ly * WG_X + lx);
    bool valid = (gx < int(pc.width) && gy < int(pc.height));

    int fw = filter_width();
    int hfw = half_filter_width();
    int tile_w = WG_X + 2 * hfw;
    int tile_h = WG_Y + 2 * hfw;

    int tile_oy = int(gl_WorkGroupID.y) * WG_Y - hfw;
    int tile_ox = int(gl_WorkGroupID.x) * WG_X - hfw;
    int tile_elems = tile_h * tile_w;
    for (int i = int(lid); i < tile_elems; i += WG_SIZE) {
        int tr = i / tile_w;
        int tc = i - tr * tile_w;
        int py = dev_mirror_v(tile_oy + tr, int(pc.height));
        int px = dev_mirror_h(tile_ox + tc, int(pc.width));
        s_ref_tile[tr * TILE_W + tc] = load_ref(py, px);
        s_dis_tile[tr * TILE_W + tc] = load_dis(py, px);
    }
    barrier();

    int vert_total = WG_Y * tile_w;
    for (int i = int(lid); i < vert_total; i += WG_SIZE) {
        int r = i / tile_w;
        int c = i - r * tile_w;
        float a_mu1 = 0.0, a_mu2 = 0.0, a_xx = 0.0, a_yy = 0.0, a_xy = 0.0;
        for (int k = 0; k < fw; k++) {
            float c_k = coeff(k);
            float ref_v = s_ref_tile[(r + k) * TILE_W + c];
            float dis_v = s_dis_tile[(r + k) * TILE_W + c];
            a_mu1 += c_k * ref_v;
            a_mu2 += c_k * dis_v;
            a_xx  += c_k * (ref_v * ref_v);
            a_yy  += c_k * (dis_v * dis_v);
            a_xy  += c_k * (ref_v * dis_v);
        }
        s_v_mu1[r * TILE_W + c] = a_mu1;
        s_v_mu2[r * TILE_W + c] = a_mu2;
        s_v_xx [r * TILE_W + c] = a_xx;
        s_v_yy [r * TILE_W + c] = a_yy;
        s_v_xy [r * TILE_W + c] = a_xy;
    }
    barrier();

    float my_num = 0.0;
    float my_den = 0.0;
    if (valid) {
        float mu1 = 0.0, mu2 = 0.0, xx = 0.0, yy = 0.0, xy = 0.0;
        for (int k = 0; k < fw; k++) {
            float c_k = coeff(k);
            mu1 += c_k * s_v_mu1[ly * TILE_W + (lx + k)];
            mu2 += c_k * s_v_mu2[ly * TILE_W + (lx + k)];
            xx  += c_k * s_v_xx [ly * TILE_W + (lx + k)];
            yy  += c_k * s_v_yy [ly * TILE_W + (lx + k)];
            xy  += c_k * s_v_xy [ly * TILE_W + (lx + k)];
        }

        const float eps = 1.0e-10;
        const float vif_sigma_nsq = 2.0;
        const float vif_egl = 100.0;
        const float sigma_max_inv = (2.0 * 2.0) / (255.0 * 255.0);

        float sigma1_sq = xx - mu1 * mu1;
        float sigma2_sq = yy - mu2 * mu2;
        float sigma12   = xy - mu1 * mu2;
        sigma1_sq = max(sigma1_sq, 0.0);
        sigma2_sq = max(sigma2_sq, 0.0);
        float g = sigma12 / (sigma1_sq + eps);
        float sv_sq = sigma2_sq - g * sigma12;
        if (sigma1_sq < eps) {
            g = 0.0;
            sv_sq = sigma2_sq;
            sigma1_sq = 0.0;
        }
        if (sigma2_sq < eps) {
            g = 0.0;
            sv_sq = 0.0;
        }
        if (g < 0.0) {
            sv_sq = sigma2_sq;
            g = 0.0;
        }
        sv_sq = max(sv_sq, eps);
        g = min(g, vif_egl);

        float num_val = log2(1.0 + (g * g * sigma1_sq) / (sv_sq + vif_sigma_nsq));
        float den_val = log2(1.0 + sigma1_sq / vif_sigma_nsq);
        if (sigma12 < 0.0) num_val = 0.0;
        if (sigma1_sq < vif_sigma_nsq) {
            num_val = 1.0 - sigma2_sq * sigma_max_inv;
            den_val = 1.0;
        }
        my_num = num_val;
        my_den = den_val;
    }

    float sg_num = subgroupAdd(my_num);
    float sg_den = subgroupAdd(my_den);
    uint sg_id = gl_SubgroupID;
    uint n_subgrps = gl_NumSubgroups;
    if (subgroupElect()) {
        s_num[sg_id] = sg_num;
        s_den[sg_id] = sg_den;
    }
    barrier();
    if (lid == 0u) {
        float total_num = 0.0, total_den = 0.0;
        for (uint s = 0u; s < n_subgrps; s++) {
            total_num += s_num[s];
            total_den += s_den[s];
        }
        uint wg_idx = gl_WorkGroupID.y * pc.num_workgroups_x + gl_WorkGroupID.x;
        num_out.v[wg_idx] = total_num;
        den_out.v[wg_idx] = total_den;
    }
}

void main_decimate() {
    int gx = int(gl_GlobalInvocationID.x);
    int gy = int(gl_GlobalInvocationID.y);
    bool valid = (gx < int(pc.width) && gy < int(pc.height));
    if (!valid) return;

    int fw = filter_width();
    int hfw = half_filter_width();
    /* CPU runs with VIF_OPT_HANDLE_BORDERS defined: filter uses mirror
     * padding across the full input plane and vif_dec2_s subsamples at
     * (2*gx, 2*gy). The filter is centred on (2*gx, 2*gy) — NOT on
     * (hfw + 2*gx, hfw + 2*gy) — and mirror padding handles taps that
     * fall outside [0, in_dim). */
    int in_x = 2 * gx;
    int in_y = 2 * gy;
    /* V-inner / H-outer ordering — matches CPU vif_filter1d_s
     * which writes tmp[j] = sum_fi f_fi * src[mirror_v(fi)][j] then
     * dst = sum_fj f_fj * tmp[mirror_h(fj)]. */
    float acc_ref = 0.0;
    float acc_dis = 0.0;
    for (int kj = 0; kj < fw; kj++) {
        float c_j = coeff(kj);
        int px = dev_mirror_h(in_x - hfw + kj, int(pc.in_width));
        float v_ref = 0.0, v_dis = 0.0;
        for (int ki = 0; ki < fw; ki++) {
            float c_i = coeff(ki);
            int py = dev_mirror_v(in_y - hfw + ki, int(pc.in_height));
            v_ref += c_i * load_ref(py, px);
            v_dis += c_i * load_dis(py, px);
        }
        acc_ref += c_j * v_ref;
        acc_dis += c_j * v_dis;
    }
    int out_idx = gy * int(pc.width) + gx;
    ref_out.v[out_idx] = acc_ref;
    dis_out.v[out_idx] = acc_dis;
}

void main() {
    if (MODE == 0) main_compute();
    else main_decimate();
}
