 *
 * Vulkan compute shader for the ssimulacra2 elementwise plane
 * multiply (T7-23 / GPU long-tail batch 3 part 7 / ADR-0200).
 * Mirrors `multiply_3plane` in libvmaf/src/feature/ssimulacra2.c
 * — but operates on a single plane per dispatch (the host loops
 * over the 3 channels). out[i] = a[i] * b[i].
 *
 * Specialization constants:
 *   constant_id = 0  WIDTH
 *   constant_id = 1  HEIGHT
 */
#version 460

layout(local_size_x = 16, local_size_y = 8, local_size_z = 1) in;

layout(constant_id = 0) const int WIDTH  = 0;
layout(constant_id = 1) const int HEIGHT = 0;

layout(set = 0, binding = 0, std430) readonly buffer AIn  { float v[]; } a_in;
layout(set = 0, binding = 1, std430) readonly buffer BIn  { float v[]; } b_in;
layout(set = 0, binding = 2, std430)          buffer Out  { float v[]; } out_buf;

layout(push_constant) uniform Params {
    uint width;       /* per-scale W (used for bounds + index stride) */
    uint height;
    uint plane_count; /* 1 or 3 — number of contiguous planes to process */
    uint plane_stride; /* element offset between consecutive channels = full_w * full_h */
} pc;

void main() {
    uint x = gl_GlobalInvocationID.x;
    uint y = gl_GlobalInvocationID.y;
    if (x >= pc.width || y >= pc.height)
        return;
    uint base = y * pc.width + x;
    for (uint c = 0u; c < pc.plane_count; ++c) {
        uint idx = base + c * pc.plane_stride;
        out_buf.v[idx] = a_in.v[idx] * b_in.v[idx];
    }
}
