 *
 * Vulkan compute shader for the integer motion feature extractor.
 *
 * Direct port of libvmaf/src/feature/sycl/integer_motion_sycl.cpp's
 * `launch_blur_sad_fused` kernel, mirroring the CPU
 * libvmaf/src/feature/integer_motion.c V->H separable Gaussian blur
 * + SAD between consecutive blurred reference frames.
 *
 * Algorithm (must match CPU integer_motion):
 *   1. Vertical filter on src plane:
 *        v[i,j] = (sum_k filter[k] * src[mirror(i-2+k), j] + (1<<(bpc-1))) >> bpc
 *   2. Horizontal filter on v:
 *        b[i,j] = (sum_k filter[k] * v[i, mirror(j-2+k)] + 32768) >> 16
 *   3. SAD:
 *        sad += |b[i,j] - prev_b[i,j]|   (per-pixel uint16)
 *
 * Filter (sum = 65536):
 *   {3571, 16004, 26386, 16004, 3571}
 *
 * Mirror padding (matches CPU edge_8 / edge_16):
 *   if (i < 0)        i = -i;
 *   if (i >= h)       i = 2*(h-1) - i;
 *   (and analogous for j vs. width)
 *
 * int64 SAD reduction
 * -------------------
 * Each workgroup writes a single int64_t partial-SAD into its slot of
 * the per-WG accumulator SSBO. The host CPU sums the slots after the
 * dispatch — same approach as vif.comp, no atomic-int64 capability
 * required. GL_EXT_shader_explicit_arithmetic_types_int64 gives us
 * native i64 for the per-thread / per-subgroup reductions.
 *
 * Specialization constants (set per-pipeline via VkSpecializationInfo):
 *   constant_id = 0  WIDTH
 *   constant_id = 1  HEIGHT
 *   constant_id = 2  BPC            8 / 10 / 12 / 16
 *   constant_id = 3  COMPUTE_SAD    0 = first frame, 1 = SAD vs prev
 *
 * SCOPE NOTE: motion3 (the 5-frame window mode in CPU
 * integer_motion.c) is intentionally NOT implemented here. It needs a
 * 5-deep ring buffer of blurred frames + the motion_blend / moving
 * average post-processing. Defer to a follow-up PR.
 */

#version 460
#extension GL_KHR_shader_subgroup_arithmetic               : require
#extension GL_KHR_shader_subgroup_basic                    : require
#extension GL_EXT_shader_explicit_arithmetic_types_int64   : require
#extension GL_EXT_shader_subgroup_extended_types_int64     : require

/* Workgroup geometry: 32 x 4 = 128 threads, matches vif.comp. */
layout(local_size_x = 32, local_size_y = 4, local_size_z = 1) in;

layout(constant_id = 0) const int WIDTH       = 0;
layout(constant_id = 1) const int HEIGHT      = 0;
layout(constant_id = 2) const int BPC         = 8;
/* SUBGROUP_SIZE pinned per-pipeline at create time; default 32 matches
 * Arc / RDNA wave32 / NVIDIA warp. Used only for compile-time array
 * sizing; runtime uses gl_NumSubgroups for the actual reduction. */
layout(constant_id = 3) const int SUBGROUP_SIZE = 32;

const int FW          = 5;
const int HALF_FW     = 2;
const int WG_X        = 32;
const int WG_Y        = 4;
const int WG_SIZE     = WG_X * WG_Y;
const int MAX_SUBGROUPS = WG_SIZE;

const uint FILTER[5] = uint[5]( 3571u, 16004u, 26386u, 16004u, 3571u );

/* Tile dimensions: 5-tap filter + WG halo on every edge. */
const int TILE_H = WG_Y + FW - 1;   /* 4 + 4 = 8  */
const int TILE_W = WG_X + FW - 1;   /* 32 + 4 = 36 */

shared uint  s_tile[TILE_H * TILE_W];   /* raw source pixels */
/* Vertically-filtered intermediate covering the full row halo so the
 * horizontal pass can index neighbours: (WG_Y rows) x TILE_W columns. */
shared uint  s_vert[WG_Y * TILE_W];

/* Per-subgroup partial SAD scratch. */
shared int64_t s_sad[MAX_SUBGROUPS];

/* ------------------------------------------------------------------
 * Resource bindings.
 *   binding 0: ref input plane.
 *              BPC <= 8  -> uint8 packed in uint32 (4 px / word)
 *              BPC  > 8  -> uint16 packed in uint32 (2 px / word)
 *   binding 1: cur blurred output (uint per pixel, payload uint16).
 *   binding 2: prev blurred input (uint per pixel, payload uint16).
 *              Read only when COMPUTE_SAD == 1.
 *   binding 3: per-workgroup int64 SAD partials (one slot per WG).
 * ------------------------------------------------------------------ */
layout(set = 0, binding = 0, std430) readonly buffer RefIn  { uint pixels[]; } ref_in;
layout(set = 0, binding = 1, std430)          buffer CurB   { uint b[];      } cur_blur;
layout(set = 0, binding = 2, std430) readonly buffer PrevB  { uint b[];      } prev_blur;
layout(set = 0, binding = 3, std430)          buffer Sad    { int64_t v[];   } sad_out;

layout(push_constant) uniform Params {
    uint width;
    uint height;
    uint bpc;
    uint compute_sad;
    uint num_workgroups_x;
} pc;

int dev_mirror(int idx, int sup) {
    if (idx < 0) return -idx;
    if (idx >= sup) return 2 * (sup - 1) - idx;
    return idx;
}

uint read_src(int y, int x) {
    if (BPC <= 8) {
        uint stride_words = (uint(pc.width) + 3u) >> 2;     /* tightly packed */
        uint row = uint(y) * stride_words;
        uint word = ref_in.pixels[row + (uint(x) >> 2)];
        uint sh = (uint(x) & 3u) * 8u;
        return (word >> sh) & 0xFFu;
    } else {
        uint stride_words = (uint(pc.width) + 1u) >> 1;
        uint row = uint(y) * stride_words;
        uint word = ref_in.pixels[row + (uint(x) >> 1)];
        uint sh = (uint(x) & 1u) * 16u;
        return (word >> sh) & 0xFFFFu;
    }
}

void main()
{
    int gx = int(gl_GlobalInvocationID.x);
    int gy = int(gl_GlobalInvocationID.y);
    int lx = int(gl_LocalInvocationID.x);
    int ly = int(gl_LocalInvocationID.y);
    uint lid = uint(ly * WG_X + lx);
    bool valid = (gx < int(pc.width) && gy < int(pc.height));

    /* Vertical-pass round/shift (CPU: round = 1 << (bpc-1), shift = bpc). */
    uint shift_v = pc.bpc;
    uint round_v = 1u << (pc.bpc - 1u);

    /* ============================================================
     * Phase 1: cooperative tile load with mirror padding.
     * Tile covers WG_X cols x WG_Y rows of outputs, with HALF_FW
     * halo on every side for the 5-tap separable filter.
     * ============================================================ */
    int tile_oy = int(gl_WorkGroupID.y) * WG_Y - HALF_FW;
    int tile_ox = int(gl_WorkGroupID.x) * WG_X - HALF_FW;
    int tile_elems = TILE_H * TILE_W;

    bool interior =
        (tile_oy >= 0) && (tile_oy + TILE_H <= int(pc.height)) &&
        (tile_ox >= 0) && (tile_ox + TILE_W <= int(pc.width));

    for (int i = int(lid); i < tile_elems; i += WG_SIZE) {
        int tr = i / TILE_W;
        int tc = i - tr * TILE_W;
        int py = tile_oy + tr;
        int px = tile_ox + tc;
        if (!interior) {
            py = dev_mirror(py, int(pc.height));
            px = dev_mirror(px, int(pc.width));
        }
        s_tile[tr * TILE_W + tc] = read_src(py, px);
    }
    barrier();

    /* ============================================================
     * Phase 2: cooperative vertical convolution -> s_vert.
     * Output covers WG_Y rows x TILE_W columns (full halo width).
     * For an output row r (0..WG_Y-1), input rows are r..r+FW-1.
     * ============================================================ */
    int vert_total = WG_Y * TILE_W;
    for (int i = int(lid); i < vert_total; i += WG_SIZE) {
        int r = i / TILE_W;
        int c = i - r * TILE_W;
        uint acc = 0u;
        for (int k = 0; k < FW; k++) {
            acc += FILTER[k] * s_tile[(r + k) * TILE_W + c];
        }
        /* Vertical quantization: (acc + round_v) >> shift_v -> uint16. */
        s_vert[r * TILE_W + c] = (acc + round_v) >> shift_v;
    }
    barrier();

    /* ============================================================
     * Phase 3: per-thread horizontal convolution + SAD.
     * For valid output pixel (gx, gy) with local (lx, ly):
     *   blurred = (sum filter[k] * s_vert[ly, lx+k] + 32768) >> 16
     * ============================================================ */
    int64_t abs_diff = 0L;

    if (valid) {
        uint h = 0u;
        for (int k = 0; k < FW; k++) {
            h += FILTER[k] * s_vert[ly * TILE_W + (lx + k)];
        }
        uint blurred = (h + 32768u) >> 16;
        cur_blur.b[uint(gy) * pc.width + uint(gx)] = blurred & 0xFFFFu;

        if (pc.compute_sad != 0u) {
            uint prev = prev_blur.b[uint(gy) * pc.width + uint(gx)] & 0xFFFFu;
            int diff = int(blurred) - int(prev);
            abs_diff = int64_t(diff < 0 ? -diff : diff);
        }
    }

    /* ============================================================
     * Phase 4: subgroup + cross-subgroup SAD reduction.
     * ============================================================ */
    if (pc.compute_sad != 0u) {
        int64_t sg_sum = subgroupAdd(abs_diff);
        uint sg_id     = gl_SubgroupID;
        uint n_subgrps = gl_NumSubgroups;

        if (subgroupElect()) {
            s_sad[sg_id] = sg_sum;
        }
        barrier();

        if (lid == 0u) {
            int64_t total = 0L;
            for (uint s = 0u; s < n_subgrps; s++) {
                total += s_sad[s];
            }
            uint wg_idx = gl_WorkGroupID.y * pc.num_workgroups_x + gl_WorkGroupID.x;
            sad_out.v[wg_idx] = total;
        }
    } else {
        /* First frame: ensure the per-WG slot is zero so the host
         * reducer sees no garbage from a previous run. */
        if (lid == 0u) {
            uint wg_idx = gl_WorkGroupID.y * pc.num_workgroups_x + gl_WorkGroupID.x;
            sad_out.v[wg_idx] = 0L;
        }
    }
}
