 *
 * Two-level GPU reduction shader for the motion per-workgroup SAD
 * accumulators (T-GPU-PERF-VK-3 / ADR-0350).
 *
 * Input:  per-WG SAD partials SSBO from motion.comp —
 *           [wg_count] int64_t  (one int64 per workgroup).
 * Output: a single int64_t total SAD in accum_out.v[0].
 *
 * The caller (motion_vulkan.c) reads 8 bytes total instead of
 * wg_count × 8 bytes from a host-visible buffer. For 1080p at
 * 32×4 workgroups, wg_count = 60 × 270 = 16,200 → was 129,600 B,
 * now 8 B. See ADR-0350.
 *
 * Bit-exactness: identical argument as vif_reduce.comp. Integer
 * tree reduction == sequential sum for any evaluation order.
 */

#version 460
#extension GL_KHR_shader_subgroup_arithmetic             : require
#extension GL_KHR_shader_subgroup_basic                  : require
#extension GL_EXT_shader_explicit_arithmetic_types_int64 : require
#extension GL_EXT_shader_subgroup_extended_types_int64   : require
#extension GL_EXT_shader_atomic_int64                    : require

layout(local_size_x = 256, local_size_y = 1, local_size_z = 1) in;

const int WG_SIZE       = 256;
const int MAX_SUBGROUPS = WG_SIZE;

layout(set = 0, binding = 0, std430) readonly buffer AccumIn {
    int64_t v[];
} accum_in;

layout(set = 0, binding = 1, std430) buffer AccumOut {
    int64_t v[];
} accum_out;

layout(push_constant) uniform Params {
    uint wg_count;
} pc;

shared int64_t s_lmem[MAX_SUBGROUPS];

void main()
{
    uint tid   = gl_LocalInvocationIndex;
    uint gid   = gl_GlobalInvocationID.x;
    uint sg_id = gl_SubgroupID;
    uint n_sg  = gl_NumSubgroups;

    int64_t t = 0L;
    uint total_threads = gl_WorkGroupSize.x * gl_NumWorkGroups.x;
    for (uint slot = gid; slot < pc.wg_count; slot += total_threads) {
        t += accum_in.v[slot];
    }

    int64_t sg_sum = subgroupAdd(t);

    if (subgroupElect()) {
        s_lmem[sg_id] = sg_sum;
    }
    memoryBarrierShared();
    barrier();

    if (tid == 0u) {
        int64_t wg_total = 0L;
        for (uint s = 0u; s < n_sg; s++) {
            wg_total += s_lmem[s];
        }
        atomicAdd(accum_out.v[0], wg_total);
    }
}
