 * SPDX-License-Identifier: BSD-3-Clause-Plus-Patent
 *
 * Vulkan compute shader for the float_ansnr feature extractor.
 *
 * CPU reference: libvmaf/src/feature/ansnr.c::compute_ansnr (2D filter
 * path; ANSNR_OPT_FILTER_1D and ANSNR_OPT_NORMALIZE both off, matching
 * the active build).
 *
 * Algorithm (must match CPU):
 *   1. Convert ref / dis pixels to float in [-128, 127.something]
 *      (`(raw / scaler) - 128.0` where scaler matches CPU
 *      picture_copy: 1 for bpc=8, 4 for bpc=10, 16 for bpc=12, 256
 *      for bpc=16).
 *   2. Apply 3x3 ref filter (1/16 weights) -> ref_filtr.
 *   3. Apply 5x5 dis filter (sums to 1.0, weights /571) -> filtd.
 *   4. sig   += ref_filtr * ref_filtr
 *      noise += (ref_filtr - filtd) * (ref_filtr - filtd)
 *   Single dispatch; per-WG sums of sig + noise (2 floats per WG)
 *   reduced on the host in `double`.
 *
 * Mirror padding: `2 * size - idx - 1` for idx >= size (edge-
 * replicating reflective mirror — same as motion_v2.comp, NOT the
 * skip-boundary form used by motion.comp).
 *
 * Specialization constants:
 *   constant_id = 0  WIDTH
 *   constant_id = 1  HEIGHT
 *   constant_id = 2  BPC            8 / 10 / 12 / 16
 *   constant_id = 3  SUBGROUP_SIZE  32 (default)
 *
 * Bindings:
 *   binding 0: ref input plane (uint8 / uint16 packed in uint32)
 *   binding 1: dis input plane (same layout)
 *   binding 2: per-workgroup `sig` partials (float, one slot per WG)
 *   binding 3: per-workgroup `noise` partials (float, one slot per WG)
 *
 * Precision contract per ADR-0192: places=3 (float convolution +
 * float reductions + log10 final transform). The convolution kernels
 * are deterministic but the per-WG float reduction and the log10 in
 * the final score introduce ULPs vs the CPU's strict left-to-right
 * accumulator. Empirical floor measured per backend at PR time.
 */

#version 460
#extension GL_KHR_shader_subgroup_arithmetic : require
#extension GL_KHR_shader_subgroup_basic      : require

layout(local_size_x = 16, local_size_y = 16, local_size_z = 1) in;

layout(constant_id = 0) const int WIDTH         = 0;
layout(constant_id = 1) const int HEIGHT        = 0;
layout(constant_id = 2) const int BPC           = 8;
layout(constant_id = 3) const int SUBGROUP_SIZE = 32;

const int WG_X = 16;
const int WG_Y = 16;
const int WG_SIZE = WG_X * WG_Y;
const int HALF_FW = 2;          /* dis filter is 5x5, dominates */
const int TILE_W = WG_X + 2 * HALF_FW;  /* 20 */
const int TILE_H = WG_Y + 2 * HALF_FW;  /* 20 */
const int MAX_SUBGROUPS = WG_SIZE;

/* CPU ansnr_filter2d_ref_s: 3x3 = {1,2,1; 2,4,2; 1,2,1} / 16. */
const float FILT_REF[9] = float[9](
    1.0/16.0, 2.0/16.0, 1.0/16.0,
    2.0/16.0, 4.0/16.0, 2.0/16.0,
    1.0/16.0, 2.0/16.0, 1.0/16.0
);

/* CPU ansnr_filter2d_dis_s: 5x5 = {2,7,12,7,2; 7,31,52,31,7;
 *   12,52,127,52,12; 7,31,52,31,7; 2,7,12,7,2} / 571. */
const float FILT_DIS[25] = float[25](
     2.0/571.0,  7.0/571.0, 12.0/571.0,  7.0/571.0,  2.0/571.0,
     7.0/571.0, 31.0/571.0, 52.0/571.0, 31.0/571.0,  7.0/571.0,
    12.0/571.0, 52.0/571.0,127.0/571.0, 52.0/571.0, 12.0/571.0,
     7.0/571.0, 31.0/571.0, 52.0/571.0, 31.0/571.0,  7.0/571.0,
     2.0/571.0,  7.0/571.0, 12.0/571.0,  7.0/571.0,  2.0/571.0
);

shared float s_ref[TILE_H * TILE_W];
shared float s_dis[TILE_H * TILE_W];
shared float s_sig[MAX_SUBGROUPS];
shared float s_noise[MAX_SUBGROUPS];

layout(set = 0, binding = 0, std430) readonly buffer Ref { uint pixels[]; } ref_in;
layout(set = 0, binding = 1, std430) readonly buffer Dis { uint pixels[]; } dis_in;
layout(set = 0, binding = 2, std430)          buffer Sig { float v[];    } sig_out;
layout(set = 0, binding = 3, std430)          buffer Noi { float v[];    } noise_out;

layout(push_constant) uniform Params {
    uint width;
    uint height;
    uint bpc;
    uint num_workgroups_x;
} pc;

int dev_mirror(int idx, int sup) {
    if (idx < 0) return -idx;
    if (idx >= sup) return 2 * sup - idx - 1;
    return idx;
}

/* GLSL doesn't allow passing SSBO arrays as function parameters
 * portably, so the per-binding readers are duplicated below. */

float read_ref_px(int y, int x, float scaler) {
    if (BPC <= 8) {
        uint stride_words = (uint(pc.width) + 3u) >> 2;
        uint word = ref_in.pixels[uint(y) * stride_words + (uint(x) >> 2)];
        uint v = (word >> ((uint(x) & 3u) * 8u)) & 0xFFu;
        return float(v) - 128.0;
    } else {
        uint stride_words = (uint(pc.width) + 1u) >> 1;
        uint word = ref_in.pixels[uint(y) * stride_words + (uint(x) >> 1)];
        uint v = (word >> ((uint(x) & 1u) * 16u)) & 0xFFFFu;
        return float(v) / scaler - 128.0;
    }
}

float read_dis_px(int y, int x, float scaler) {
    if (BPC <= 8) {
        uint stride_words = (uint(pc.width) + 3u) >> 2;
        uint word = dis_in.pixels[uint(y) * stride_words + (uint(x) >> 2)];
        uint v = (word >> ((uint(x) & 3u) * 8u)) & 0xFFu;
        return float(v) - 128.0;
    } else {
        uint stride_words = (uint(pc.width) + 1u) >> 1;
        uint word = dis_in.pixels[uint(y) * stride_words + (uint(x) >> 1)];
        uint v = (word >> ((uint(x) & 1u) * 16u)) & 0xFFFFu;
        return float(v) / scaler - 128.0;
    }
}

void main() {
    int gx = int(gl_GlobalInvocationID.x);
    int gy = int(gl_GlobalInvocationID.y);
    int lx = int(gl_LocalInvocationID.x);
    int ly = int(gl_LocalInvocationID.y);
    uint lid = uint(ly * WG_X + lx);
    bool valid = (gx < int(pc.width) && gy < int(pc.height));

    /* picture_copy scaler: 1 for bpc<=8, else 1<<(bpc-8). */
    float scaler = 1.0;
    if (BPC == 10) scaler = 4.0;
    else if (BPC == 12) scaler = 16.0;
    else if (BPC == 16) scaler = 256.0;

    /* --- Phase 1: cooperative tile load --- */
    int tile_oy = int(gl_WorkGroupID.y) * WG_Y - HALF_FW;
    int tile_ox = int(gl_WorkGroupID.x) * WG_X - HALF_FW;
    int tile_elems = TILE_H * TILE_W;

    bool interior =
        (tile_oy >= 0) && (tile_oy + TILE_H <= int(pc.height)) &&
        (tile_ox >= 0) && (tile_ox + TILE_W <= int(pc.width));

    for (int i = int(lid); i < tile_elems; i += WG_SIZE) {
        int tr = i / TILE_W;
        int tc = i - tr * TILE_W;
        int py = tile_oy + tr;
        int px = tile_ox + tc;
        if (!interior) {
            py = dev_mirror(py, int(pc.height));
            px = dev_mirror(px, int(pc.width));
        }
        s_ref[tr * TILE_W + tc] = read_ref_px(py, px, scaler);
        s_dis[tr * TILE_W + tc] = read_dis_px(py, px, scaler);
    }
    barrier();

    /* --- Phase 2: per-thread 3x3 ref + 5x5 dis filters + accumulators --- */
    float my_sig = 0.0;
    float my_noise = 0.0;

    if (valid) {
        /* Center-of-pixel index in the shared tile is (ly + HALF_FW,
         * lx + HALF_FW). 3x3 reads s_ref[ly+1..ly+3][lx+1..lx+3];
         * 5x5 reads s_dis[ly..ly+4][lx..lx+4]. */
        float ref_filtr = 0.0;
        for (int k = 0; k < 3; k++) {
            for (int l = 0; l < 3; l++) {
                ref_filtr += FILT_REF[k * 3 + l] *
                             s_ref[(ly + 1 + k) * TILE_W + (lx + 1 + l)];
            }
        }

        float filtd = 0.0;
        for (int k = 0; k < 5; k++) {
            for (int l = 0; l < 5; l++) {
                filtd += FILT_DIS[k * 5 + l] *
                         s_dis[(ly + k) * TILE_W + (lx + l)];
            }
        }

        my_sig   = ref_filtr * ref_filtr;
        float diff = ref_filtr - filtd;
        my_noise = diff * diff;
    }

    /* --- Phase 3: subgroup + cross-subgroup reductions for sig + noise --- */
    float sg_sig   = subgroupAdd(my_sig);
    float sg_noise = subgroupAdd(my_noise);
    uint  sg_id    = gl_SubgroupID;
    uint  n_subgrps = gl_NumSubgroups;

    if (subgroupElect()) {
        s_sig[sg_id]   = sg_sig;
        s_noise[sg_id] = sg_noise;
    }
    barrier();

    if (lid == 0u) {
        float total_sig = 0.0;
        float total_noise = 0.0;
        for (uint s = 0u; s < n_subgrps; s++) {
            total_sig   += s_sig[s];
            total_noise += s_noise[s];
        }
        uint wg_idx = gl_WorkGroupID.y * pc.num_workgroups_x + gl_WorkGroupID.x;
        sig_out.v[wg_idx]   = total_sig;
        noise_out.v[wg_idx] = total_noise;
    }
}
