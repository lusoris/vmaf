 *
 * Vulkan compute shader for the integer_ssim feature extractor.
 * Port of the CUDA twin (feature/cuda/integer_ssim/ssim_score.cu) to
 * GLSL, following the float ssim.comp two-pass design but reading raw
 * integer luma samples (uint8 or uint16) directly from the SSBO instead
 * of pre-converted float values.
 *
 * Normalisation mirrors picture_copy / picture_copy_hbd:
 *   8bpc  → sample as-is in [0, 255]
 *   10bpc → sample / 4   → [0, 255]
 *   12bpc → sample / 16  → [0, 255]
 *   16bpc → sample / 256 → [0, 255]
 * so L=255 and the SSIM constants C1, C2 match the CPU path.
 *
 * Two dispatches:
 *   PASS = 0  main_horiz:         horizontal 11-tap separable Gaussian
 *                                  over ref / cmp / ref² / cmp² / ref·cmp
 *                                  → 5 float intermediate buffers sized
 *                                  (W - 10) × H.
 *   PASS = 1  main_vert_combine:  vertical 11-tap on intermediates +
 *                                  per-pixel SSIM combine + per-WG partial
 *                                  sum stored in partials[wg_idx].
 *
 * Host accumulates per-WG float partials in double, divides by
 * (W - 10)·(H - 10) and emits `ssim` (the integer-path SSIM feature
 * consumed by the VMAF model).
 *
 * Spec-constants:
 *   0  WIDTH         full input width
 *   1  HEIGHT        full input height
 *   2  PASS          0 = horiz, 1 = vert+combine
 *   3  BPC           bits per component (8, 10, 12, 16)
 *   4  SUBGROUP_SIZE compile-time subgroup size for shared-array sizing
 */
#version 460
#extension GL_KHR_shader_subgroup_arithmetic : require
#extension GL_KHR_shader_subgroup_basic      : require

layout(local_size_x = 16, local_size_y = 8, local_size_z = 1) in;

layout(constant_id = 0) const int WIDTH         = 0;
layout(constant_id = 1) const int HEIGHT        = 0;
layout(constant_id = 2) const int PASS          = 0;
layout(constant_id = 3) const int BPC           = 8;
layout(constant_id = 4) const int SUBGROUP_SIZE = 32;

const int WG_X    = 16;
const int WG_Y    = 8;
const int WG_SIZE = WG_X * WG_Y;
/* Maximum number of subgroups per workgroup — sized to the compile-time
 * SUBGROUP_SIZE spec-constant so the array is stack-allocated once. */
const int MAX_SUBGROUPS = WG_SIZE;
const int K      = 11;
const int K_HALF = 5;

/* 11-tap normalised Gaussian — byte-for-byte match with the CPU's
 * g_gaussian_window_h in libvmaf/src/feature/iqa/ssim_tools.h. */
const float G[K] = float[](
    0.001028, 0.007599, 0.036001, 0.109361, 0.213006,
    0.266012,
    0.213006, 0.109361, 0.036001, 0.007599, 0.001028);

shared float s_partials[MAX_SUBGROUPS];

/* Binding 0+1: raw luma samples.
 *   8bpc  → each element is one uint8 packed as uint (only low 8 bits used).
 *   16bpc → each element is one uint16 packed as uint (low 16 bits used).
 * The host uploads row-packed data (no padding) with
 *   bytes_per_pixel = (bpc <= 8) ? 1 : 2
 * and stride = width * bytes_per_pixel. We use a uint[] view and
 * unpack manually so a single shader binary covers both depths (the
 * spec-constant BPC selects the branch at pipeline-compile time). */
layout(set = 0, binding = 0, std430) readonly buffer RefIn    { uint v[]; } ref_in;
layout(set = 0, binding = 1, std430) readonly buffer CmpIn    { uint v[]; } cmp_in;
layout(set = 0, binding = 2, std430)          buffer HRefMu   { float v[]; } h_ref_mu;
layout(set = 0, binding = 3, std430)          buffer HCmpMu   { float v[]; } h_cmp_mu;
layout(set = 0, binding = 4, std430)          buffer HRefSq   { float v[]; } h_ref_sq;
layout(set = 0, binding = 5, std430)          buffer HCmpSq   { float v[]; } h_cmp_sq;
layout(set = 0, binding = 6, std430)          buffer HRefCmp  { float v[]; } h_refcmp;
layout(set = 0, binding = 7, std430)          buffer Partials { float v[]; } partials_out;

layout(push_constant) uniform Params {
    uint width;
    uint height;
    uint w_horiz;
    uint h_horiz;
    uint w_final;
    uint h_final;
    uint num_workgroups_x;
    float c1;
    float c2;
} pc;

/* Read one normalised luma sample from the raw-integer SSBO.
 * For 8bpc: each uint holds one sample (only bits [7:0] live).
 * For 16bpc: each uint holds one sample (bits [15:0] live).
 * The host packs the rows contiguously; stride = width * bytes_per_pixel
 * and the buffer is indexed as elements, not bytes. */
float read_ref(uint x, uint y) {
    if (BPC <= 8) {
        /* 8bpc: buffer element = 1 byte packed into low 8 bits of uint.
         * The host uploads via uint8 view; each element corresponds to
         * one uint value holding the byte. */
        uint raw = ref_in.v[y * pc.width + x];
        return float(raw & 0xFFu);
    } else {
        /* 10/12/16bpc: host uploads uint16 values in the low 16 bits.
         * Scaler: 10bpc→4, 12bpc→16, 16bpc→256. */
        uint raw    = ref_in.v[y * pc.width + x];
        float sval  = float(raw & 0xFFFFu);
        float scale = (BPC == 10) ? 4.0 : (BPC == 12) ? 16.0 : 256.0;
        return sval / scale;
    }
}

float read_cmp(uint x, uint y) {
    if (BPC <= 8) {
        uint raw = cmp_in.v[y * pc.width + x];
        return float(raw & 0xFFu);
    } else {
        uint raw    = cmp_in.v[y * pc.width + x];
        float sval  = float(raw & 0xFFFFu);
        float scale = (BPC == 10) ? 4.0 : (BPC == 12) ? 16.0 : 256.0;
        return sval / scale;
    }
}

void main_horiz(uint x, uint y) {
    if (x >= pc.w_horiz || y >= pc.h_horiz)
        return;

    float ref_mu_h = 0.0;
    float cmp_mu_h = 0.0;
    float ref_sq_h = 0.0;
    float cmp_sq_h = 0.0;
    float refcmp_h = 0.0;

    for (int u = 0; u < K; u++) {
        uint src_x = x + uint(u);
        float r = read_ref(src_x, y);
        float c = read_cmp(src_x, y);
        float w = G[u];
        ref_mu_h += w * r;
        cmp_mu_h += w * c;
        ref_sq_h += w * (r * r);
        cmp_sq_h += w * (c * c);
        refcmp_h += w * (r * c);
    }

    uint dst_idx = y * pc.w_horiz + x;
    h_ref_mu.v[dst_idx] = ref_mu_h;
    h_cmp_mu.v[dst_idx] = cmp_mu_h;
    h_ref_sq.v[dst_idx] = ref_sq_h;
    h_cmp_sq.v[dst_idx] = cmp_sq_h;
    h_refcmp.v[dst_idx] = refcmp_h;
}

void main_vert_combine(uint x, uint y) {
    float my_ssim = 0.0;
    if (x < pc.w_final && y < pc.h_final) {
        float ref_mu = 0.0;
        float cmp_mu = 0.0;
        float ref_sq = 0.0;
        float cmp_sq = 0.0;
        float refcmp = 0.0;

        for (int v = 0; v < K; v++) {
            uint src_y  = y + uint(v);
            uint src_idx = src_y * pc.w_horiz + x;
            float w = G[v];
            ref_mu += w * h_ref_mu.v[src_idx];
            cmp_mu += w * h_cmp_mu.v[src_idx];
            ref_sq += w * h_ref_sq.v[src_idx];
            cmp_sq += w * h_cmp_sq.v[src_idx];
            refcmp += w * h_refcmp.v[src_idx];
        }

        float ref_var = ref_sq - ref_mu * ref_mu;
        float cmp_var = cmp_sq - cmp_mu * cmp_mu;
        float covar   = refcmp - ref_mu * cmp_mu;
        float mu_xy   = ref_mu * cmp_mu;
        float num     = (2.0 * mu_xy + pc.c1) * (2.0 * covar + pc.c2);
        float den     = (ref_mu * ref_mu + cmp_mu * cmp_mu + pc.c1) *
                        (ref_var + cmp_var + pc.c2);
        my_ssim = num / den;
    }

    float sg_sum = subgroupAdd(my_ssim);
    if (subgroupElect()) {
        s_partials[gl_SubgroupID] = sg_sum;
    }
    barrier();

    if (gl_LocalInvocationIndex == 0u) {
        float wg_total = 0.0;
        for (uint i = 0u; i < gl_NumSubgroups; ++i) {
            wg_total += s_partials[i];
        }
        uint wg_idx = gl_WorkGroupID.y * pc.num_workgroups_x + gl_WorkGroupID.x;
        partials_out.v[wg_idx] = wg_total;
    }
}

void main() {
    uint gx = gl_GlobalInvocationID.x;
    uint gy = gl_GlobalInvocationID.y;
    if (PASS == 0) {
        main_horiz(gx, gy);
    } else {
        main_vert_combine(gx, gy);
    }
}
