 *
 * Vulkan compute shader for the float_ms_ssim pyramid decimation
 * step (T7-23 / batch 2 part 2a / ADR-0188 / ADR-0190). Mirrors
 * libvmaf/src/feature/ms_ssim_decimate.c::ms_ssim_decimate_scalar
 * — 9-tap 9/7 biorthogonal LPF in separable form, 2× downsample
 * in both dimensions.
 *
 * REBASE-SENSITIVE INVARIANT: the LPF coefficients MUST match
 * `ms_ssim_lpf_h` / `ms_ssim_lpf_v` in
 * libvmaf/src/feature/ms_ssim_decimate.c (which itself mirrors
 * `g_lpf_h` / `g_lpf_v` in libvmaf/src/feature/ms_ssim.c). See
 * docs/adr/0125-ms-ssim-decimate-simd.md.
 *
 * Single 2D dispatch — each thread computes one output pixel
 * doing 81 source reads (9×9). At pyramid scales 0..4 with
 * 576×324 input the largest scale is 576×324 → 288×162, so
 * even at the coarsest output the ALU/bandwidth ratio is
 * acceptable.
 *
 * Output dimensions: w_out = (w + 1) >> 1, h_out = (h + 1) >> 1.
 *
 * Specialization constants (per VkSpecializationInfo):
 *   constant_id = 0  WIDTH       (input W)
 *   constant_id = 1  HEIGHT      (input H)
 */
#version 460

layout(local_size_x = 16, local_size_y = 8, local_size_z = 1) in;

layout(constant_id = 0) const int WIDTH  = 0;
layout(constant_id = 1) const int HEIGHT = 0;

const int LPF_LEN = 9;
const int LPF_HALF = 4;

const float LPF[LPF_LEN] = float[](
    0.026727, -0.016828, -0.078201, 0.266846, 0.602914,
    0.266846, -0.078201, -0.016828, 0.026727);

layout(set = 0, binding = 0, std430) readonly buffer SrcIn { float v[]; } src_in;
layout(set = 0, binding = 1, std430)          buffer DstOut { float v[]; } dst_out;

layout(push_constant) uniform Params {
    uint width;
    uint height;
    uint w_out;
    uint h_out;
} pc;

/* Period-2n mirror — handles sub-kernel-radius inputs the
 * single-reflect form leaves out of bounds. Matches
 * ms_ssim_decimate_mirror() in ms_ssim_decimate.c. */
int mirror_idx(int idx, int n) {
    int period = 2 * n;
    int r = idx % period;
    if (r < 0) r += period;
    if (r >= n) r = period - r - 1;
    return r;
}

void main() {
    uint x_out = gl_GlobalInvocationID.x;
    uint y_out = gl_GlobalInvocationID.y;
    if (x_out >= pc.w_out || y_out >= pc.h_out)
        return;

    int w = int(pc.width);
    int h = int(pc.height);
    int x_src = int(x_out) * 2;
    int y_src = int(y_out) * 2;

    /* Separable: horizontal then vertical. Inline the two
     * passes inside one kernel so we don't need a temp buffer.
     * Cost: 9*9 = 81 LPF evaluations per output pixel. */
    float acc = 0.0;
    for (int kv = 0; kv < LPF_LEN; ++kv) {
        int yi = mirror_idx(y_src + kv - LPF_HALF, h);
        float row_acc = 0.0;
        for (int ku = 0; ku < LPF_LEN; ++ku) {
            int xi = mirror_idx(x_src + ku - LPF_HALF, w);
            row_acc += src_in.v[yi * w + xi] * LPF[ku];
        }
        acc += row_acc * LPF[kv];
    }
    dst_out.v[y_out * pc.w_out + x_out] = acc;
}
