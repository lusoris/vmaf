 *
 * Vulkan compute shader for the float_ms_ssim feature
 * extractor (T7-23 / batch 2 part 2a / ADR-0190). Variant of
 * ssim.comp (PR #139) — same separable 11-tap Gaussian over
 * 5 SSIM stats, but the vertical pass emits THREE per-WG
 * partial sums (l, c, s) instead of one combined SSIM mean.
 * Per-pixel l/c/s formulas mirror ssim_accumulate_default_scalar
 * in iqa/ssim_tools.c line-for-line, including the σxy clamp.
 *
 * Two passes (selected by PASS spec constant):
 *   1. main_horiz:   horizontal 11-tap → 5 intermediate floats
 *                    (identical to ssim.comp's pass 0)
 *   2. main_vert_lcs: vertical 11-tap on intermediates +
 *                     per-pixel l/c/s + 3-output per-WG sums
 *
 * Output dimensions follow iqa_convolve's "valid" convention:
 *   horiz output:  w_h × h_h = (W - 10) × H
 *   vert  output:  w_v × h_v = (W - 10) × (H - 10)
 *
 * Specialization constants:
 *   constant_id = 0  WIDTH         (input W after decimation)
 *   constant_id = 1  HEIGHT        (input H after decimation)
 *   constant_id = 2  PASS          (0 = horiz, 1 = vert+lcs)
 *   constant_id = 3  SUBGROUP_SIZE
 */
#version 460
#extension GL_KHR_shader_subgroup_arithmetic : require
#extension GL_KHR_shader_subgroup_basic      : require

layout(local_size_x = 16, local_size_y = 8, local_size_z = 1) in;

layout(constant_id = 0) const int WIDTH         = 0;
layout(constant_id = 1) const int HEIGHT        = 0;
layout(constant_id = 2) const int PASS          = 0;
layout(constant_id = 3) const int SUBGROUP_SIZE = 32;

const int WG_X = 16;
const int WG_Y = 8;
const int WG_SIZE = WG_X * WG_Y;
const int MAX_SUBGROUPS = WG_SIZE;
const int K = 11;

/* 11-tap normalised Gaussian — bit-identical to ssim.comp's G[]
 * which itself matches g_gaussian_window_h in
 * libvmaf/src/feature/iqa/ssim_tools.h. */
const float G[K] = float[](
    0.001028, 0.007599, 0.036001, 0.109361, 0.213006,
    0.266012,
    0.213006, 0.109361, 0.036001, 0.007599, 0.001028);

/* Per-subgroup partials for 3 metrics (used in PASS=1 only). */
shared float s_l[MAX_SUBGROUPS];
shared float s_c[MAX_SUBGROUPS];
shared float s_s[MAX_SUBGROUPS];

layout(set = 0, binding = 0, std430) readonly buffer RefIn   { float v[]; } ref_in;
layout(set = 0, binding = 1, std430) readonly buffer CmpIn   { float v[]; } cmp_in;
layout(set = 0, binding = 2, std430)          buffer HRefMu  { float v[]; } h_ref_mu;
layout(set = 0, binding = 3, std430)          buffer HCmpMu  { float v[]; } h_cmp_mu;
layout(set = 0, binding = 4, std430)          buffer HRefSq  { float v[]; } h_ref_sq;
layout(set = 0, binding = 5, std430)          buffer HCmpSq  { float v[]; } h_cmp_sq;
layout(set = 0, binding = 6, std430)          buffer HRefCmp { float v[]; } h_refcmp;
layout(set = 0, binding = 7, std430)          buffer LPart   { float v[]; } l_partials;
layout(set = 0, binding = 8, std430)          buffer CPart   { float v[]; } c_partials;
layout(set = 0, binding = 9, std430)          buffer SPart   { float v[]; } s_partials;

layout(push_constant) uniform Params {
    uint width;
    uint height;
    uint w_horiz;
    uint h_horiz;
    uint w_final;
    uint h_final;
    uint num_workgroups_x;
    float c1;
    float c2;
    float c3;
} pc;

void main_horiz(uint x, uint y) {
    if (x >= pc.w_horiz || y >= pc.h_horiz)
        return;

    float ref_mu_h = 0.0;
    float cmp_mu_h = 0.0;
    float ref_sq_h = 0.0;
    float cmp_sq_h = 0.0;
    float refcmp_h = 0.0;

    for (int u = 0; u < K; u++) {
        uint src_x = x + uint(u);
        uint src_idx = y * pc.width + src_x;
        float r = ref_in.v[src_idx];
        float c = cmp_in.v[src_idx];
        float w = G[u];
        ref_mu_h += w * r;
        cmp_mu_h += w * c;
        ref_sq_h += w * (r * r);
        cmp_sq_h += w * (c * c);
        refcmp_h += w * (r * c);
    }

    uint dst_idx = y * pc.w_horiz + x;
    h_ref_mu.v[dst_idx]  = ref_mu_h;
    h_cmp_mu.v[dst_idx]  = cmp_mu_h;
    h_ref_sq.v[dst_idx]  = ref_sq_h;
    h_cmp_sq.v[dst_idx]  = cmp_sq_h;
    h_refcmp.v[dst_idx]  = refcmp_h;
}

void main_vert_lcs(uint x, uint y) {
    float my_l = 0.0;
    float my_c = 0.0;
    float my_s = 0.0;
    if (x < pc.w_final && y < pc.h_final) {
        float ref_mu = 0.0;
        float cmp_mu = 0.0;
        float ref_sq = 0.0;
        float cmp_sq = 0.0;
        float refcmp = 0.0;

        for (int v = 0; v < K; v++) {
            uint src_y = y + uint(v);
            uint src_idx = src_y * pc.w_horiz + x;
            float w = G[v];
            ref_mu += w * h_ref_mu.v[src_idx];
            cmp_mu += w * h_cmp_mu.v[src_idx];
            ref_sq += w * h_ref_sq.v[src_idx];
            cmp_sq += w * h_cmp_sq.v[src_idx];
            refcmp += w * h_refcmp.v[src_idx];
        }

        /* ssim_variance: σ² = E[x²] - μ²; σ_xy = E[xy] - μxμy.
         * Clamp variances to >=0 before sqrt — matches the
         * `MAX(0, ...)` clamp in iqa/ssim_tools.c::ssim_variance_scalar
         * which otherwise produces NaN on flat regions where
         * float ULP errors push σ² slightly negative. */
        float ref_var = max(ref_sq - ref_mu * ref_mu, 0.0);
        float cmp_var = max(cmp_sq - cmp_mu * cmp_mu, 0.0);
        float covar   = refcmp - ref_mu * cmp_mu;
        /* sigma_ref_sigma_cmp = sqrt(σx²·σy²) — bit-exact match
         * to ssim_accumulate_default_scalar via sqrt of product. */
        float sigma_xy_geom = sqrt(ref_var * cmp_var);
        /* Clamp σxy for the ref==cmp flat-region edge case where
         * σxy can drift slightly negative via float rounding while
         * sigma_xy_geom is zero. Mirrors lines 192-194 in
         * iqa/ssim_tools.c. */
        float clamped_sigma_xy = (covar < 0.0 && sigma_xy_geom <= 0.0) ? 0.0 : covar;

        float l = (2.0 * ref_mu * cmp_mu + pc.c1) /
                  (ref_mu * ref_mu + cmp_mu * cmp_mu + pc.c1);
        float c = (2.0 * sigma_xy_geom + pc.c2) / (ref_var + cmp_var + pc.c2);
        float s = (clamped_sigma_xy + pc.c3) / (sigma_xy_geom + pc.c3);
        my_l = l;
        my_c = c;
        my_s = s;
    }

    /* 3 parallel per-WG reductions: subgroup → shared[] → one
     * float per partial buffer per WG. */
    float sg_l = subgroupAdd(my_l);
    float sg_c = subgroupAdd(my_c);
    float sg_s = subgroupAdd(my_s);
    if (subgroupElect()) {
        s_l[gl_SubgroupID] = sg_l;
        s_c[gl_SubgroupID] = sg_c;
        s_s[gl_SubgroupID] = sg_s;
    }
    barrier();

    if (gl_LocalInvocationIndex == 0u) {
        float wg_l = 0.0;
        float wg_c = 0.0;
        float wg_s = 0.0;
        for (uint i = 0u; i < gl_NumSubgroups; ++i) {
            wg_l += s_l[i];
            wg_c += s_c[i];
            wg_s += s_s[i];
        }
        uint wg_idx = gl_WorkGroupID.y * pc.num_workgroups_x + gl_WorkGroupID.x;
        l_partials.v[wg_idx] = wg_l;
        c_partials.v[wg_idx] = wg_c;
        s_partials.v[wg_idx] = wg_s;
    }
}

void main() {
    uint gx = gl_GlobalInvocationID.x;
    uint gy = gl_GlobalInvocationID.y;
    if (PASS == 0) {
        main_horiz(gx, gy);
    } else {
        main_vert_lcs(gx, gy);
    }
}
