 * SPDX-License-Identifier: BSD-3-Clause-Plus-Patent
 *
 * Vulkan compute shader for the per-pixel derivative kernel of
 * the cambi spatial mask. CPU reference:
 *
 *   libvmaf/src/feature/cambi.c::get_derivative_data_for_row()
 *   libvmaf/src/feature/x86/cambi_avx2.c::get_derivative_data_for_row_avx2()
 *
 * Algorithm (must match CPU bit-exactly):
 *   For each pixel (i, j):
 *     horizontal_derivative = (j == width - 1)
 *                          || image[i, j] == image[i, j + 1]
 *     vertical_derivative   = (i == height - 1)
 *                          || image[i, j] == image[i + 1, j]
 *     derivative[i, j] = (horizontal_derivative && vertical_derivative) ? 1 : 0
 *
 * Edge cases (matching the AVX2 path):
 *   - Last column: horizontal_derivative is forced to true.
 *   - Last row:    vertical_derivative is forced to true; the AVX2
 *                  path special-cases this row to compute only the
 *                  horizontal derivative — same end value because
 *                  vertical_derivative becomes a constant `1`.
 *
 * Output is a single `uint16` per pixel (0 or 1), matching CPU's
 * `uint16_t derivative_buffer[]` layout. Bit-exact w.r.t. CPU.
 *
 * Status: scaffold only. Not yet build-wired; full integration
 * deferred to the follow-up PR that ships `cambi_vulkan.c`'s host
 * residual call path. See ADR-0205.
 *
 * Specialization constants:
 *   constant_id = 0  WIDTH
 *   constant_id = 1  HEIGHT
 *
 * Bindings:
 *   binding 0: image input plane (uint16 packed in uint32)
 *   binding 1: derivative output (uint16 packed in uint32)
 *
 * Precision contract: bit-exact (integer `==` and `&&`).
 */

#version 460

layout(local_size_x = 16, local_size_y = 16, local_size_z = 1) in;

layout(constant_id = 0) const int WIDTH  = 0;
layout(constant_id = 1) const int HEIGHT = 0;

layout(set = 0, binding = 0, std430) readonly buffer Img  { uint pixels[]; } image_in;
layout(set = 0, binding = 1, std430)          buffer Drv  { uint pixels[]; } derivative_out;

layout(push_constant) uniform Params {
    uint width;
    uint height;
    uint stride_words;   /* = (width + 1) >> 1 — image is uint16 packed */
    uint deriv_stride_words;
} pc;

uint read_image_u16(int y, int x) {
    uint word = image_in.pixels[uint(y) * pc.stride_words + (uint(x) >> 1)];
    return (word >> ((uint(x) & 1u) * 16u)) & 0xFFFFu;
}

void write_derivative_u16(int y, int x, uint v) {
    uint idx = uint(y) * pc.deriv_stride_words + (uint(x) >> 1);
    uint shift = (uint(x) & 1u) * 16u;
    uint mask = 0xFFFFu << shift;
    /* Word-tearing free path: each 32-bit word holds two derivative
     * outputs at distinct (y, x); but two adjacent x's may map to
     * the same word and run on different threads. Use atomicAnd +
     * atomicOr to set the half-word. */
    atomicAnd(derivative_out.pixels[idx], ~mask);
    atomicOr (derivative_out.pixels[idx], (v & 0xFFFFu) << shift);
}

void main() {
    int x = int(gl_GlobalInvocationID.x);
    int y = int(gl_GlobalInvocationID.y);
    if (x >= int(pc.width) || y >= int(pc.height))
        return;

    uint cur = read_image_u16(y, x);

    bool h_eq;
    if (x == int(pc.width) - 1) {
        h_eq = true;
    } else {
        uint right = read_image_u16(y, x + 1);
        h_eq = (cur == right);
    }

    bool v_eq;
    if (y == int(pc.height) - 1) {
        v_eq = true;
    } else {
        uint below = read_image_u16(y + 1, x);
        v_eq = (cur == below);
    }

    uint d = (h_eq && v_eq) ? 1u : 0u;
    write_derivative_u16(y, x, d);
}
