 *
 * Vulkan compute shader for the float_ssim feature extractor
 * (T7-23 / batch 2 part 1a / ADR-0188 / ADR-0189). Mirrors the
 * SIMD-dispatched CPU path in libvmaf/src/feature/iqa/ssim_tools.c
 * + iqa/convolve.c — separable 11-tap Gaussian convolution of
 * five SSIM stats (ref_mu, cmp_mu, ref², cmp², ref·cmp), then a
 * per-pixel SSIM combine using:
 *
 *     SSIM(x,y) = (2·μ_xy + C1)·(2·σ_xy + C2)
 *               / ((μ_x² + μ_y² + C1)·(σ_x² + σ_y² + C2))
 *
 * Two dispatches:
 *   1. main_horiz:    horizontal 11-tap → 5 intermediate floats
 *                     per pixel.
 *   2. main_vert_combine: vertical 11-tap on intermediates +
 *                          per-pixel SSIM + per-WG partial sum.
 *
 * Output dimensions follow iqa_convolve's "valid" convention:
 *   horiz output:  w_h × h_h = (W - 10) × H
 *   vert  output:  w_v × h_v = (W - 10) × (H - 10)
 *
 * SSIM is averaged over (W - 10)·(H - 10) pixels — same window
 * the CPU uses (per ssim_compute_stats / iqa_ssim).
 *
 * Specialization constants (per VkSpecializationInfo):
 *   constant_id = 0  WIDTH         (input W after decimation)
 *   constant_id = 1  HEIGHT        (input H after decimation)
 *   constant_id = 2  PASS          (0 = horiz, 1 = vert+combine)
 *   constant_id = 3  SUBGROUP_SIZE (compile-time array sizing)
 */
#version 460
#extension GL_KHR_shader_subgroup_arithmetic : require
#extension GL_KHR_shader_subgroup_basic      : require

layout(local_size_x = 16, local_size_y = 8, local_size_z = 1) in;

layout(constant_id = 0) const int WIDTH         = 0;
layout(constant_id = 1) const int HEIGHT        = 0;
layout(constant_id = 2) const int PASS          = 0;
layout(constant_id = 3) const int SUBGROUP_SIZE = 32;

const int WG_X    = 16;
const int WG_Y    = 8;
const int WG_SIZE = WG_X * WG_Y;
const int MAX_SUBGROUPS = WG_SIZE;
const int K = 11;
const int K_HALF = 5;

/* 11-tap normalized Gaussian — matches g_gaussian_window_h
 * in libvmaf/src/feature/iqa/ssim_tools.h byte-for-byte. */
const float G[K] = float[](
    0.001028, 0.007599, 0.036001, 0.109361, 0.213006,
    0.266012,
    0.213006, 0.109361, 0.036001, 0.007599, 0.001028);

/* Per-subgroup partial sums for the per-pixel SSIM contribution
 * (used in PASS=1 only). */
shared float s_partials[MAX_SUBGROUPS];

/* PASS 0 inputs: ref_in, cmp_in (float, full W × H).
 * PASS 0 outputs: 5 intermediates (float, w_h × h_h).
 *
 * PASS 1 inputs: 5 intermediates from pass 0 (float, w_h × h_h).
 * PASS 1 outputs: partials_out (float[wg_count]). */
layout(set = 0, binding = 0, std430) readonly buffer RefIn   { float v[]; } ref_in;
layout(set = 0, binding = 1, std430) readonly buffer CmpIn   { float v[]; } cmp_in;
layout(set = 0, binding = 2, std430)          buffer HRefMu  { float v[]; } h_ref_mu;
layout(set = 0, binding = 3, std430)          buffer HCmpMu  { float v[]; } h_cmp_mu;
layout(set = 0, binding = 4, std430)          buffer HRefSq  { float v[]; } h_ref_sq;
layout(set = 0, binding = 5, std430)          buffer HCmpSq  { float v[]; } h_cmp_sq;
layout(set = 0, binding = 6, std430)          buffer HRefCmp { float v[]; } h_refcmp;
layout(set = 0, binding = 7, std430)          buffer Partials { float v[]; } partials_out;

layout(push_constant) uniform Params {
    uint width;            /* full input width  */
    uint height;           /* full input height */
    uint w_horiz;          /* W - K + 1 = W - 10 */
    uint h_horiz;          /* H */
    uint w_final;          /* W - 10 */
    uint h_final;          /* H - 10 */
    uint num_workgroups_x; /* dispatch grid in pass 1 */
    float c1;
    float c2;
} pc;

/* PASS 0: read ref + cmp at column (x..x+10, row y); compute the
 * 5 horizontal-pass values into the intermediate buffers. The
 * output buffer is sized w_horiz × H_horiz where w_horiz = W-10,
 * h_horiz = H. The output index uses w_horiz as stride. */
void main_horiz(uint x, uint y) {
    if (x >= pc.w_horiz || y >= pc.h_horiz)
        return;

    float ref_mu_h = 0.0;
    float cmp_mu_h = 0.0;
    float ref_sq_h = 0.0;
    float cmp_sq_h = 0.0;
    float refcmp_h = 0.0;

    /* Each output pixel reads input columns [x, x + K - 1]. */
    for (int u = 0; u < K; u++) {
        uint src_x = x + uint(u);
        uint src_idx = y * pc.width + src_x;
        float r = ref_in.v[src_idx];
        float c = cmp_in.v[src_idx];
        float w = G[u];
        ref_mu_h += w * r;
        cmp_mu_h += w * c;
        ref_sq_h += w * (r * r);
        cmp_sq_h += w * (c * c);
        refcmp_h += w * (r * c);
    }

    uint dst_idx = y * pc.w_horiz + x;
    h_ref_mu.v[dst_idx]  = ref_mu_h;
    h_cmp_mu.v[dst_idx]  = cmp_mu_h;
    h_ref_sq.v[dst_idx]  = ref_sq_h;
    h_cmp_sq.v[dst_idx]  = cmp_sq_h;
    h_refcmp.v[dst_idx]  = refcmp_h;
}

/* PASS 1: vertical 11-tap on the 5 intermediates → 5 final
 * stats; then per-pixel SSIM combine + per-WG partial sum. The
 * grid is sized w_final × h_final. */
void main_vert_combine(uint x, uint y) {
    float my_ssim = 0.0;
    if (x < pc.w_final && y < pc.h_final) {
        float ref_mu = 0.0;
        float cmp_mu = 0.0;
        float ref_sq = 0.0;
        float cmp_sq = 0.0;
        float refcmp = 0.0;

        for (int v = 0; v < K; v++) {
            uint src_y = y + uint(v);
            uint src_idx = src_y * pc.w_horiz + x;
            float w = G[v];
            ref_mu += w * h_ref_mu.v[src_idx];
            cmp_mu += w * h_cmp_mu.v[src_idx];
            ref_sq += w * h_ref_sq.v[src_idx];
            cmp_sq += w * h_cmp_sq.v[src_idx];
            refcmp += w * h_refcmp.v[src_idx];
        }

        /* ssim_variance: σ²_x = E[x²] - μ_x²; σ_xy = E[xy] - μ_xμ_y */
        float ref_var = ref_sq - ref_mu * ref_mu;
        float cmp_var = cmp_sq - cmp_mu * cmp_mu;
        float covar   = refcmp - ref_mu * cmp_mu;
        float mu_xy   = ref_mu * cmp_mu;
        float num     = (2.0 * mu_xy + pc.c1) * (2.0 * covar + pc.c2);
        float den     = (ref_mu * ref_mu + cmp_mu * cmp_mu + pc.c1) *
                        (ref_var + cmp_var + pc.c2);
        my_ssim       = num / den;
    }

    /* Per-WG sum reduction: subgroup → shared[] → one float per WG. */
    float sg_sum = subgroupAdd(my_ssim);
    if (subgroupElect()) {
        s_partials[gl_SubgroupID] = sg_sum;
    }
    barrier();

    if (gl_LocalInvocationIndex == 0u) {
        float wg_total = 0.0;
        for (uint i = 0u; i < gl_NumSubgroups; ++i) {
            wg_total += s_partials[i];
        }
        uint wg_idx = gl_WorkGroupID.y * pc.num_workgroups_x + gl_WorkGroupID.x;
        partials_out.v[wg_idx] = wg_total;
    }
}

void main() {
    uint gx = gl_GlobalInvocationID.x;
    uint gy = gl_GlobalInvocationID.y;
    if (PASS == 0) {
        main_horiz(gx, gy);
    } else {
        main_vert_combine(gx, gy);
    }
}
