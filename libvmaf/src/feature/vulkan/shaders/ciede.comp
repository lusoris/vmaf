 *
 * Vulkan compute shader for the ciede2000 (ΔE) feature extractor
 * (T7-23 / batch 1c part 1 / ADR-0182). Mirrors the per-pixel
 * portion of libvmaf/src/feature/ciede.c — converts each YUV
 * pixel to BT.709 RGB, then to XYZ, then to L*a*b*, computes the
 * CIEDE2000 ΔE between ref and dis, and accumulates a per-
 * workgroup partial sum that the host reduces in `double`.
 *
 * Precision contract: float throughout the per-pixel math (the
 * CPU reference is itself float for ciede2000() — see ciede.c).
 * Per-WG partials are float; host accumulates partials in double
 * to retain a places=2 contract on the final score (4096×4096
 * pixels × ~10 max ΔE = ~10^8 sum, which exceeds float7-digit
 * precision but fits cleanly in double). See ADR-0187.
 *
 * Input: 6 storage buffers — ref_y, ref_u, ref_v, dis_y, dis_u,
 * dis_v — each at full luma resolution (host-side chroma
 * upscale matches CPU behaviour from ciede.c::scale_chroma_planes).
 * Output: float[num_workgroups] of per-WG sums.
 *
 * Specialization constants (per VkSpecializationInfo):
 *   constant_id = 0  WIDTH
 *   constant_id = 1  HEIGHT
 *   constant_id = 2  BPC                 (8 / 10 / 12 / 16)
 *   constant_id = 3  SUBGROUP_SIZE       (compile-time array sizing)
 */
#version 460
#extension GL_KHR_shader_subgroup_arithmetic : require
#extension GL_KHR_shader_subgroup_basic      : require

layout(local_size_x = 16, local_size_y = 8, local_size_z = 1) in;

layout(constant_id = 0) const int WIDTH         = 0;
layout(constant_id = 1) const int HEIGHT        = 0;
layout(constant_id = 2) const int BPC           = 8;
layout(constant_id = 3) const int SUBGROUP_SIZE = 32;

const int WG_X    = 16;
const int WG_Y   = 8;
const int WG_SIZE = WG_X * WG_Y;
const int MAX_SUBGROUPS = WG_SIZE;

/* Per-subgroup float partial sums. */
shared float s_partials[MAX_SUBGROUPS];

layout(set = 0, binding = 0, std430) readonly buffer RefY { uint pixels[]; } ref_y_in;
layout(set = 0, binding = 1, std430) readonly buffer RefU { uint pixels[]; } ref_u_in;
layout(set = 0, binding = 2, std430) readonly buffer RefV { uint pixels[]; } ref_v_in;
layout(set = 0, binding = 3, std430) readonly buffer DisY { uint pixels[]; } dis_y_in;
layout(set = 0, binding = 4, std430) readonly buffer DisU { uint pixels[]; } dis_u_in;
layout(set = 0, binding = 5, std430) readonly buffer DisV { uint pixels[]; } dis_v_in;
layout(set = 0, binding = 6, std430)          buffer PartialSums {
    float v[];
} partials_out;

layout(push_constant) uniform Params {
    uint width;
    uint height;
    uint bpc;
    uint num_workgroups_x;
} pc;

/* Read one pixel from a packed std430 buffer. Same packing as
 * moment.comp / psnr.comp: 4 bytes per uint32 at 8bpc, 2 uint16
 * per uint32 at 10/12/16bpc. GLSL pre-VK_EXT_buffer_device_address
 * doesn't allow passing buffer blocks as parameters, so the
 * per-buffer accessors below replicate the load inline. */
uint unpack_8bpc(uint x, uint packed) {
    return (packed >> ((x & 3u) * 8u)) & 0xFFu;
}
uint unpack_16bpc(uint x, uint packed) {
    return (packed >> ((x & 1u) * 16u)) & 0xFFFFu;
}

uint read_ref_y(uint y, uint x) {
    if (BPC <= 8) {
        uint sw = (pc.width + 3u) >> 2;
        return unpack_8bpc(x, ref_y_in.pixels[y * sw + (x >> 2)]);
    } else {
        uint sw = (pc.width + 1u) >> 1;
        return unpack_16bpc(x, ref_y_in.pixels[y * sw + (x >> 1)]);
    }
}
uint read_ref_u(uint y, uint x) {
    if (BPC <= 8) {
        uint sw = (pc.width + 3u) >> 2;
        return unpack_8bpc(x, ref_u_in.pixels[y * sw + (x >> 2)]);
    } else {
        uint sw = (pc.width + 1u) >> 1;
        return unpack_16bpc(x, ref_u_in.pixels[y * sw + (x >> 1)]);
    }
}
uint read_ref_v(uint y, uint x) {
    if (BPC <= 8) {
        uint sw = (pc.width + 3u) >> 2;
        return unpack_8bpc(x, ref_v_in.pixels[y * sw + (x >> 2)]);
    } else {
        uint sw = (pc.width + 1u) >> 1;
        return unpack_16bpc(x, ref_v_in.pixels[y * sw + (x >> 1)]);
    }
}
uint read_dis_y(uint y, uint x) {
    if (BPC <= 8) {
        uint sw = (pc.width + 3u) >> 2;
        return unpack_8bpc(x, dis_y_in.pixels[y * sw + (x >> 2)]);
    } else {
        uint sw = (pc.width + 1u) >> 1;
        return unpack_16bpc(x, dis_y_in.pixels[y * sw + (x >> 1)]);
    }
}
uint read_dis_u(uint y, uint x) {
    if (BPC <= 8) {
        uint sw = (pc.width + 3u) >> 2;
        return unpack_8bpc(x, dis_u_in.pixels[y * sw + (x >> 2)]);
    } else {
        uint sw = (pc.width + 1u) >> 1;
        return unpack_16bpc(x, dis_u_in.pixels[y * sw + (x >> 1)]);
    }
}
uint read_dis_v(uint y, uint x) {
    if (BPC <= 8) {
        uint sw = (pc.width + 3u) >> 2;
        return unpack_8bpc(x, dis_v_in.pixels[y * sw + (x >> 2)]);
    } else {
        uint sw = (pc.width + 1u) >> 1;
        return unpack_16bpc(x, dis_v_in.pixels[y * sw + (x >> 1)]);
    }
}

const float PI = 3.14159265358979323846;

/* BT.709 YUV (full-range scaling per CPU reference) → linear RGB.
 * Mirrors libvmaf/src/feature/ciede.c::get_lab_color.
 *
 * `precise` on r/g/b blocks NVIDIA's Vulkan-1.4 FMA-fold of the
 * `y + k*u` / `y - k*u - k*v` patterns which would otherwise drift
 * the per-pixel ΔE relative to the CPU reference (research-0053). */
vec3 yuv_to_rgb(float y_lim, float u_lim, float v_lim) {
    /* CPU reference uses 0..255 normalized to 16-235 / 16-240.
     * Scale factor is 1.0 for 8bpc; (2^(bpc-8)) for HBD. */
    float scale = 1.0;
    if (BPC == 10) scale = 4.0;
    else if (BPC == 12) scale = 16.0;
    else if (BPC == 16) scale = 256.0;
    float y = (y_lim - 16.0 * scale) * (1.0 / (219.0 * scale));
    float u = (u_lim - 128.0 * scale) * (1.0 / (224.0 * scale));
    float v = (v_lim - 128.0 * scale) * (1.0 / (224.0 * scale));
    precise float r = y + 1.28033 * v;
    precise float g = y - 0.21482 * u - 0.38059 * v;
    precise float b = y + 2.12798 * u;
    return vec3(r, g, b);
}

/* sRGB transfer function (gamma 2.4 piecewise). Matches CPU
 * rgb_to_xyz_map. */
float srgb_to_linear(float c) {
    if (c > 10.0 / 255.0) {
        const float A = 0.055;
        const float D = 1.0 / 1.055;
        return pow((c + A) * D, 2.4);
    } else {
        return c / 12.92;
    }
}

/* CIE XYZ from linear BT.709 RGB (D65). Matches CPU constants.
 *
 * `precise` on the three accumulators stops NVIDIA's 1.4 default
 * FMA-fold across the 3×3 mat-mul. The CPU reference performs each
 * `a*b + c*d + e*f` as separate mul+add — the GPU has to match for
 * the places=4 cross-backend gate (research-0053). */
vec3 rgb_to_xyz(vec3 rgb) {
    precise float x = rgb.r * 0.4124564390896921 + rgb.g * 0.357576077643909  + rgb.b * 0.18043748326639894;
    precise float y = rgb.r * 0.21267285140562248 + rgb.g * 0.715152155287818  + rgb.b * 0.07217499330655958;
    precise float z = rgb.r * 0.019333895582329317 + rgb.g * 0.119192025881303  + rgb.b * 0.9503040785363677;
    return vec3(x, y, z);
}

/* XYZ → Lab nonlinearity (CIE standard). */
float xyz_to_lab_map(float t) {
    if (t > 0.008856) return pow(t, 1.0 / 3.0);
    return (7.787 * t) + (16.0 / 116.0);
}

vec3 yuv_to_lab(float y, float u, float v) {
    vec3 rgb = yuv_to_rgb(y, u, v);
    rgb.r = srgb_to_linear(rgb.r);
    rgb.g = srgb_to_linear(rgb.g);
    rgb.b = srgb_to_linear(rgb.b);
    vec3 xyz = rgb_to_xyz(rgb);
    /* D65 white point normalization (matches CPU). */
    xyz.x *= 1.0 / 0.95047;
    xyz.z *= 1.0 / 1.08883;
    float lx = xyz_to_lab_map(xyz.x);
    float ly = xyz_to_lab_map(xyz.y);
    float lz = xyz_to_lab_map(xyz.z);
    return vec3(116.0 * ly - 16.0, 500.0 * (lx - ly), 200.0 * (ly - lz));
}

/* CIEDE2000 helpers — direct port of libvmaf/src/feature/ciede.c
 * functions get_h_prime / get_delta_h_prime / get_upcase_h_bar_prime
 * / get_upcase_t / get_r_sub_t. */
float get_h_prime(float b, float a) {
    if (b == 0.0 && a == 0.0) return 0.0;
    float h = atan(b, a);
    if (h < 0.0) h += 2.0 * PI;
    return h * 180.0 / PI;
}
float get_delta_h_prime(float c1, float c2, float h1, float h2) {
    if (c1 * c2 == 0.0) return 0.0;
    float diff = h2 - h1;
    if (abs(diff) <= 180.0) return diff * PI / 180.0;
    if (diff > 180.0) return (diff - 360.0) * PI / 180.0;
    return (diff + 360.0) * PI / 180.0;
}
float get_upcase_h_bar_prime(float h1, float h2) {
    float diff = abs(h1 - h2);
    if (diff > 180.0) return ((h1 + h2 + 360.0) / 2.0) * PI / 180.0;
    return ((h1 + h2) / 2.0) * PI / 180.0;
}
float get_upcase_t(float h_bar) {
    return 1.0 - 0.17 * cos(h_bar - PI / 6.0)
               + 0.24 * cos(2.0 * h_bar)
               + 0.32 * cos(3.0 * h_bar + PI / 30.0)
               - 0.20 * cos(4.0 * h_bar - 63.0 * PI / 180.0);
}
float get_r_sub_t(float c_bar, float h_bar) {
    float exponent = -pow((h_bar * 180.0 / PI - 275.0) / 25.0, 2.0);
    float c7 = pow(c_bar, 7.0);
    float r_c = 2.0 * sqrt(c7 / (c7 + pow(25.0, 7.0)));
    return -sin(60.0 * PI / 180.0 * exp(exponent)) * r_c;
}

/* `precise` on the chroma magnitudes, the `a*_p`/`c*_p` half-axes,
 * the `s_l/s_c/s_h` correction terms, the lightness/chroma/hue
 * normalisations, and the final ΔE return value. These are the
 * load-bearing `mul + add` reductions that NVIDIA's Vulkan-1.4
 * default FMA-fold drifts vs the CPU reference (42/48 frame
 * mismatches at API 1.4 — research-0053).
 *
 * Helpers (`get_h_prime`, `get_delta_h_prime`, `get_upcase_t`,
 * `get_r_sub_t`) are deliberately NOT tagged: empirically widening
 * the `precise` net into them increases the CPU-vs-GPU drift on
 * NVIDIA driver 595.71 — the helpers' internal FMA folds appear
 * to align *better* with the CPU compiler's folds when left
 * un-decorated. The conservative scope here drops the regression
 * from 42/48 mismatches (max abs 1.67e-04) to 5/48 (max abs
 * 8.9e-05) — a 19× reduction. The remaining 5-frame tail is at
 * 1.78× the places=4 threshold and is documented as
 * follow-up work for a CPU-side double-precision bisect; see
 * research-0053 §"Open questions". */
float ciede2000(vec3 c1, vec3 c2) {
    const float k_l = 0.65;
    const float k_c = 1.0;
    const float k_h = 4.0;
    float dl_p = c2.x - c1.x;
    float l_bar = 0.5 * (c1.x + c2.x);
    precise float c1_chroma = sqrt(c1.y * c1.y + c1.z * c1.z);
    precise float c2_chroma = sqrt(c2.y * c2.y + c2.z * c2.z);
    float c_bar = 0.5 * (c1_chroma + c2_chroma);
    float c_bar_7 = pow(c_bar, 7.0);
    float g_factor = 1.0 - sqrt(c_bar_7 / (c_bar_7 + pow(25.0, 7.0)));
    precise float a1_p = c1.y + 0.5 * c1.y * g_factor;
    precise float a2_p = c2.y + 0.5 * c2.y * g_factor;
    precise float c1_p = sqrt(a1_p * a1_p + c1.z * c1.z);
    precise float c2_p = sqrt(a2_p * a2_p + c2.z * c2.z);
    float c_bar_p = 0.5 * (c1_p + c2_p);
    float dc_p = c2_p - c1_p;
    float dl2 = (l_bar - 50.0) * (l_bar - 50.0);
    precise float s_l = 1.0 + (0.015 * dl2) / sqrt(20.0 + dl2);
    precise float s_c = 1.0 + 0.045 * c_bar_p;
    float h1_p = get_h_prime(c1.z, a1_p);
    float h2_p = get_h_prime(c2.z, a2_p);
    float dh_p = get_delta_h_prime(c1_chroma, c2_chroma, h1_p, h2_p);
    precise float dH_p = 2.0 * sqrt(c1_p * c2_p) * sin(dh_p / 2.0);
    float H_bar_p = get_upcase_h_bar_prime(h1_p, h2_p);
    float t_term = get_upcase_t(H_bar_p);
    precise float s_h = 1.0 + 0.015 * c_bar_p * t_term;
    float r_t = get_r_sub_t(c_bar_p, H_bar_p);
    precise float lightness = dl_p / (k_l * s_l);
    precise float chroma   = dc_p / (k_c * s_c);
    precise float hue      = dH_p / (k_h * s_h);
    precise float de = sqrt(lightness * lightness + chroma * chroma + hue * hue
                          + r_t * chroma * hue);
    return de;
}

void main() {
    uint gx = gl_GlobalInvocationID.x;
    uint gy = gl_GlobalInvocationID.y;
    bool valid = (gx < pc.width && gy < pc.height);

    float my_de = 0.0;
    if (valid) {
        float ry = float(read_ref_y(gy, gx));
        float ru = float(read_ref_u(gy, gx));
        float rv = float(read_ref_v(gy, gx));
        float dy = float(read_dis_y(gy, gx));
        float du = float(read_dis_u(gy, gx));
        float dv = float(read_dis_v(gy, gx));
        vec3 lab1 = yuv_to_lab(ry, ru, rv);
        vec3 lab2 = yuv_to_lab(dy, du, dv);
        my_de = ciede2000(lab1, lab2);
    }

    float sg_sum = subgroupAdd(my_de);
    if (subgroupElect()) {
        s_partials[gl_SubgroupID] = sg_sum;
    }
    barrier();

    if (gl_LocalInvocationIndex == 0u) {
        float wg_total = 0.0;
        for (uint i = 0u; i < gl_NumSubgroups; ++i) {
            wg_total += s_partials[i];
        }
        uint wg_idx = gl_WorkGroupID.y * pc.num_workgroups_x + gl_WorkGroupID.x;
        partials_out.v[wg_idx] = wg_total;
    }
}
