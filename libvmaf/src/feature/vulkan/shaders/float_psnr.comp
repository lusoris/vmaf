 *
 * Vulkan compute shader for the float_psnr feature extractor.
 *
 * CPU reference: libvmaf/src/feature/float_psnr.c
 *
 * Algorithm (must match CPU):
 *   1. Convert raw pixel to float: `val = raw / scaler` (offset=0;
 *      scaler is 1 for bpc=8, 4/16/256 for bpc=10/12/16). Domain is
 *      [0, peak] where peak = 255.0 / 255.75 / 255.9375 / 255.99609375.
 *   2. noise += (ref - dis) * (ref - dis)   (per-pixel float).
 *   3. host: noise /= (w * h)
 *           score = MIN(10 * log10(peak² / max(noise, 1e-10)), psnr_max)
 *
 * Single dispatch; per-WG float partials reduced on host in `double`.
 *
 * Specialization constants:
 *   constant_id = 0  WIDTH
 *   constant_id = 1  HEIGHT
 *   constant_id = 2  BPC            8 / 10 / 12 / 16
 *   constant_id = 3  SUBGROUP_SIZE  32 (default)
 *
 * Bindings:
 *   binding 0: ref input plane (uint8 / uint16 packed in uint32)
 *   binding 1: dis input plane
 *   binding 2: per-WG float partials (one float per WG)
 *
 * Precision contract per ADR-0192: places=3 (float diff² + float
 * reductions + log10 final transform). The integer twin (`psnr_y`)
 * already ships on all GPU backends with `int64` accumulators; the
 * float kernel here is for callers that explicitly want the
 * float_psnr extractor (Netflix-style float models, cross-backend
 * float-vs-int sanity).
 */

#version 460
#extension GL_KHR_shader_subgroup_arithmetic : require
#extension GL_KHR_shader_subgroup_basic      : require

layout(local_size_x = 16, local_size_y = 16, local_size_z = 1) in;

layout(constant_id = 0) const int WIDTH         = 0;
layout(constant_id = 1) const int HEIGHT        = 0;
layout(constant_id = 2) const int BPC           = 8;
layout(constant_id = 3) const int SUBGROUP_SIZE = 32;

const int WG_X = 16;
const int WG_Y = 16;
const int WG_SIZE = WG_X * WG_Y;
const int MAX_SUBGROUPS = WG_SIZE;

shared float s_partials[MAX_SUBGROUPS];

layout(set = 0, binding = 0, std430) readonly buffer Ref { uint pixels[]; } ref_in;
layout(set = 0, binding = 1, std430) readonly buffer Dis { uint pixels[]; } dis_in;
layout(set = 0, binding = 2, std430)          buffer Out { float v[];    } out_partials;

layout(push_constant) uniform Params {
    uint width;
    uint height;
    uint bpc;
    uint num_workgroups_x;
} pc;

float read_ref_px(int y, int x, float inv_scaler) {
    if (BPC <= 8) {
        uint stride_words = (uint(pc.width) + 3u) >> 2;
        uint word = ref_in.pixels[uint(y) * stride_words + (uint(x) >> 2)];
        uint v = (word >> ((uint(x) & 3u) * 8u)) & 0xFFu;
        return float(v);
    } else {
        uint stride_words = (uint(pc.width) + 1u) >> 1;
        uint word = ref_in.pixels[uint(y) * stride_words + (uint(x) >> 1)];
        uint v = (word >> ((uint(x) & 1u) * 16u)) & 0xFFFFu;
        return float(v) * inv_scaler;
    }
}

float read_dis_px(int y, int x, float inv_scaler) {
    if (BPC <= 8) {
        uint stride_words = (uint(pc.width) + 3u) >> 2;
        uint word = dis_in.pixels[uint(y) * stride_words + (uint(x) >> 2)];
        uint v = (word >> ((uint(x) & 3u) * 8u)) & 0xFFu;
        return float(v);
    } else {
        uint stride_words = (uint(pc.width) + 1u) >> 1;
        uint word = dis_in.pixels[uint(y) * stride_words + (uint(x) >> 1)];
        uint v = (word >> ((uint(x) & 1u) * 16u)) & 0xFFFFu;
        return float(v) * inv_scaler;
    }
}

void main() {
    int gx = int(gl_GlobalInvocationID.x);
    int gy = int(gl_GlobalInvocationID.y);
    uint lid = uint(gl_LocalInvocationID.y * WG_X + gl_LocalInvocationID.x);
    bool valid = (gx < int(pc.width) && gy < int(pc.height));

    /* picture_copy scaler: 1 for bpc<=8, 4/16/256 for bpc=10/12/16. */
    float scaler = 1.0;
    if (BPC == 10) scaler = 4.0;
    else if (BPC == 12) scaler = 16.0;
    else if (BPC == 16) scaler = 256.0;
    float inv_scaler = 1.0 / scaler;

    float my_noise = 0.0;
    if (valid) {
        float r = read_ref_px(gy, gx, inv_scaler);
        float d = read_dis_px(gy, gx, inv_scaler);
        float diff = r - d;
        my_noise = diff * diff;
    }

    /* Subgroup + cross-subgroup float reduction. */
    float sg_sum = subgroupAdd(my_noise);
    uint sg_id = gl_SubgroupID;
    uint n_subgrps = gl_NumSubgroups;
    if (subgroupElect()) {
        s_partials[sg_id] = sg_sum;
    }
    barrier();

    if (lid == 0u) {
        float total = 0.0;
        for (uint s = 0u; s < n_subgrps; s++) {
            total += s_partials[s];
        }
        uint wg_idx = gl_WorkGroupID.y * pc.num_workgroups_x + gl_WorkGroupID.x;
        out_partials.v[wg_idx] = total;
    }
}
