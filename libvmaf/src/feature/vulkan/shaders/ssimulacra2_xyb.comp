 *
 * Vulkan compute shader for the ssimulacra2 linear-RGB → XYB
 * conversion (T7-23 / GPU long-tail batch 3 part 7 / ADR-0200).
 * Mirrors libvmaf/src/feature/ssimulacra2.c::linear_rgb_to_xyb
 * line-for-line, including the deterministic in-shader cube-root
 * (vmaf_ss2_cbrtf bit-trick port) and the "MakePositiveXYB"
 * rescale (B = (B - Y) + 0.55, X = 14X + 0.42, Y += 0.01).
 *
 * Three planar float input buffers (R, G, B) → three planar
 * float output buffers (X, Y, B). All buffers are tightly
 * packed at the per-scale (W × H) of the current pyramid level.
 *
 * Specialization constants:
 *   constant_id = 0  WIDTH   (per-scale W; informational)
 *   constant_id = 1  HEIGHT  (per-scale H; informational)
 */
#version 460

layout(local_size_x = 16, local_size_y = 8, local_size_z = 1) in;

layout(constant_id = 0) const int WIDTH  = 0;
layout(constant_id = 1) const int HEIGHT = 0;

/* Opsin mixing matrix and bias — bit-identical to ssimulacra2.c. */
const float kM00 = 0.30;
const float kM02 = 0.078;
const float kM10 = 0.23;
const float kM12 = 0.078;
const float kM20 = 0.24342268924547819;
const float kM21 = 0.20476744424496821;
const float kOpsinBias = 0.0037930732552754493;

layout(set = 0, binding = 0, std430) readonly buffer RIn { float v[]; } r_in;
layout(set = 0, binding = 1, std430) readonly buffer GIn { float v[]; } g_in;
layout(set = 0, binding = 2, std430) readonly buffer BIn { float v[]; } b_in;
layout(set = 0, binding = 3, std430)          buffer XOut { float v[]; } x_out;
layout(set = 0, binding = 4, std430)          buffer YOut { float v[]; } y_out;
layout(set = 0, binding = 5, std430)          buffer BOut { float v[]; } b_out;

layout(push_constant) uniform Params {
    uint width;
    uint height;
} pc;

/* Deterministic cube root (port of vmaf_ss2_cbrtf in
 * libvmaf/src/feature/ssimulacra2_math.h). Bit-trick initial
 * estimate (i/3 + 0x2a5137a0) followed by 2 Newton iterations
 * of f(y) = y^3 - x. Negative inputs return 0.
 *
 * `precise` on every intermediate prevents the SPIR-V/driver
 * compiler from FMA-contracting `2*y + x/(y*y)` (the CPU port
 * compiles to a separate FMUL/FDIV/FADD pair under -O2 without
 * -ffast-math, so the GPU must match). Without `precise` lavapipe
 * (and most hw drivers) emit `OpExtInst Fma` and lose ~3 ULP per
 * iteration, which compounds across the 6-scale pyramid + IIR
 * blur + SSIM-stats reductions to a 1.5e-2 pooled-score drift. */
precise float ss2_cbrtf(float x) {
    if (x <= 0.0)
        return 0.0;
    uint bits = floatBitsToUint(x);
    bits = bits / 3u + 0x2a5137a0u;
    precise float y = uintBitsToFloat(bits);
    /* Explicit per-op staging blocks `a + b*c` → `fma(b, c, a)`
     * fusion that lavapipe and several Mesa back-ends still emit
     * even with `precise` on the LHS. Mirrors the CPU port:
     *   y = (2.0f * y + x / (y * y)) * (1.0f / 3.0f);
     * which under -O2 (no -mfma) compiles to discrete mul / div /
     * mul / add / mul ops. */
    precise float ysq = y * y;
    precise float quot = x / ysq;
    precise float two_y = 2.0 * y;
    precise float sum_iter = two_y + quot;
    y = sum_iter * (1.0 / 3.0);
    ysq = y * y;
    quot = x / ysq;
    two_y = 2.0 * y;
    sum_iter = two_y + quot;
    y = sum_iter * (1.0 / 3.0);
    return y;
}

/* cbrt of the opsin bias: hoisted out of the per-pixel loop (the
 * CPU reference computes this once outside `linear_rgb_to_xyb`).
 * Using a `precise` global initialiser would not be guaranteed by
 * GLSL, so we compute it inside main() once. */

void main() {
    uint x = gl_GlobalInvocationID.x;
    uint y = gl_GlobalInvocationID.y;
    if (x >= pc.width || y >= pc.height)
        return;

    uint idx = y * pc.width + x;

    precise float r = r_in.v[idx];
    precise float g = g_in.v[idx];
    precise float b = b_in.v[idx];

    /* Constants inlined from CPU `linear_rgb_to_xyb`. */
    precise float m01 = 1.0 - kM00 - kM02;
    precise float m11 = 1.0 - kM10 - kM12;
    precise float m22 = 1.0 - kM20 - kM21;

    /* Matmul + bias: bracket exactly as the CPU C source so the
     * SPIR-V optimizer cannot reassociate. CPU expression order is
     *   l = kM00*r + m01*g + kM02*b + kOpsinBias.
     * Stage every multiply into its own precise temp so the GLSL
     * compiler / driver back-end never sees `a + b*c` and cannot
     * emit `OpExtInst Fma`. (The `precise` qualifier alone is
     * spec-defined to block FMA contraction, but lavapipe and
     * several Mesa back-ends still emit FMA on `a + b*c` even
     * with `precise` on the LHS — splitting the multiply into a
     * named `precise` temp closes that loophole.) */
    precise float l_r = kM00 * r;
    precise float l_g = m01  * g;
    precise float l_b = kM02 * b;
    precise float l_rg = l_r + l_g;
    precise float l_rgb = l_rg + l_b;
    precise float l = l_rgb + kOpsinBias;

    precise float m_r = kM10 * r;
    precise float m_g = m11  * g;
    precise float m_b = kM12 * b;
    precise float m_rg = m_r + m_g;
    precise float m_rgb = m_rg + m_b;
    precise float m = m_rgb + kOpsinBias;

    precise float s_r = kM20 * r;
    precise float s_g = kM21 * g;
    precise float s_b = m22  * b;
    precise float s_rg = s_r + s_g;
    precise float s_rgb = s_rg + s_b;
    precise float s = s_rgb + kOpsinBias;

    if (l < 0.0) l = 0.0;
    if (m < 0.0) m = 0.0;
    if (s < 0.0) s = 0.0;

    precise float cbrt_bias = ss2_cbrtf(kOpsinBias);
    precise float L = ss2_cbrtf(l) - cbrt_bias;
    precise float M = ss2_cbrtf(m) - cbrt_bias;
    precise float S = ss2_cbrtf(s) - cbrt_bias;

    precise float X = 0.5 * (L - M);
    precise float Y = 0.5 * (L + M);
    precise float B = S;

    /* MakePositiveXYB: B uses Y BEFORE Y is offset (matches libjxl). */
    B = (B - Y) + 0.55;
    X = X * 14.0 + 0.42;
    Y = Y + 0.01;

    x_out.v[idx] = X;
    y_out.v[idx] = Y;
    b_out.v[idx] = B;
}
