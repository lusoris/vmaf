"""Console shim — delegates to :func:`vmaftune.cli.main`.

Useful when the package is run from a checkout without a ``pip install``.
"""

from __future__ import annotations

import os
import sys

# Make src/ importable when invoked from the repo without pip install.
_HERE = os.path.dirname(os.path.abspath(__file__))
sys.path.insert(0, os.path.join(_HERE, "src"))

from vmaftune.cli import main  # noqa: E402

if __name__ == "__main__":
    raise SystemExit(main())
