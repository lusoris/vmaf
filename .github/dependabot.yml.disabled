# Disabled 2026-05-09 — superseded by Renovate (renovate.json + .github/workflows/renovate.yml).
# See ADR-0363. Re-enable by renaming back to dependabot.yml; in that case ALSO disable Renovate
# (remove or rename .github/workflows/renovate.yml) to avoid duplicate dependency-update PRs.

version: 2
updates:
  - package-ecosystem: "github-actions"
    directory: "/"
    schedule:
      interval: "weekly"
      day: "monday"
    open-pull-requests-limit: 5
    labels: ["ci", "dependencies"]
    groups:
      minor-and-patch:
        update-types: ["minor", "patch"]

  - package-ecosystem: "pip"
    directory: "/python"
    schedule:
      interval: "weekly"
    open-pull-requests-limit: 5
    labels: ["dependencies", "python"]
    ignore:
      - dependency-name: "numpy"
        update-types: ["version-update:semver-major"]

  - package-ecosystem: "pip"
    directory: "/ai"
    schedule:
      interval: "weekly"
    open-pull-requests-limit: 5
    labels: ["dependencies", "python", "tiny-ai"]

  - package-ecosystem: "pip"
    directory: "/mcp-server/vmaf-mcp"
    schedule:
      interval: "weekly"
    open-pull-requests-limit: 3
    labels: ["dependencies", "python", "mcp"]

  - package-ecosystem: "pip"
    directory: "/dev-llm"
    schedule:
      interval: "weekly"
    open-pull-requests-limit: 3
    labels: ["dependencies", "python", "dev-llm"]

  - package-ecosystem: "docker"
    directory: "/"
    schedule:
      interval: "monthly"
    open-pull-requests-limit: 3
    labels: ["dependencies", "docker"]

  - package-ecosystem: "docker"
    directory: "/docker"
    schedule:
      interval: "monthly"
    open-pull-requests-limit: 3
    labels: ["dependencies", "docker"]
