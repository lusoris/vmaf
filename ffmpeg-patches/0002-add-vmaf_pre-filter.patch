+
+/**
+ * @file
+ * vmaf_pre: learned pre-processing filter backed by libvmaf's DNN runtime.
+ * Loads a residual-CNN ONNX model via the standalone vmaf_dnn_session_*
+ * API and applies it to the luma plane. 8-bit (yuv420p / 422p / 444p,
+ * gray8) dispatches to vmaf_dnn_session_run_luma8; 10/12-bit dispatches
+ * to vmaf_dnn_session_run_plane16 (ADR-0170 / T6-4). When chroma=1 is
+ * set, the same session is re-run on the U and V planes at their own
+ * dimensions; otherwise chroma passes through untouched.
+ */
+
+#include <libvmaf/dnn.h>
+
+#include "libavutil/avstring.h"
+#include "libavutil/imgutils.h"
+#include "libavutil/mem.h"
+#include "libavutil/opt.h"
+#include "libavutil/pixdesc.h"
+
+#include "avfilter.h"
+#include "filters.h"
+#include "formats.h"
+#include "video.h"
+
+typedef struct VmafPreContext {
+    const AVClass *class;
+    char *model_path;
+    char *device;
+    int   threads;
+    int   chroma;   /* apply the filter to U/V as well as Y */
+    VmafDnnSession *session;
+} VmafPreContext;
+
+#define OFFSET(x) offsetof(VmafPreContext, x)
+#define FLAGS AV_OPT_FLAG_FILTERING_PARAM | AV_OPT_FLAG_VIDEO_PARAM
+
+static const AVOption vmaf_pre_options[] = {
+    { "model",   "Path to ONNX learned-filter model.",    OFFSET(model_path),
+        AV_OPT_TYPE_STRING, {.str=NULL},   0, 0,       FLAGS },
+    { "device",  "auto | cpu | cuda | openvino | openvino-npu | openvino-cpu | openvino-gpu | coreml | coreml-ane | coreml-gpu | coreml-cpu | rocm.", OFFSET(device),
+        AV_OPT_TYPE_STRING, {.str="auto"}, 0, 0,       FLAGS },
+    { "threads", "CPU EP intra-op threads.",              OFFSET(threads),
+        AV_OPT_TYPE_INT,    {.i64=0},      0, INT_MAX, FLAGS },
+    { "chroma",  "Also filter U/V planes (0/1; default 0 = luma-only).",
+        OFFSET(chroma),
+        AV_OPT_TYPE_BOOL,   {.i64=0},      0, 1,       FLAGS },
+    { NULL }
+};
+
+AVFILTER_DEFINE_CLASS(vmaf_pre);
+
+static int parse_device(const char *s, VmafDnnDevice *out)
+{
+    if (!s || !*s || !av_strcasecmp(s, "auto"))     { *out = VMAF_DNN_DEVICE_AUTO;         return 0; }
+    if (!av_strcasecmp(s, "cpu"))                   { *out = VMAF_DNN_DEVICE_CPU;           return 0; }
+    if (!av_strcasecmp(s, "cuda"))                  { *out = VMAF_DNN_DEVICE_CUDA;          return 0; }
+    if (!av_strcasecmp(s, "openvino"))              { *out = VMAF_DNN_DEVICE_OPENVINO;      return 0; }
+    if (!av_strcasecmp(s, "openvino-npu"))          { *out = VMAF_DNN_DEVICE_OPENVINO_NPU;  return 0; }
+    if (!av_strcasecmp(s, "openvino-cpu"))          { *out = VMAF_DNN_DEVICE_OPENVINO_CPU;  return 0; }
+    if (!av_strcasecmp(s, "openvino-gpu"))          { *out = VMAF_DNN_DEVICE_OPENVINO_GPU;  return 0; }
+    if (!av_strcasecmp(s, "coreml"))                { *out = VMAF_DNN_DEVICE_COREML;        return 0; }
+    if (!av_strcasecmp(s, "coreml-ane"))            { *out = VMAF_DNN_DEVICE_COREML_ANE;    return 0; }
+    if (!av_strcasecmp(s, "coreml-gpu"))            { *out = VMAF_DNN_DEVICE_COREML_GPU;    return 0; }
+    if (!av_strcasecmp(s, "coreml-cpu"))            { *out = VMAF_DNN_DEVICE_COREML_CPU;    return 0; }
+    if (!av_strcasecmp(s, "rocm"))                  { *out = VMAF_DNN_DEVICE_ROCM;          return 0; }
+    return AVERROR(EINVAL);
+}
+
+static av_cold int init(AVFilterContext *ctx)
+{
+    VmafPreContext *s = ctx->priv;
+    VmafDnnConfig  cfg = { 0 };
+    int err;
+
+    if (!s->model_path || !*s->model_path) {
+        av_log(ctx, AV_LOG_ERROR, "vmaf_pre: model= option is required.\n");
+        return AVERROR(EINVAL);
+    }
+    if (!vmaf_dnn_available()) {
+        av_log(ctx, AV_LOG_ERROR,
+               "vmaf_pre: libvmaf was built without --enable_dnn.\n");
+        return AVERROR(ENOSYS);
+    }
+
+    err = parse_device(s->device, &cfg.device);
+    if (err < 0) {
+        av_log(ctx, AV_LOG_ERROR,
+               "vmaf_pre: unknown device=%s.\n", s->device ? s->device : "");
+        return err;
+    }
+    cfg.threads = s->threads;
+
+    err = vmaf_dnn_session_open(&s->session, s->model_path, &cfg);
+    if (err < 0) {
+        av_log(ctx, AV_LOG_ERROR,
+               "vmaf_pre: vmaf_dnn_session_open(%s) failed: %d.\n",
+               s->model_path, err);
+        return AVERROR(EINVAL);
+    }
+    av_log(ctx, AV_LOG_INFO,
+           "vmaf_pre: loaded %s (device=%s threads=%d chroma=%d)\n",
+           s->model_path, s->device ? s->device : "auto",
+           s->threads, s->chroma);
+    return 0;
+}
+
+static av_cold void uninit(AVFilterContext *ctx)
+{
+    VmafPreContext *s = ctx->priv;
+    if (s->session) {
+        vmaf_dnn_session_close(s->session);
+        s->session = NULL;
+    }
+}
+
+/* Dispatch one plane through the DNN session, picking the luma8 or
+ * plane16 entrypoint by bit-depth. */
+static int run_plane(VmafPreContext *s, int bpc,
+                     const uint8_t *in, size_t in_linesize,
+                     uint8_t *out, size_t out_linesize,
+                     int w, int h)
+{
+    if (bpc == 8) {
+        return vmaf_dnn_session_run_luma8(s->session, in, in_linesize, w, h,
+                                          out, out_linesize);
+    }
+    if (bpc >= 9 && bpc <= 16) {
+        return vmaf_dnn_session_run_plane16(s->session,
+                                            (const uint16_t *)in, in_linesize,
+                                            w, h, bpc,
+                                            (uint16_t *)out, out_linesize);
+    }
+    return AVERROR(EINVAL);
+}
+
+static int filter_frame(AVFilterLink *inlink, AVFrame *in)
+{
+    AVFilterContext *ctx    = inlink->dst;
+    AVFilterLink    *outlink = ctx->outputs[0];
+    VmafPreContext  *s       = ctx->priv;
+    AVFrame *out;
+    const AVPixFmtDescriptor *d = av_pix_fmt_desc_get(in->format);
+    int err;
+
+    if (!d) {
+        av_frame_free(&in);
+        return AVERROR(EINVAL);
+    }
+    const int bpc = d->comp[0].depth; /* 8, 10, 12 for the formats we admit */
+
+    out = ff_get_video_buffer(outlink, in->width, in->height);
+    if (!out) {
+        av_frame_free(&in);
+        return AVERROR(ENOMEM);
+    }
+    av_frame_copy_props(out, in);
+
+    /* Luma plane — required for every accepted format. */
+    err = run_plane(s, bpc,
+                    in->data[0],  (size_t) in->linesize[0],
+                    out->data[0], (size_t) out->linesize[0],
+                    in->width, in->height);
+    if (err < 0) {
+        av_log(ctx, AV_LOG_ERROR,
+               "vmaf_pre: luma inference failed (%d) at bpc=%d.\n", err, bpc);
+        av_frame_free(&in);
+        av_frame_free(&out);
+        return AVERROR(EIO);
+    }
+
+    /* Chroma: filter when the caller opts in AND we have chroma planes;
+     * otherwise copy through. */
+    if (in->data[1] && out->data[1]) {
+        const int sub_w = d->log2_chroma_w;
+        const int sub_h = d->log2_chroma_h;
+        const int cw = AV_CEIL_RSHIFT(in->width,  sub_w);
+        const int ch = AV_CEIL_RSHIFT(in->height, sub_h);
+
+        if (s->chroma) {
+            err = run_plane(s, bpc,
+                            in->data[1],  (size_t) in->linesize[1],
+                            out->data[1], (size_t) out->linesize[1],
+                            cw, ch);
+            if (err < 0) {
+                av_log(ctx, AV_LOG_ERROR,
+                       "vmaf_pre: U inference failed (%d); chroma=off "
+                       "fallback by copy.\n", err);
+                av_image_copy_plane(out->data[1], out->linesize[1],
+                                    in->data[1],  in->linesize[1],
+                                    cw * (bpc > 8 ? 2 : 1), ch);
+            }
+            err = run_plane(s, bpc,
+                            in->data[2],  (size_t) in->linesize[2],
+                            out->data[2], (size_t) out->linesize[2],
+                            cw, ch);
+            if (err < 0) {
+                av_log(ctx, AV_LOG_ERROR,
+                       "vmaf_pre: V inference failed (%d); chroma=off "
+                       "fallback by copy.\n", err);
+                av_image_copy_plane(out->data[2], out->linesize[2],
+                                    in->data[2],  in->linesize[2],
+                                    cw * (bpc > 8 ? 2 : 1), ch);
+            }
+        } else {
+            av_image_copy_plane(out->data[1], out->linesize[1],
+                                in->data[1],  in->linesize[1],
+                                cw * (bpc > 8 ? 2 : 1), ch);
+            av_image_copy_plane(out->data[2], out->linesize[2],
+                                in->data[2],  in->linesize[2],
+                                cw * (bpc > 8 ? 2 : 1), ch);
+        }
+    }
+
+    av_frame_free(&in);
+    return ff_filter_frame(outlink, out);
+}
+
+static int query_formats(const AVFilterContext *ctx,
+                         AVFilterFormatsConfig **cfg_in,
+                         AVFilterFormatsConfig **cfg_out)
+{
+    static const enum AVPixelFormat pix_fmts[] = {
+        /* 8-bit */
+        AV_PIX_FMT_GRAY8,
+        AV_PIX_FMT_YUV420P, AV_PIX_FMT_YUV422P, AV_PIX_FMT_YUV444P,
+        /* 10-bit LE (ADR-0170) */
+        AV_PIX_FMT_GRAY10LE,
+        AV_PIX_FMT_YUV420P10LE, AV_PIX_FMT_YUV422P10LE, AV_PIX_FMT_YUV444P10LE,
+        /* 12-bit LE */
+        AV_PIX_FMT_GRAY12LE,
+        AV_PIX_FMT_YUV420P12LE, AV_PIX_FMT_YUV422P12LE, AV_PIX_FMT_YUV444P12LE,
+        AV_PIX_FMT_NONE,
+    };
+    return ff_set_common_formats_from_list2(ctx, cfg_in, cfg_out, pix_fmts);
+}
+
+static const AVFilterPad vmaf_pre_inputs[] = {
+    {
+        .name         = "default",
+        .type         = AVMEDIA_TYPE_VIDEO,
+        .filter_frame = filter_frame,
+    },
+};
+
+const FFFilter ff_vf_vmaf_pre = {
+    .p.name          = "vmaf_pre",
+    .p.description   = NULL_IF_CONFIG_SMALL("Learned pre-processing filter (Lusoris libvmaf tiny-AI C3)."),
+    .p.priv_class    = &vmaf_pre_class,
+    .priv_size       = sizeof(VmafPreContext),
+    .init            = init,
+    .uninit          = uninit,
+    FILTER_INPUTS(vmaf_pre_inputs),
+    FILTER_OUTPUTS(ff_video_default_filterpad),
+    FILTER_QUERY_FUNC2(query_formats),
+};
-- 
