diff --git a/libavfilter/vf_vmaf_pre.c b/libavfilter/vf_vmaf_pre.c
new file mode 100644
index 0000000..b339442
--- /dev/null
+++ b/libavfilter/vf_vmaf_pre.c
@@ -0,0 +1,264 @@
