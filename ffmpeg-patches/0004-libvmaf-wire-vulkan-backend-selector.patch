From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Lusoris <lusoris@pm.me>
Date: Fri, 24 Apr 2026 22:23:38 +0200
Subject: [PATCH] libvmaf: wire vulkan backend selector (vulkan_device option)

ADR-0175 / T5-1 — scaffold-only equivalent of the SYCL selector
in 0003. Adds a `vulkan_device` integer option (default -1 =
disabled). When set, the filter calls vmaf_vulkan_state_init +
vmaf_vulkan_import_state and lets libvmaf dispatch to the Vulkan
backend.

Until the Vulkan kernels land, the libvmaf side returns -ENOSYS
on every entry point — flipping `vulkan_device >= 0` will fail
init with a clear error rather than silently degrading. The
filter wiring lives in this patch so the rebase story stays one
patch ahead of the runtime.
---
 configure                |  1 +
 libavfilter/vf_libvmaf.c | 41 +++++++++++++++++++++++++++++++++++++++
 2 files changed, 42 insertions(+)

diff --git a/configure b/configure
index c1666a9..d4e0a8e 100755
--- a/configure
+++ b/configure
@@ -7392,6 +7392,7 @@ enabled libvidstab        && require_pkg_config libvidstab "vidstab >= 0.98" vid
 enabled libvmaf           && require_pkg_config libvmaf "libvmaf >= 2.0.0" libvmaf.h vmaf_init
 enabled libvmaf           && check_pkg_config libvmaf_cuda "libvmaf >= 2.0.0" libvmaf_cuda.h vmaf_cuda_state_init
 enabled libvmaf           && check_pkg_config libvmaf_sycl "libvmaf >= 3.0.0" libvmaf/libvmaf_sycl.h vmaf_sycl_state_init
+enabled libvmaf           && check_pkg_config libvmaf_vulkan "libvmaf >= 3.0.0" libvmaf/libvmaf_vulkan.h vmaf_vulkan_state_init
 enabled vmaf_pre_filter   && require_pkg_config libvmaf_dnn "libvmaf >= 3.0.0" libvmaf/dnn.h vmaf_dnn_session_open
 enabled libvo_amrwbenc    && { check_pkg_config libvo_amrwbenc vo-amrwbenc vo-amrwbenc/enc_if.h E_IF_init ||
                                require libvo_amrwbenc vo-amrwbenc/enc_if.h E_IF_init -lvo-amrwbenc; }
diff --git a/libavfilter/vf_libvmaf.c b/libavfilter/vf_libvmaf.c
index e3cf572..f5d29b4 100644
--- a/libavfilter/vf_libvmaf.c
+++ b/libavfilter/vf_libvmaf.c
@@ -51,6 +51,10 @@
 #include <libvmaf/libvmaf_sycl.h>
 #endif

+#if CONFIG_LIBVMAF_VULKAN
+#include <libvmaf/libvmaf_vulkan.h>
+#endif
+
 typedef struct LIBVMAFContext {
     const AVClass *class;
     FFFrameSync fs;
@@ -71,6 +75,10 @@ typedef struct LIBVMAFContext {
 #if CONFIG_LIBVMAF_SYCL
     VmafSyclState *sycl_state;
 #endif
+    int   vulkan_device;
+#if CONFIG_LIBVMAF_VULKAN
+    VmafVulkanState *vulkan_state;
+#endif

     VmafContext *vmaf;
     VmafModel **model;
@@ -98,6 +106,7 @@ static const AVOption libvmaf_options[] = {
     {"tiny_fp16",    "Request fp16 I/O when the device supports it.",                   OFFSET(tiny_fp16),       AV_OPT_TYPE_BOOL,   {.i64=0},      0, 1,        FLAGS},
     {"sycl_device",  "SYCL device index (-1 = disabled).",                              OFFSET(sycl_device),     AV_OPT_TYPE_INT,    {.i64=-1},    -1, INT_MAX,  FLAGS},
     {"sycl_profile", "Enable SYCL queue profiling.",                                    OFFSET(sycl_profile),    AV_OPT_TYPE_BOOL,   {.i64=0},      0, 1,        FLAGS},
+    {"vulkan_device","Vulkan device index (-1 = disabled; scaffold-only as of v3.0).",  OFFSET(vulkan_device),   AV_OPT_TYPE_INT,    {.i64=-1},    -1, INT_MAX,  FLAGS},
     { NULL }
 };

@@ -491,6 +500,30 @@ static av_cold int init(AVFilterContext *ctx)
 #endif
     }

+    if (s->vulkan_device >= 0) {
+#if CONFIG_LIBVMAF_VULKAN
+        VmafVulkanConfiguration vk_cfg = {
+            .device_index     = s->vulkan_device,
+            .enable_validation = 0,
+        };
+        err = vmaf_vulkan_state_init(&s->vulkan_state, vk_cfg);
+        if (err) {
+            av_log(ctx, AV_LOG_ERROR,
+                   "vmaf_vulkan_state_init(%d) failed: %d.\n",
+                   s->vulkan_device, err);
+            return AVERROR(EINVAL);
+        }
+        err = vmaf_vulkan_import_state(s->vmaf, s->vulkan_state);
+        if (err) {
+            av_log(ctx, AV_LOG_ERROR,
+                   "vmaf_vulkan_import_state failed: %d.\n", err);
+            return AVERROR(EINVAL);
+        }
+        av_log(ctx, AV_LOG_INFO,
+               "Vulkan backend active (device=%d)\n",
+               s->vulkan_device);
+#else
+        av_log(ctx, AV_LOG_ERROR,
+               "vulkan_device set but libvmaf was built without Vulkan support.\n");
+        return AVERROR(ENOSYS);
+#endif
+    }
+
     err = parse_models(ctx);
     if (err)
         return err;
@@ -694,6 +727,14 @@ clean_up:
         vmaf_sycl_state_free(s->sycl_state);
         s->sycl_state = NULL;
     }
+#endif
+
+#if CONFIG_LIBVMAF_VULKAN
+    if (s->vulkan_state) {
+        vmaf_vulkan_state_free(&s->vulkan_state);
+        s->vulkan_state = NULL;
+    }
 #endif
 }

-- 
2.54.0
