From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Lusoris <lusoris@pm.me>
Date: Sun, 11 May 2026 17:00:00 +0200
Subject: [PATCH] libvmaf: wire metal backend selector (metal_device option)

Adds a per-context Metal backend selector to the regular `libvmaf`
filter, mirroring the existing `sycl_device` / `vulkan_device` /
`hip_device` options from patches 0003 / 0004 / 0011 and the `cuda`
boolean from patch 0010.

When `metal_device >= -1` (special value -1 = system default Metal
device on Apple Silicon; 0+ = explicit MTLCopyAllDevices ordinal) the
filter:

  * initialises a VmafMetalState on the requested Metal device. The
    runtime gates on `[device supportsFamily:MTLGPUFamilyApple7]`, so
    Intel Macs and non-Apple hosts surface as -ENODEV. The fork's
    Apple-Silicon-only posture is documented in ADR-0361 and
    ADR-0420,
  * imports the state into the VmafContext via
    vmaf_metal_import_state(),
  * uses the standard vmaf_picture_alloc() path for AVFrame input.
    Apple Silicon's unified memory means the libvmaf-internal
    MTLBuffer allocator (`MTLResourceStorageModeShared`) reads the
    same DRAM the AVFrame's data pointers reference; no explicit
    H2D copy needed,
  * frees the state after vmaf_close() per the libvmaf_metal.h
    ownership contract (vmaf_metal_state_free takes a double pointer,
    matching vmaf_sycl_state_free / vmaf_vulkan_state_free /
    vmaf_hip_state_free).

Configure additions:

  * --enable-libvmaf-metal added to the configure help text and to
    EXTERNAL_LIBRARY_LIST, matching --enable-libvmaf-sycl /
    --enable-libvmaf-vulkan / --enable-libvmaf-cuda /
    --enable-libvmaf-hip.
  * enabled libvmaf_metal && require_pkg_config + check_pkg_config
    wiring; the libvmaf >= 3.0.0 floor matches the Vulkan / SYCL /
    HIP floor (the Metal header arrived in the same version bump).
  * enabled libvmaf && check_pkg_config libvmaf_metal auto-detects
    the in-filter selector when libvmaf was built with Metal but
    the user has not explicitly passed --enable-libvmaf-metal.

A dedicated `libvmaf_metal` filter for IOSurface hwdec import is
deferred: FFmpeg's VideoToolbox hwdec produces CVPixelBuffers that
back to IOSurface, and zero-copy IOSurface → MTLTexture is a real
optimisation but needs the libvmaf-side `vmaf_metal_picture_import`
companion entry point (not yet shipped — T8-1d follow-up). When that
lands a companion 0013 patch can be added. The gap is documented in
docs/state.md and docs/rebase-notes.md.

Closes the FFmpeg integration gap for Metal: --enable-libvmaf-metal
now exists alongside --enable-libvmaf-sycl / --enable-libvmaf-vulkan
/ --enable-libvmaf-cuda / --enable-libvmaf-hip. See ADR-0420 /
ADR-0421.

Validated against n8.1.1 with the cumulative 0001..0011 patch stack
applied; applies cleanly.
---
 configure                |  5 +++++
 libavfilter/vf_libvmaf.c | 45 ++++++++++++++++++++++++++++++++++++++++
 2 files changed, 50 insertions(+)

diff --git a/configure b/configure
index 405ffe1..7c8c8ef 100755
--- a/configure
+++ b/configure
@@ -296,6 +296,7 @@ External library support:
   --enable-libvidstab      enable video stabilization using vid.stab [no]
   --enable-libvmaf         enable vmaf filter via libvmaf [no]
   --enable-libvmaf-hip     enable HIP-accelerated vmaf filter via libvmaf [no]
+  --enable-libvmaf-metal   enable Metal-accelerated vmaf filter via libvmaf [no]
   --enable-libvmaf-cuda    enable CUDA-accelerated vmaf filter via libvmaf [no]
   --enable-libvmaf-sycl    enable SYCL-accelerated vmaf filter via libvmaf [no]
   --enable-libvmaf-vulkan  enable Vulkan-accelerated vmaf filter via libvmaf [no]
@@ -2104,6 +2105,7 @@ EXTERNAL_LIBRARY_LIST="
     libv4l2
     libvmaf
     libvmaf_hip
+    libvmaf_metal
     libvmaf_cuda
     libvmaf_sycl
     libvmaf_vulkan
@@ -7403,6 +7405,9 @@ enabled libvidstab        && require_pkg_config libvidstab "vidstab >= 0.98" vid
 enabled libvmaf           && require_pkg_config libvmaf "libvmaf >= 2.0.0" libvmaf.h vmaf_init
 enabled libvmaf_hip       && require_pkg_config libvmaf "libvmaf >= 3.0.0" libvmaf.h vmaf_init &&
                              check_pkg_config libvmaf_hip "libvmaf >= 3.0.0" libvmaf/libvmaf_hip.h vmaf_hip_state_init
 enabled libvmaf           && check_pkg_config libvmaf_hip "libvmaf >= 3.0.0" libvmaf/libvmaf_hip.h vmaf_hip_state_init
+enabled libvmaf_metal     && require_pkg_config libvmaf "libvmaf >= 3.0.0" libvmaf.h vmaf_init &&
+                             check_pkg_config libvmaf_metal "libvmaf >= 3.0.0" libvmaf/libvmaf_metal.h vmaf_metal_state_init
+enabled libvmaf           && check_pkg_config libvmaf_metal "libvmaf >= 3.0.0" libvmaf/libvmaf_metal.h vmaf_metal_state_init
 enabled libvmaf_cuda      && require_pkg_config libvmaf "libvmaf >= 2.0.0" libvmaf.h vmaf_init &&
                              check_pkg_config libvmaf_cuda "libvmaf >= 2.0.0" libvmaf_cuda.h vmaf_cuda_state_init
diff --git a/libavfilter/vf_libvmaf.c b/libavfilter/vf_libvmaf.c
index 0793356..5c4d5ad 100644
--- a/libavfilter/vf_libvmaf.c
+++ b/libavfilter/vf_libvmaf.c
@@ -72,6 +72,10 @@
 #include <libvmaf/libvmaf_hip.h>
 #endif

+#if CONFIG_LIBVMAF_METAL
+#include <libvmaf/libvmaf_metal.h>
+#endif
+
 typedef struct LIBVMAFContext {
     const AVClass *class;
     FFFrameSync fs;
@@ -108,6 +112,10 @@ typedef struct LIBVMAFContext {
 #if CONFIG_LIBVMAF_HIP
     VmafHipState *hip_state;            /* owned by the libvmaf filter when hip_device >= 0 */
 #endif
+    int   metal_device;
+#if CONFIG_LIBVMAF_METAL
+    VmafMetalState *metal_state;        /* owned by the libvmaf filter when metal_device >= -1 + !default-disabled */
+#endif

     VmafContext *vmaf;
     VmafModel **model;
@@ -139,6 +147,7 @@ static const AVOption libvmaf_options[] = {
     {"vulkan_device","Vulkan device index (-1 = disabled, 0+ = device index).",         OFFSET(vulkan_device),   AV_OPT_TYPE_INT,    {.i64=-1},    -1, INT_MAX,  FLAGS},
     {"cuda",         "Enable the CUDA backend on the primary device (software AVFrame input).", OFFSET(cuda),    AV_OPT_TYPE_BOOL,   {.i64=0},      0, 1,        FLAGS},
     {"hip_device",   "HIP device index (-1 = disabled, 0+ = device index).",            OFFSET(hip_device),      AV_OPT_TYPE_INT,    {.i64=-1},    -1, INT_MAX,  FLAGS},
+    {"metal_device", "Metal device index (-2 = disabled, -1 = system default, 0+ = MTLCopyAllDevices ordinal).", OFFSET(metal_device), AV_OPT_TYPE_INT, {.i64=-2}, -2, INT_MAX, FLAGS},
     { NULL }
 };

@@ -688,6 +697,35 @@ static av_cold int init(AVFilterContext *ctx)
 #endif
     }

+    if (s->metal_device >= -1) {
+#if CONFIG_LIBVMAF_METAL
+        VmafMetalConfiguration metal_cfg = {
+            .device_index = s->metal_device,
+            .flags        = 0,
+        };
+        err = vmaf_metal_state_init(&s->metal_state, metal_cfg);
+        if (err) {
+            av_log(ctx, AV_LOG_ERROR,
+                   "vmaf_metal_state_init(%d) failed: %d.\n",
+                   s->metal_device, err);
+            return AVERROR(-err);
+        }
+        err = vmaf_metal_import_state(s->vmaf, s->metal_state);
+        if (err) {
+            av_log(ctx, AV_LOG_ERROR,
+                   "vmaf_metal_import_state failed: %d.\n", err);
+            return AVERROR(-err);
+        }
+        av_log(ctx, AV_LOG_INFO,
+               "Metal backend active (device=%d)\n", s->metal_device);
+#else
+        av_log(ctx, AV_LOG_ERROR,
+               "metal_device set but libvmaf was built without Metal support "
+               "(rebuild with --enable-libvmaf-metal).\n");
+        return AVERROR(ENOSYS);
+#endif
+    }
+
     err = parse_models(ctx);
     if (err)
         return err;
@@ -921,6 +959,13 @@ clean_up:
         s->hip_state = NULL;
     }
 #endif
+
+#if CONFIG_LIBVMAF_METAL
+    if (s->metal_state) {
+        vmaf_metal_state_free(&s->metal_state);
+        s->metal_state = NULL;
+    }
+#endif
 }

 static const AVFilterPad libvmaf_inputs[] = {
--
2.54.0
