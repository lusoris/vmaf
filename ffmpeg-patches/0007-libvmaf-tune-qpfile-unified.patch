     svt_ret = svt_av1_enc_init(svt_enc->svt_handle);
     if (svt_ret != EB_ErrorNone) {
         return svt_print_error(avctx, svt_ret, "Error initializing encoder");
@@ -533,6 +600,193 @@ static av_cold int eb_enc_init(AVCodecContext *avctx)
     return alloc_buffer(&svt_enc->enc_params, svt_enc);
 }
 
+#if SVT_AV1_CHECK_VERSION(1, 6, 0)
+/* Translate a vmaf-tune qpfile into a fleet of per-frame
+ * SvtAv1RoiMapEvt records.
+ *
+ * Strategy:
+ *   1. Per frame, discover the QP-offset value range; pick up to
+ *      QPFILE_SVTAV1_MAX_SEGMENTS distinct segment QPs (uniform
+ *      binning when the value span exceeds the segment budget).
+ *   2. Downsample the qpfile's per-16x16-MB grid to SVT-AV1's
+ *      per-64x64-SB grid by averaging the four MBs that overlap
+ *      each SB and assigning the nearest segment id.
+ *   3. Size b64_seg_map at the encoder's actual SB grid stride
+ *      ((max_input_luma_width+63)/64) so segmentation.c can index
+ *      it correctly even if the qpfile was cut against a smaller
+ *      preview.
+ *
+ * Per-SB rectangles fall out naturally — SVT-AV1 consumes a dense
+ * per-SB segment map, so explicit rectangle decomposition would
+ * be redundant. Trade-off: per-MB qpfile resolution is rounded
+ * to per-SB granularity, losing spatial detail finer than 64x64
+ * px (a salient face smaller than that gets averaged with its
+ * surroundings). Acceptable for saliency_student_v1's object-
+ * sized ROIs; finer granularity would require an SVT-AV1 ABI
+ * change (ADR-0312, SVT-AV1 deferral retired).
+ *
+ * Lifetime: the library shallow-copies ROI_MAP_EVENT pointers
+ * (copy_private_data_list in enc_handle.c) and reads them later
+ * on async pipeline threads, so the SvtAv1RoiMapEvt and its
+ * b64_seg_map must outlive svt_av1_enc_send_picture() — they
+ * are owned by SvtContext and freed in eb_enc_close().
+ */
+#define QPFILE_SVTAV1_MAX_SEGMENTS 8
+#define QPFILE_SVTAV1_SB_SIDE      4   /* 4 MBs (16 px each) per SB (64 px) */
+
+static int build_one_roi_evt(const VmafTuneQpFrame *qf,
+                             unsigned dest_b64_cols,
+                             unsigned dest_b64_rows,
+                             SvtAv1RoiMapEvt *out_evt,
+                             uint8_t **out_seg_map)
+{
+    unsigned mb_cols = qf->block_cols;
+    unsigned mb_rows = qf->block_rows;
+    int seg_values[QPFILE_SVTAV1_MAX_SEGMENTS];
+    unsigned n_seg = 0;
+    unsigned i, j, sb_x, sb_y;
+    int min_off = QPFILE_DELTA_MAX, max_off = QPFILE_DELTA_MIN;
+    uint8_t *seg_map = NULL;
+
+    if (mb_cols == 0 || mb_rows == 0 || !qf->block_offsets ||
+        dest_b64_cols == 0 || dest_b64_rows == 0)
+        return AVERROR(EINVAL);
+
+    /* Pass 1: discover the value range. */
+    for (i = 0; i < mb_rows; i++) {
+        for (j = 0; j < mb_cols; j++) {
+            int v = qf->block_offsets[i * mb_cols + j];
+            if (v < min_off) min_off = v;
+            if (v > max_off) max_off = v;
+        }
+    }
+
+    /* Pass 2: pick segment QPs. */
+    if (max_off == min_off) {
+        seg_values[0] = min_off;
+        n_seg = 1;
+    } else {
+        int span = max_off - min_off + 1;
+        if (span <= QPFILE_SVTAV1_MAX_SEGMENTS) {
+            for (int v = min_off; v <= max_off; v++)
+                seg_values[n_seg++] = v;
+        } else {
+            for (i = 0; i < QPFILE_SVTAV1_MAX_SEGMENTS; i++) {
+                int v = min_off +
+                    (int)((unsigned long)(max_off - min_off) * i /
+                          (QPFILE_SVTAV1_MAX_SEGMENTS - 1u));
+                seg_values[i] = v;
+            }
+            n_seg = QPFILE_SVTAV1_MAX_SEGMENTS;
+        }
+    }
+
+    /* Pass 3: emit the per-SB segment map at the encoder grid. */
+    seg_map = av_calloc((size_t)dest_b64_rows * dest_b64_cols,
+                        sizeof(*seg_map));
+    if (!seg_map)
+        return AVERROR(ENOMEM);
+
+    for (sb_y = 0; sb_y < dest_b64_rows; sb_y++) {
+        for (sb_x = 0; sb_x < dest_b64_cols; sb_x++) {
+            long sum = 0;
+            unsigned count = 0;
+            unsigned mb_y0 = sb_y * QPFILE_SVTAV1_SB_SIDE;
+            unsigned mb_x0 = sb_x * QPFILE_SVTAV1_SB_SIDE;
+            unsigned mb_y1 = mb_y0 + QPFILE_SVTAV1_SB_SIDE;
+            unsigned mb_x1 = mb_x0 + QPFILE_SVTAV1_SB_SIDE;
+            int avg, best_idx = 0, best_dist = INT_MAX;
+            if (mb_y1 > mb_rows) mb_y1 = mb_rows;
+            if (mb_x1 > mb_cols) mb_x1 = mb_cols;
+            if (mb_x0 >= mb_cols || mb_y0 >= mb_rows) {
+                /* SB lies outside the qpfile coverage — leave at seg 0
+                 * (zero offset). The qpfile may be smaller than the
+                 * encoder's padded SB grid; the saliency model is
+                 * applied where defined and elsewhere we encode at
+                 * the encoder's default rate-control decision. */
+                seg_map[sb_y * dest_b64_cols + sb_x] = 0;
+                continue;
+            }
+            for (i = mb_y0; i < mb_y1; i++) {
+                for (j = mb_x0; j < mb_x1; j++) {
+                    sum += qf->block_offsets[i * mb_cols + j];
+                    count++;
+                }
+            }
+            avg = count ? (int)(sum / (long)count) : 0;
+            for (i = 0; i < n_seg; i++) {
+                int d = avg - seg_values[i];
+                if (d < 0) d = -d;
+                if (d < best_dist) {
+                    best_dist = d;
+                    best_idx = (int)i;
+                }
+            }
+            seg_map[sb_y * dest_b64_cols + sb_x] = (uint8_t)best_idx;
+        }
+    }
+
+    memset(out_evt, 0, sizeof(*out_evt));
+    out_evt->start_picture_number = qf->frame_index;
+    out_evt->b64_seg_map          = seg_map;
+    out_evt->max_seg_id           = (int8_t)(n_seg - 1u);
+    for (i = 0; i < n_seg; i++)
+        out_evt->seg_qp[i] = (int16_t)seg_values[i];
+    out_evt->next = NULL;
+    *out_seg_map = seg_map;
+    return 0;
+}
+
+static int build_all_roi_evts(AVCodecContext *avctx, SvtContext *svt_enc)
+{
+    unsigned i;
+    unsigned b64_cols = ((unsigned)avctx->width  + 63u) / 64u;
+    unsigned b64_rows = ((unsigned)avctx->height + 63u) / 64u;
+    unsigned n = svt_enc->qpfile.frame_count;
+
+    if (n == 0 || b64_cols == 0 || b64_rows == 0)
+        return AVERROR(EINVAL);
+
+    svt_enc->roi_evts = av_calloc(n, sizeof(*svt_enc->roi_evts));
+    svt_enc->roi_seg_maps = av_calloc(n, sizeof(*svt_enc->roi_seg_maps));
+    if (!svt_enc->roi_evts || !svt_enc->roi_seg_maps)
+        return AVERROR(ENOMEM);
+    svt_enc->roi_evt_count = n;
+    svt_enc->roi_b64_cols  = b64_cols;
+    svt_enc->roi_b64_rows  = b64_rows;
+
+    for (i = 0; i < n; i++) {
+        int qret = build_one_roi_evt(&svt_enc->qpfile.frames[i],
+                                     b64_cols, b64_rows,
+                                     &svt_enc->roi_evts[i],
+                                     &svt_enc->roi_seg_maps[i]);
+        if (qret < 0) {
+            av_log(avctx, AV_LOG_ERROR,
+                   "libsvtav1: failed to build ROI map for qpfile frame %u (%d)\n",
+                   i, qret);
+            return qret;
+        }
+    }
+    return 0;
+}
+
+static SvtAv1RoiMapEvt *roi_evt_for_pts(SvtContext *svt_enc, int64_t pts)
+{
+    /* Match qpfile frame_index to PTS; bounded linear scan (qpfiles
+     * are short for vmaf-tune). Falls back to the last entry when
+     * the qpfile is shorter than the stream — mirrors the saliency.py
+     * "one mask, all frames" pattern. */
+    unsigned k;
+    if (pts < 0 || svt_enc->roi_evt_count == 0)
+        return NULL;
+    for (k = 0; k < svt_enc->roi_evt_count; k++) {
+        if (svt_enc->roi_evts[k].start_picture_number == (uint64_t)pts)
+            return &svt_enc->roi_evts[k];
+    }
+    return &svt_enc->roi_evts[svt_enc->roi_evt_count - 1u];
+}
