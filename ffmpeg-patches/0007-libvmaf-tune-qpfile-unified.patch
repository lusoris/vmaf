diff --git a/libavcodec/qpfile_parser.c b/libavcodec/qpfile_parser.c
new file mode 100644
index 0000000000..cf781305ac
--- /dev/null
+++ b/libavcodec/qpfile_parser.c
@@ -0,0 +1,302 @@
+/*
+ * Copyright 2026 Lusoris and Claude (Anthropic)
+ *
+ * This file is part of FFmpeg.
+ *
+ * FFmpeg is free software; you can redistribute it and/or modify it under
+ * the terms of the GNU Lesser General Public License as published by the
+ * Free Software Foundation; either version 2.1 of the License, or (at
+ * your option) any later version.
+ *
+ * FFmpeg is distributed in the hope that it will be useful, but WITHOUT
+ * ANY WARRANTY; without even the implied warranty of MERCHANTABILITY or
+ * FITNESS FOR A PARTICULAR PURPOSE. See the GNU Lesser General Public
+ * License for more details.
+ */
+
+/**
+ * @file
+ * Shared parser for the vmaf-tune qpfile format consumed by libx264,
+ * libsvtav1, and libaom-av1 encoder adapters. See ADR-0312 and
+ * tools/vmaf-tune/src/vmaftune/saliency.py for the format definition.
+ *
+ * Format (ASCII, one logical record per frame):
+ *
+ *     <frame_idx> <I|P|B> <baseline_qp>
+ *     <delta_0_0> <delta_0_1> ... <delta_0_(bw-1)>
+ *     ...
+ *
+ * NASA POW10 / SEI CERT C: bounded loops, no recursion, no banned
+ * functions (uses strtol, never atoi/sprintf/strcpy). Line reading
+ * uses a portable fgetc loop (not POSIX getline) so we don't drag
+ * in feature-test macros.
+ */
+
+#include <errno.h>
+#include <limits.h>
+#include <stdio.h>
+#include <stdlib.h>
+#include <string.h>
+
+#include "libavutil/error.h"
+#include "libavutil/mem.h"
+
+#include "qpfile_parser.h"
+
+#define QPFILE_MAX_FRAMES         (1u << 20)
+#define QPFILE_MAX_BLOCKS_PER_DIM (1u << 14)
+#define QPFILE_MAX_LINE_BYTES     (1u << 20)
+
+static int parse_long(const char *s, char **end, long *out)
+{
+    long v;
+    errno = 0;
+    v = strtol(s, end, 10);
+    if (errno == ERANGE)
+        return AVERROR(ERANGE);
+    if (*end == s)
+        return AVERROR(EINVAL);
+    *out = v;
+    return 0;
+}
+
+static int clamp_offset(long v)
+{
+    if (v < QPFILE_DELTA_MIN) return QPFILE_DELTA_MIN;
+    if (v > QPFILE_DELTA_MAX) return QPFILE_DELTA_MAX;
+    return (int)v;
+}
+
+static int looks_like_header(const char *line)
+{
+    const char *p = line;
+    while (*p == ' ' || *p == '\t') p++;
+    if (*p < '0' || *p > '9') return 0;
+    while (*p >= '0' && *p <= '9') p++;
+    while (*p == ' ' || *p == '\t') p++;
+    return (*p == 'I' || *p == 'P' || *p == 'B' ||
+            *p == 'i' || *p == 'p' || *p == 'b');
+}
+
+static int parse_header(const char *line, VmafTuneQpFrame *f)
+{
+    char *p = NULL;
+    long idx = 0, qp = 0;
+    char kind = 0;
+    const char *cur = line;
+    int err;
+
+    err = parse_long(cur, &p, &idx);
+    if (err < 0) return err;
+    if (idx < 0 || (unsigned long)idx > QPFILE_MAX_FRAMES)
+        return AVERROR(EINVAL);
+    cur = p;
+    while (*cur == ' ' || *cur == '\t') cur++;
+    kind = *cur;
+    if (kind != 'I' && kind != 'P' && kind != 'B' &&
+        kind != 'i' && kind != 'p' && kind != 'b')
+        return AVERROR(EINVAL);
+    cur++;
+    while (*cur == ' ' || *cur == '\t') cur++;
+    err = parse_long(cur, &p, &qp);
+    if (err < 0) return err;
+    if (qp < 0 || qp > 63) return AVERROR(EINVAL);
+
+    f->frame_index   = (unsigned)idx;
+    f->frame_type    = (char)((kind >= 'a' && kind <= 'z') ? kind - 32 : kind);
+    f->baseline_qp   = (int)qp;
+    f->block_offsets = NULL;
+    f->block_cols    = 0;
+    f->block_rows    = 0;
+    return 0;
+}
+
+static unsigned count_tokens(const char *line)
+{
+    unsigned n = 0;
+    int in_tok = 0;
+    for (const char *p = line; *p; p++) {
+        if (*p == ' ' || *p == '\t' || *p == '\r' || *p == '\n') {
+            in_tok = 0;
+        } else if (!in_tok) {
+            in_tok = 1;
+            n++;
+            if (n > QPFILE_MAX_BLOCKS_PER_DIM)
+                return n;
+        }
+    }
+    return n;
+}
+
+static int parse_row(const char *line, int *row_out, unsigned bw)
+{
+    char *p = NULL;
+    const char *cur = line;
+    long v = 0;
+    int err;
+    for (unsigned i = 0; i < bw; i++) {
+        err = parse_long(cur, &p, &v);
+        if (err < 0) return err;
+        row_out[i] = clamp_offset(v);
+        cur = p;
+        while (*cur == ' ' || *cur == '\t') cur++;
+    }
+    return 0;
+}
+
+/* Portable line reader (no POSIX getline dependency). */
+static int qpfile_getline(char **buf, size_t *cap, FILE *fp, ssize_t *out_len)
+{
+    size_t pos = 0;
+    if (*cap == 0 || !*buf) {
+        *cap = 4096;
+        *buf = av_realloc(*buf, *cap);
+        if (!*buf) return AVERROR(ENOMEM);
+    }
+    while (1) {
+        if (pos + 1 >= *cap) {
+            size_t nc = (*cap) * 2u;
+            char *nb = av_realloc(*buf, nc);
+            if (!nb) return AVERROR(ENOMEM);
+            *buf = nb;
+            *cap = nc;
+        }
+        int c = fgetc(fp);
+        if (c == EOF) {
+            if (pos == 0) { *out_len = -1; return 0; }
+            (*buf)[pos] = 0;
+            *out_len = (ssize_t)pos;
+            return 0;
+        }
+        (*buf)[pos++] = (char)c;
+        if (c == '\n') {
+            (*buf)[pos] = 0;
+            *out_len = (ssize_t)pos;
+            return 0;
+        }
+        if (pos > QPFILE_MAX_LINE_BYTES)
+            return AVERROR(EINVAL);
+    }
+}
+
+int ff_qpfile_load(const char *path, VmafTuneQpFile *out)
+{
+    FILE *fp = NULL;
+    char *line = NULL;
+    size_t line_cap = 0;
+    int ret = 0;
+    unsigned bw = 0, bh = 0, cap_frames = 0;
+    int *row_buf = NULL;
+    unsigned row_count = 0;
+    VmafTuneQpFrame *cur_frame = NULL;
+
+    if (!path || !out) return AVERROR(EINVAL);
+    memset(out, 0, sizeof(*out));
+
+    fp = fopen(path, "rb");
+    if (!fp) return AVERROR(errno ? errno : ENOENT);
+
+    cap_frames = 16;
+    out->frames = av_calloc(cap_frames, sizeof(*out->frames));
+    if (!out->frames) { ret = AVERROR(ENOMEM); goto fail; }
+
+    while (1) {
+        ssize_t got = 0;
+        ret = qpfile_getline(&line, &line_cap, fp, &got);
+        if (ret < 0) goto fail;
+        if (got < 0) break;
+        if ((size_t)got > QPFILE_MAX_LINE_BYTES) { ret = AVERROR(EINVAL); goto fail; }
+        if (got == 0 || line[0] == '#' || line[0] == '\n' || line[0] == '\r')
+            continue;
+
+        if (looks_like_header(line)) {
+            if (cur_frame && row_count > 0) {
+                if (bw == 0) { bw = cur_frame->block_cols; bh = row_count; }
+                else if (row_count != bh) { ret = AVERROR(EINVAL); goto fail; }
+                cur_frame->block_offsets = av_calloc((size_t)bh * bw, sizeof(int));
+                if (!cur_frame->block_offsets) { ret = AVERROR(ENOMEM); goto fail; }
+                memcpy(cur_frame->block_offsets, row_buf,
+                       (size_t)bh * bw * sizeof(int));
+                cur_frame->block_rows = bh;
+                cur_frame->block_cols = bw;
+            }
+
+            if (out->frame_count == cap_frames) {
+                unsigned nc = cap_frames * 2u;
+                if (nc > QPFILE_MAX_FRAMES) { ret = AVERROR(EINVAL); goto fail; }
+                VmafTuneQpFrame *nf = av_realloc_array(out->frames, nc, sizeof(*nf));
+                if (!nf) { ret = AVERROR(ENOMEM); goto fail; }
+                memset(nf + cap_frames, 0, (nc - cap_frames) * sizeof(*nf));
+                out->frames = nf;
+                cap_frames = nc;
+            }
+
+            cur_frame = &out->frames[out->frame_count];
+            ret = parse_header(line, cur_frame);
+            if (ret < 0) goto fail;
+            out->frame_count++;
+            row_count = 0;
+        } else {
+            if (!cur_frame) { ret = AVERROR(EINVAL); goto fail; }
+            unsigned tokens = count_tokens(line);
+            if (tokens == 0) continue;
+            if (tokens > QPFILE_MAX_BLOCKS_PER_DIM) { ret = AVERROR(EINVAL); goto fail; }
+            if (cur_frame->block_cols == 0) {
+                cur_frame->block_cols = tokens;
+                if (bw && tokens != bw) { ret = AVERROR(EINVAL); goto fail; }
+            } else if (tokens != cur_frame->block_cols) {
+                ret = AVERROR(EINVAL); goto fail;
+            }
+            unsigned this_bw = cur_frame->block_cols;
+            unsigned needed = (row_count + 1) * this_bw;
+            int *nrow = av_realloc_array(row_buf, needed, sizeof(int));
+            if (!nrow) { ret = AVERROR(ENOMEM); goto fail; }
+            row_buf = nrow;
+            ret = parse_row(line, &row_buf[row_count * this_bw], this_bw);
+            if (ret < 0) goto fail;
+            row_count++;
+            if (row_count > QPFILE_MAX_BLOCKS_PER_DIM) { ret = AVERROR(EINVAL); goto fail; }
+        }
+    }
+
+    if (cur_frame && row_count > 0) {
+        if (bw == 0) { bw = cur_frame->block_cols; bh = row_count; }
+        else if (row_count != bh) { ret = AVERROR(EINVAL); goto fail; }
+        cur_frame->block_offsets = av_calloc((size_t)bh * bw, sizeof(int));
+        if (!cur_frame->block_offsets) { ret = AVERROR(ENOMEM); goto fail; }
+        memcpy(cur_frame->block_offsets, row_buf,
+               (size_t)bh * bw * sizeof(int));
+        cur_frame->block_rows = bh;
+        cur_frame->block_cols = bw;
+    }
+    av_freep(&row_buf);
+
+    out->block_cols = bw;
+    out->block_rows = bh;
+
+    if (out->frame_count == 0) { ret = AVERROR(EINVAL); goto fail; }
+
+    av_free(line);
+    fclose(fp);
+    return 0;
+
+fail:
+    av_freep(&row_buf);
+    av_free(line);
+    if (fp) fclose(fp);
+    ff_qpfile_free(out);
+    return ret;
+}
+
+void ff_qpfile_free(VmafTuneQpFile *qpf)
+{
+    if (!qpf) return;
+    if (qpf->frames) {
+        for (unsigned i = 0; i < qpf->frame_count; i++)
+            av_freep(&qpf->frames[i].block_offsets);
+        av_freep(&qpf->frames);
+    }
+    qpf->frame_count = 0;
+    qpf->block_cols  = 0;
+    qpf->block_rows  = 0;
+}
