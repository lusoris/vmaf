+#endif
+
 static av_cold int eb_enc_init(AVCodecContext *avctx)
 {
     SvtContext   *svt_enc = avctx->priv_data;
@@ -487,11 +518,47 @@ static av_cold int eb_enc_init(AVCodecContext *avctx)
         return ret;
     }
 
+    if (svt_enc->qpfile_path && *svt_enc->qpfile_path) {
+        int qret = ff_qpfile_load(svt_enc->qpfile_path, &svt_enc->qpfile);
+        if (qret < 0) {
+            av_log(avctx, AV_LOG_ERROR, "libsvtav1: qpfile=%s parse failed (%d).\n",
+                   svt_enc->qpfile_path, qret);
+            return qret;
