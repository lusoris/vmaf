+/**
+ * @file
+ * Shared parser for the vmaf-tune qpfile format. Consumed by libx264,
+ * libsvtav1, and libaom-av1 encoder adapters via the new -qpfile
+ * AVOption.
+ *
+ * Patches 0007-0009 of ffmpeg-patches/ must keep this parser shared
+ * so future encoder additions inherit it (vmaf-tune patch invariant -
+ * see ffmpeg-patches/README.md and ADR-0312).
+ */
+
+#ifndef AVCODEC_QPFILE_PARSER_H
+#define AVCODEC_QPFILE_PARSER_H
+
+#include <stddef.h>
+
+#define QPFILE_DELTA_MIN (-12)
+#define QPFILE_DELTA_MAX (12)
+
+typedef struct VmafTuneQpFrame {
+    unsigned int frame_index;
+    char         frame_type;
+    int          baseline_qp;
+    int         *block_offsets;
+    unsigned int block_cols;
+    unsigned int block_rows;
+} VmafTuneQpFrame;
+
+typedef struct VmafTuneQpFile {
+    VmafTuneQpFrame *frames;
+    unsigned int     frame_count;
+    unsigned int     block_cols;
+    unsigned int     block_rows;
+} VmafTuneQpFile;
+
+int  ff_qpfile_load(const char *path, VmafTuneQpFile *out);
+void ff_qpfile_free(VmafTuneQpFile *qpf);
+
+#endif /* AVCODEC_QPFILE_PARSER_H */
