# Caches, build artifacts
.DS_Store
.cache/
*.egg*
.gradle/
.idea/
*.py[cod]
.pypirc
.tox/
.*version
.venv*/
__pycache__/
build/
dist/
vmaf_output.xml
compile_commands.json

# Large test data (generated via testdata/generate.sh)
testdata/*_1280x720_*.yuv
testdata/*_1920x1080_*.yuv
testdata/*_3840x2160_*.yuv
testdata/bbb/*.yuv

# Large binary files
*.mp4
*.mkv

# Upstream MATLAB MEX compiled artefacts (platform-specific binaries).
# Rebuild locally via `mex file.c` if you need the MATLAB reference path.
# See Scorecard Binary-Artifacts / D38.
python/vmaf/matlab/**/*.mex
python/vmaf/matlab/**/*.mex[0-9]*
python/vmaf/matlab/**/*.mexa64
python/vmaf/matlab/**/*.mexglx
python/vmaf/matlab/**/*.mexlx
python/vmaf/matlab/**/*.mexmac
python/vmaf/matlab/**/*.mexmaci64
python/vmaf/matlab/**/*.mexsol
python/vmaf/matlab/**/*.mexw32
python/vmaf/matlab/**/*.mexw64
python/vmaf/matlab/**/*.dll
python/vmaf/matlab/**/*.exp
python/vmaf/matlab/**/*.lib
python/vmaf/matlab/**/*.o

# Working/scratch directories
.workingdir/
.workingdir2/

# Claude Code local (machine-specific) settings
.claude/settings.local.json
.claude/scheduled_tasks.lock

# Generated benchmark results
testdata/bbb/results/
build-docs/
preprints202604.0035.v1.pdf
