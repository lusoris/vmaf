# Caches, build artifacts
.DS_Store
.cache/
*.egg*
.gradle/
.idea/
*.py[cod]
.pypirc
.tox/
.*version
.venv*/
__pycache__/
build/
dist/
vmaf_output.xml
compile_commands.json

# tiny-AI training artifacts (re-generated by ai/scripts/train_konvid.py).
# The contents of ai/data/ are gitignored EXCEPT the ADR-0203 Python
# modules. We use the "ignore everything inside the dir, then re-allow
# .py" pattern so the dir itself stays tracked for the modules below.
ai/data/*
!ai/data/__init__.py
!ai/data/netflix_loader.py
!ai/data/feature_extractor.py
!ai/data/scores.py
# Phase F.5 calibrated recipe overrides (ADR-0325).
# Tracked as a tiny JSON snapshot — regenerated by
# ai/scripts/calibrate_phase_f_recipes.py against a real corpus.
!ai/data/phase_f_recipes_calibrated.json
# ADR-0335 — hardware-capability prior table is small, hand-curated,
# and committed in-tree (not a generated artifact).
!ai/data/hardware_caps.csv
runs/

# Large test data (generated via testdata/generate.sh)
testdata/*_1280x720_*.yuv
testdata/*_1920x1080_*.yuv
testdata/*_3840x2160_*.yuv
testdata/bbb/*.yuv

# Large binary files
*.mp4
*.mkv

# Upstream MATLAB MEX compiled artefacts (platform-specific binaries).
# Rebuild locally via `mex file.c` if you need the MATLAB reference path.
# See Scorecard Binary-Artifacts / D38.
python/vmaf/matlab/**/*.mex
python/vmaf/matlab/**/*.mex[0-9]*
python/vmaf/matlab/**/*.mexa64
python/vmaf/matlab/**/*.mexglx
python/vmaf/matlab/**/*.mexlx
python/vmaf/matlab/**/*.mexmac
python/vmaf/matlab/**/*.mexmaci64
python/vmaf/matlab/**/*.mexsol
python/vmaf/matlab/**/*.mexw32
python/vmaf/matlab/**/*.mexw64
python/vmaf/matlab/**/*.dll
python/vmaf/matlab/**/*.exp
python/vmaf/matlab/**/*.lib
python/vmaf/matlab/**/*.o

# Working/scratch directories
.workingdir/
.workingdir2/
.corpus/

# vmaf-tune Phase A scratch outputs (ADR-0237)
corpus.jsonl
tools/vmaf-tune/build/
tools/vmaf-tune/dist/
tools/vmaf-tune/*.egg-info/

# external-bench harness scratch / binary downloads (ADR-0332)
tools/external-bench/**/build/
tools/external-bench/**/dist/
tools/external-bench/**/*.bin
tools/external-bench/**/output*.json
tools/external-bench/**/__pycache__/

# Claude Code local (machine-specific) settings
.claude/settings.local.json
.claude/scheduled_tasks.lock

# Generated benchmark results
testdata/bbb/results/
build-docs/
preprints202604.0035.v1.pdf

# Meson wrap-fetched subprojects (downloaded at meson setup time).
# Only the .wrap files + packagefiles/ are tracked; the unpacked
# upstream trees are gitignored.
libvmaf/subprojects/*/
!libvmaf/subprojects/packagefiles/
libvmaf/subprojects/packagecache/
libvmaf/subprojects/.wraplock

# Per-run training output (per-epoch ONNX checkpoints)
model/tiny/training_runs/

# u2netp fork-local mirror (ADR-0325). Binary lives only in GitHub
# Releases; the scaffold (license, model card, operator doc, release
# workflow guard) is tracked, the binary itself is not.
model/u2netp_mirror.onnx
model/u2netp_mirror.pth
